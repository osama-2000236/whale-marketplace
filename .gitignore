# ──────────────────────────────────────────────────────────────
# Whale Marketplace — .gitignore
# Purpose: Exclude secrets, build artifacts, and user uploads
# Author: Whale Development Team
# Created: 2026-03-18
# ──────────────────────────────────────────────────────────────

# ── Dependencies ──
node_modules/

# ── Environment secrets — NEVER commit these ──
.env
.env.local
.env.test
.env.production
.env.staging

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── User uploads — served from Cloudinary in production ──
public/uploads/

# ── Product images (local dev only, Cloudinary in prod) ──
public/images/products/*
!public/images/products/.gitkeep
!public/images/products/placeholder.svg

# ── OS files ──
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── Test output ──
coverage/
playwright-report/
__uitests__/screenshots/
test-results/
.nyc_output/

# ── Build artifacts ──
dist/
build/
*.min.css.map

# ── IDE / Editor / Tools ──
.idea/
.vscode/
*.code-workspace
.claude/

# ── Railway / Docker ──
.railway/
