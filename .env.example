# ============================================
# WHALE MARKETPLACE — ENVIRONMENT VARIABLES
# ============================================
# انسخ هذا الملف إلى .env ثم حدّث القيم حسب بيئتك
# For Railway: set these in the service's Variables tab

# Server
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000

# Database (PostgreSQL) — Railway provides this automatically when you add a DB
# Append ?connection_limit=10&pool_timeout=30 in production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whale_db?schema=public

# Session — REQUIRED in production. Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-random-64-char-string

# Cloudinary (optional, fallback is /public/uploads)
CLOUDINARY_URL=

# Claude provider
# CLAUDE_PROVIDER can be "anthropic" or "openrouter"
CLAUDE_PROVIDER=anthropic
CLAUDE_MAX_TOKENS=512

# Anthropic direct API
# Verified official model as of March 17, 2026:
# ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter (supports Claude models via a different key format, e.g. sk-or-v1-...)
# Recommended Claude Sonnet 4.6 model id on OpenRouter:
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Admin account (used in seed and startup sync)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@pcgaming.local
ADMIN_PASSWORD=PcGaming@2024

# WhatsApp
WHATSAPP_NUMBER=970597127547
CONTACT_EMAIL=contact@whale.ps

# Language/theme defaults
DEFAULT_LANG=ar
DEFAULT_THEME=light

# CORS — comma-separated allowed origins (production only)
ALLOWED_ORIGINS=https://your-domain.up.railway.app

# Upload limits
MAX_FILE_SIZE=5242880

# Payment provider: "paymob" for Arab region, "paypal" as fallback
PAYMENT_PROVIDER=paymob

# Paymob — register at dashboard.paymob.com
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=

# PayPal — register at developer.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Subscription pricing
SUBSCRIPTION_PRICE_NIS=20
SUBSCRIPTION_PRICE_EGP=170
SUBSCRIPTION_PRICE_USD=6

# Your production domain (used in QR codes and payment redirects)
BASE_URL=https://yourdomain.com
OAUTH_CALLBACK_BASE=http://localhost:3000

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./keys/AuthKey_XXXXXXXXXX.p8

# Email delivery
EMAIL_PROVIDER=smtp
SENDGRID_API_KEY=
EMAIL_FROM=noreply@whale.ps
EMAIL_FROM_NAME=Whale · الحوت
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Marketplace settings
MARKETPLACE_COMMISSION_PERCENT=0
MARKETPLACE_BOOST_PRICE_NIS=15
MARKETPLACE_BOOST_DAYS=7
MARKETPLACE_FREE_LISTINGS_PER_MONTH=3
AUTO_COMPLETE_DAYS=14
