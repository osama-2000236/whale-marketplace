<%- include('../partials/header') %>

<section class="page-section listing-detail-page">
  <div class="container">
    <div class="listing-detail-grid">
      <div class="listing-gallery">
        <img src="<%= listing.images && listing.images[0] ? listing.images[0] : '/images/products/placeholder.svg' %>" alt="<%= listing.titleAr || listing.title %>" class="listing-main-image">
        <% if (listing.images && listing.images.length > 1) { %>
          <div class="listing-thumbs">
            <% listing.images.forEach((img) => { %>
              <img src="<%= img %>" alt="thumb" loading="lazy">
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="listing-detail-content">
        <h1><%= listing.titleAr || listing.title %></h1>
        <% if (listing.titleAr && listing.title) { %>
          <p class="muted"><%= listing.title %></p>
        <% } %>

        <div class="listing-detail-price">₪ <%= Number(listing.price || 0).toLocaleString() %></div>
        <p class="listing-attrs"><span><%= listing.condition %></span> • <span><%= listing.category %></span> • <span><%= listing.location %></span></p>

        <p dir="<%= getDirection ? getDirection(listing.descriptionAr || listing.description || '') : 'rtl' %>"><%= listing.descriptionAr || listing.description %></p>

        <% if (currentUser) { %>
          <a
            class="btn-whatsapp"
            target="_blank"
            href="https://wa.me/<%= listing.whatsappNumber %>?text=<%= encodeURIComponent('مهتم بالإعلان: ' + (listing.titleAr || listing.title)) %>"
          >💬 تواصل عبر واتساب / Contact on WhatsApp</a>
        <% } else { %>
          <a href="/auth/register?reason=contact" class="btn btn-secondary">🔒 سجّل مجاناً للتواصل مع البائع / Register free to contact seller</a>
        <% } %>
        <button type="button" class="btn btn-outline btn-sm">🚩 تبليغ عن الإعلان | Report Listing</button>

        <div class="listing-stats">👁️ <%= listing.views %> مشاهدات | views</div>
      </div>

      <aside class="listing-seller panel-card">
        <h3>البائع | Seller</h3>
        <a href="/u/<%= listing.seller.username %>" class="seller-link">
          <%- include('../partials/avatar', { user: listing.seller, size: 'md' }) %>
          <div>
            <strong><%= listing.seller.username %></strong>
            <p>عضو منذ | Since <%= new Date(listing.seller.createdAt).toLocaleDateString('ar-PS') %></p>
          </div>
        </a>

        <h4>إعلانات أخرى | Other listings</h4>
        <% if (listing.sellerOtherListings && listing.sellerOtherListings.length) { %>
          <ul class="simple-list">
            <% listing.sellerOtherListings.forEach((item) => { %>
              <li><a href="/marketplace/<%= item.id %>"><%= item.titleAr || item.title %></a></li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="muted">لا يوجد | None</p>
        <% } %>
      </aside>
    </div>

    <section class="related-listings">
      <h2>إعلانات مشابهة | Related Listings</h2>
      <div class="market-grid">
        <% if (listing.related && listing.related.length) { %>
          <% listing.related.forEach((related) => { %>
            <%- include('../partials/listing-card', { listing: related }) %>
          <% }) %>
        <% } else { %>
          <p class="muted">لا يوجد إعلانات مشابهة | No related listings</p>
        <% } %>
      </div>
    </section>
  </div>
</section>

<%- include('../partials/footer') %>
