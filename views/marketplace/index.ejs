<%- include('../partials/header') %>

<section class="page-section marketplace-page">
  <% if (!currentUser) { %>
    <div class="container" style="margin-bottom: 10px;">
      <div class="guest-banner" style="position: static; border-radius: 10px;">
        <span>🛒 تريد البيع؟ / Want to sell?</span>
        <a href="/welcome">سجّل مجاناً واحصل على شهر Pro مجاني / Register free — get 1 month Pro</a>
      </div>
    </div>
  <% } %>

  <div class="container marketplace-layout">
    <aside class="market-filters panel-card">
      <h3>فلترة | Filters</h3>
      <form method="GET" action="/marketplace" class="market-filter-form">
        <input type="text" name="search" placeholder="بحث | Search" value="<%= filters.search || '' %>">

        <label>الفئة | Category</label>
        <select name="category">
          <option value="">الكل | All</option>
          <% listingCategories.forEach((cat) => { %>
            <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>

        <label>الحالة | Condition</label>
        <select name="condition">
          <option value="">الكل | All</option>
          <% listingConditions.forEach((condition) => { %>
            <option value="<%= condition %>" <%= filters.condition === condition ? 'selected' : '' %>><%= condition %></option>
          <% }) %>
        </select>

        <label>الموقع | Location</label>
        <select name="location">
          <option value="">الكل | All</option>
          <% listingLocations.forEach((location) => { %>
            <option value="<%= location %>" <%= filters.location === location ? 'selected' : '' %>><%= location %></option>
          <% }) %>
        </select>

        <label>السعر الأدنى | Min Price</label>
        <input type="number" name="minPrice" value="<%= filters.minPrice || '' %>">

        <label>السعر الأعلى | Max Price</label>
        <input type="number" name="maxPrice" value="<%= filters.maxPrice || '' %>">

        <button type="submit" class="btn btn-primary btn-block">تطبيق | Apply</button>
      </form>
    </aside>

    <main class="market-main">
      <section class="market-hero panel-card">
        <div>
          <h1>سوق الجيمرز الفلسطيني | Gamer Marketplace</h1>
          <p>بيع واشتري قطع PC، لابتوبات، وإكسسوارات من مجتمع اللاعبين مباشرة.</p>
        </div>
        <div class="market-hero-actions">
          <a href="/marketplace/new" class="btn btn-primary">+ نشر إعلان | Post Listing</a>
          <a href="/forum/best-deals" class="btn btn-secondary">أفضل العروض | Best Deals</a>
        </div>
      </section>

      <div class="market-quick-chips">
        <a href="/marketplace?category=GPU" class="market-chip <%= filters.category === 'GPU' ? 'active' : '' %>">GPU</a>
        <a href="/marketplace?category=FULL_PC" class="market-chip <%= filters.category === 'FULL_PC' ? 'active' : '' %>">Full PC</a>
        <a href="/marketplace?category=LAPTOP" class="market-chip <%= filters.category === 'LAPTOP' ? 'active' : '' %>">Laptop</a>
        <a href="/marketplace?category=MONITOR" class="market-chip <%= filters.category === 'MONITOR' ? 'active' : '' %>">Monitor</a>
        <a href="/marketplace?condition=LIKE_NEW" class="market-chip <%= filters.condition === 'LIKE_NEW' ? 'active' : '' %>">Like New</a>
      </div>

      <div class="market-header">
        <h1>سوق القيمنق | Marketplace</h1>
        <% if (currentUser) { %>
          <a href="/marketplace/new" class="btn btn-primary">نشر إعلان | Post Listing</a>
        <% } else { %>
          <a href="/auth/login" class="btn btn-outline">دخول للنشر | Login to Post</a>
        <% } %>
      </div>

      <div class="market-grid">
        <% if (listings && listings.length) { %>
          <% listings.forEach((listing) => { %>
            <%- include('../partials/listing-card', { listing }) %>
          <% }) %>
        <% } else { %>
          <div class="empty-state">
            <span class="empty-icon">🛒</span>
            <h3>لا توجد إعلانات | No listings found</h3>
          </div>
        <% } %>
      </div>

      <% if (pageInfo && pageInfo.hasMore) { %>
        <div class="load-more-row">
          <a class="btn btn-outline" href="/marketplace?cursor=<%= pageInfo.nextCursor %>">تحميل المزيد | Load More</a>
        </div>
      <% } %>
    </main>
  </div>
</section>

<%- include('../partials/footer') %>
