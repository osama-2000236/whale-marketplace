<%- include('../partials/header') %>

<section class="page-section listing-form-page">
  <div class="container">
    <div class="panel-card form-panel wide">
      <h1><%= listing && listing.id ? 'تعديل إعلان | Edit Listing' : 'إضافة إعلان | Post a Listing' %></h1>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (!listing && !isPro) { %>
        <div class="alert alert-info">
          هذه الميزة متاحة لمشتركي Pro فقط | Posting new listings requires Pro subscription.
          <a href="/upgrade" class="btn btn-gold btn-sm" style="margin-inline-start:8px;">ترقية الآن | Upgrade</a>
        </div>
      <% } %>

      <%
        const listingAction = listing && listing.id ? '/marketplace/' + listing.id + '/edit' : '/marketplace/new';
      %>
      <form method="POST" action="<%= listingAction %>?_csrf=<%= encodeURIComponent(csrfToken || '') %>" enctype="multipart/form-data" class="listing-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-row">
          <div class="form-group">
            <label>العنوان بالعربي | Arabic Title *</label>
            <input type="text" name="titleAr" required value="<%= listing?.titleAr || '' %>">
          </div>
          <div class="form-group">
            <label>English Title *</label>
            <input type="text" name="title" required value="<%= listing?.title || '' %>">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>الفئة | Category *</label>
            <select name="category" required>
              <% listingCategories.forEach((cat) => { %>
                <option value="<%= cat %>" <%= listing?.category === cat ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>الحالة | Condition *</label>
            <select name="condition" required>
              <% listingConditions.forEach((condition) => { %>
                <option value="<%= condition %>" <%= listing?.condition === condition ? 'selected' : '' %>><%= condition %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>السعر (₪) | Price *</label>
            <input type="number" name="price" required min="1" value="<%= listing?.price || '' %>">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>الوصف بالعربي | Arabic Description *</label>
            <textarea name="descriptionAr" rows="4" required><%= listing?.descriptionAr || '' %></textarea>
          </div>
          <div class="form-group">
            <label>Description (EN) *</label>
            <textarea name="description" rows="4" required><%= listing?.description || '' %></textarea>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>المدينة | City *</label>
            <select name="location" required>
              <% listingLocations.forEach((location) => { %>
                <option value="<%= location %>" <%= listing?.location === location ? 'selected' : '' %>><%= location %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>رقم واتساب | WhatsApp Number *</label>
            <input type="text" name="whatsappNumber" required value="<%= listing?.whatsappNumber || whatsappNumber %>">
          </div>
          <% if (listing && listing.id) { %>
            <div class="form-group">
              <label>الحالة | Status</label>
              <select name="status">
                <option value="ACTIVE" <%= listing.status === 'ACTIVE' ? 'selected' : '' %>>ACTIVE</option>
                <option value="SOLD" <%= listing.status === 'SOLD' ? 'selected' : '' %>>SOLD</option>
                <option value="REMOVED" <%= listing.status === 'REMOVED' ? 'selected' : '' %>>REMOVED</option>
              </select>
            </div>
          <% } %>
        </div>

        <div class="form-group">
          <label>الصور (حتى 6) | Images (up to 6, drag order supported in next iteration)</label>
          <input type="file" name="images" accept="image/*" multiple>
          <% if (listing?.images?.length) { %>
            <div class="image-preview-grid">
              <% listing.images.forEach((img) => { %>
                <img src="<%= img %>" alt="Listing image" loading="lazy">
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" <%= !listing && !isPro ? 'disabled' : '' %>><%= listing && listing.id ? 'حفظ التعديلات | Save Changes' : 'نشر الإعلان | Post Listing' %></button>
          <% if (listing && listing.id) { %><a href="/marketplace/my-listings" class="btn btn-outline">إدارة الحالة | Manage Status</a><% } %>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
