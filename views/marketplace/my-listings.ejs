<%- include('../partials/header') %>

<section class="page-section my-listings-page">
  <div class="container">
    <div class="section-header section-header-inline">
      <h1>إعلاناتي | My Listings</h1>
      <a href="/marketplace/new" class="btn btn-primary">إعلان جديد | New Listing</a>
    </div>

    <div class="market-grid">
      <% if (listings && listings.length) { %>
        <% listings.forEach((listing) => { %>
          <div class="my-listing-card">
            <%- include('../partials/listing-card', { listing }) %>
            <div class="my-listing-actions">
              <a class="btn btn-sm btn-outline" href="/marketplace/<%= listing.id %>/edit">تعديل | Edit</a>
              <form method="POST" action="/marketplace/<%= listing.id %>/mark-sold">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-sm btn-primary">مباع | Sold</button>
              </form>
              <form method="POST" action="/marketplace/<%= listing.id %>/remove">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-sm btn-danger">إزالة | Remove</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          <h3>لا توجد إعلانات | No listings yet</h3>
          <a href="/marketplace/new" class="btn btn-primary">أضف إعلانك الأول | Add your first listing</a>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
