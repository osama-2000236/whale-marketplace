<%- include('partials/header') %>
<section class="section page-section">
  <div class="container">
    <div class="section-header"><h2>من نحن</h2><div class="section-line"></div></div>
    <div class="about-content">
      <div class="about-text">
        <h3>🖥️ PC Gaming - <%= config.location.cityAr %></h3>
        <p><%= config.description %></p>
        <p>نحن متخصصون في بيع وتجميع أجهزة الكمبيوتر واللابتوبات والاكسسوارات بأفضل الأسعار في <%= config.location.cityAr %>. نقدم خدمات صيانة وتطوير الأجهزة بأيدي فنيين محترفين.</p>
        <div class="about-features">
          <% config.features.forEach(f => { %>
          <div class="about-feature"><span><%= f.icon %></span><div><strong><%= f.title %></strong><p><%= f.desc %></p></div></div>
          <% }) %>
        </div>
      </div>
      <div class="about-services">
        <h3>خدماتنا</h3>
        <div class="services-list">
          <% categories.forEach(cat => { %>
          <a href="/products?category=<%= cat.id %>" class="service-item"><span><%= cat.icon %></span><span><%= cat.nameAr %></span></a>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
