<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <h1><%= t('whale.browse') %></h1>
      <p class="text-muted"><%= total %> <%= locale === 'ar' ? 'منتج' : 'listings' %></p>
    </div>

    <div class="browse-layout">
      <!-- Filters -->
      <aside class="filter-sidebar">
        <h3><%= t('whale.filter') %></h3>
        <form class="filter-form" method="GET" action="/whale">
          <div class="form-group">
            <label class="form-label"><%= t('general.search') %></label>
            <input
              type="text"
              name="q"
              class="input"
              value="<%= filters.q || '' %>"
              placeholder="<%= t('general.search') %>"
            >
          </div>
          <div class="form-group">
            <label class="form-label"><%= t('whale.category') %></label>
            <select name="category" class="select">
              <option value=""><%= t('whale.all_categories') %></option>
              <% categories.forEach((cat) => { %>
                <option value="<%= cat.slug %>" <%= filters.categorySlug === cat.slug ? 'selected' : '' %>>
                  <%= locale === 'ar' ? cat.nameAr : cat.name %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label"><%= t('whale.city') %></label>
            <select name="city" class="select">
              <option value=""><%= t('whale.all_cities') %></option>
              <% cities.forEach((c) => { %>
                <option value="<%= c.value %>" <%= filters.city === c.value ? 'selected' : '' %>><%= c.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label"><%= t('whale.condition') %></label>
            <select name="condition" class="select">
              <option value=""><%= t('whale.all_conditions') %></option>
              <% ['NEW', 'LIKE_NEW', 'GOOD', 'USED', 'FAIR', 'FOR_PARTS'].forEach((c) => { %>
                <option value="<%= c %>" <%= filters.condition === c ? 'selected' : '' %>>
                  <%= t('condition.' + c) %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label"><%= t('whale.min_price') %></label>
              <input
                type="number"
                name="minPrice"
                class="input"
                value="<%= filters.minPrice || '' %>"
                min="0"
              >
            </div>
            <div class="form-group">
              <label class="form-label"><%= t('whale.max_price') %></label>
              <input
                type="number"
                name="maxPrice"
                class="input"
                value="<%= filters.maxPrice || '' %>"
                min="0"
              >
            </div>
          </div>
          <div class="form-group">
            <label class="form-label"><%= t('whale.sort') %></label>
            <select name="sort" class="select">
              <% ['newest', 'oldest', 'price_asc', 'price_desc', 'popular'].forEach((s) => { %>
                <option value="<%= s %>" <%= filters.sort === s ? 'selected' : '' %>>
                  <%= t('whale.sort.' + s) %>
                </option>
              <% }) %>
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-block"><%= t('whale.filter') %></button>
        </form>
      </aside>

      <!-- Listings Grid -->
      <div>
        <% if (listings.length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon">🔍</div>
            <h3><%= t('whale.no_results') %></h3>
            <a href="/whale" class="btn btn-ghost">
              <%= locale === 'ar' ? 'مسح الفلاتر' : 'Clear Filters' %>
            </a>
          </div>
        <% } else { %>
          <div class="grid-listings">
            <% listings.forEach((listing) => { %>
              <%- include('../partials/listing-card', { listing }) %>
            <% }) %>
          </div>
          <% if (nextCursor) { %>
            <div class="text-center mt-3">
              <a
                href="/whale?<%= Object.entries(filters).filter(([k, v]) => v).map(([k, v]) => k + '=' + encodeURIComponent(v)).join('&') %>&cursor=<%= nextCursor %>"
                class="btn btn-ghost"
              >
                <%= t('whale.load_more') %>
              </a>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
