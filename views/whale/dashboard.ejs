<%- include('../partials/header', { title: t('dashboard.title') + ' — Whale' }) %>

<section class="page-section whale-page">
  <div class="container">
    <div class="whale-flex-between">
      <h1 class="page-title"><%= t('dashboard.title') %></h1>
      <a href="/whale/my-listings" class="btn btn-ghost"><%= t('dashboard.manage_listings') %></a>
    </div>

    <div class="listing-grid whale-dashboard-stats">
      <div class="panel-card" aria-label="<%= t('dashboard.total_sales') %>: <%= profile?.totalSales || 0 %>">
        <div class="muted"><%= t('dashboard.total_sales') %></div>
        <strong class="whale-stat-value"><%= profile?.totalSales || 0 %></strong>
      </div>
      <div class="panel-card" aria-label="<%= t('dashboard.total_revenue') %>: <%= Number(profile?.totalRevenue || 0).toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %> ₪">
        <div class="muted"><%= t('dashboard.total_revenue') %></div>
        <strong class="whale-stat-value"><%= Number(profile?.totalRevenue || 0).toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %> ₪</strong>
      </div>
      <div class="panel-card" aria-label="<%= t('dashboard.avg_rating') %>: <%= Number(profile?.averageRating || 0).toFixed(1) %>">
        <div class="muted"><%= t('dashboard.avg_rating') %></div>
        <strong class="whale-stat-value"><%= Number(profile?.averageRating || 0).toFixed(1) %> ★</strong>
      </div>
      <div class="panel-card" aria-label="<%= t('dashboard.active_listings') %>: <%= activeListings %>">
        <div class="muted"><%= t('dashboard.active_listings') %></div>
        <strong class="whale-stat-value"><%= activeListings %></strong>
      </div>
    </div>

    <div class="panel-card">
      <h3><%= t('dashboard.pending_orders') %></h3>
      <% const pendingRows = recentOrders.filter((o) => ['PENDING', 'SELLER_CONFIRMED', 'SHIPPED'].includes(o.orderStatus)); %>
      <% if (pendingRows.length) { %>
        <table class="data-table whale-mt-sm">
          <caption class="sr-only"><%= t('dashboard.pending_orders') %></caption>
          <thead>
            <tr>
              <th scope="col"><%= t('order.number') %></th>
              <th scope="col"><%= t('order.buyer') %></th>
              <th scope="col"><%= t('order.item') %></th>
              <th scope="col"><%= t('order.amount') %></th>
              <th scope="col"><%= t('order.status') %></th>
              <th scope="col"><%= t('order.actions') %></th>
            </tr>
          </thead>
          <tbody>
            <% pendingRows.forEach((order) => { %>
              <tr>
                <td><%= order.orderNumber %></td>
                <td><%= order.buyer.username %></td>
                <td dir="auto"><%= order.listing.titleAr || order.listing.title %></td>
                <td><%= order.amount.toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %> ₪</td>
                <td><%- include('../partials/status-badge', { status: order.orderStatus }) %></td>
                <td><a href="/whale/orders/<%= order.id %>"><%= t('ui.open') %></a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p class="muted whale-py-sm"><%= t('order.no_orders') %></p>
      <% } %>
    </div>

    <div class="panel-card whale-mt-md">
      <h3><%= t('dashboard.recent_reviews') %></h3>
      <% if (recentReviews.length) { %>
        <% recentReviews.forEach((review) => { %>
          <%- include('../partials/review-card', { review, lang }) %>
        <% }) %>
      <% } else { %>
        <p class="muted whale-py-sm"><%= t('seller.no_reviews') %></p>
      <% } %>
    </div>

    <div class="panel-card whale-mt-md">
      <h3><%= t('dashboard.my_listings_preview') %></h3>
      <div class="listing-grid whale-mt-sm">
        <% myListingsPreview.forEach((listing) => { %>
          <a class="listing-card card" href="/whale/listing/<%= listing.slug || listing.id %>">
            <img src="<%= listing.images[0] || '/images/products/placeholder.svg' %>" class="listing-img" alt="<%= listing.titleAr || listing.title %>" loading="lazy">
            <div class="listing-body">
              <div class="listing-title" dir="auto"><%= listing.titleAr || listing.title %></div>
              <div class="muted">👁️ <%= listing.views %> · 🛒 <%= listing._count.orders %></div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
