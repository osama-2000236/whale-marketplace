<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <h1><%= t('dashboard.title') %></h1>
    </div>

    <div class="grid-stats mb-3">
      <div class="stat-card">
        <div class="stat-card-value"><%= stats.totalListings %></div>
        <div class="stat-card-label"><%= t('dashboard.total_listings') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value"><%= stats.activeListings %></div>
        <div class="stat-card-label"><%= t('dashboard.active_listings') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value"><%= stats.totalOrders %></div>
        <div class="stat-card-label"><%= t('dashboard.total_orders') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value"><%= stats.pendingOrders %></div>
        <div class="stat-card-label"><%= t('dashboard.pending_orders') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value">$<%= parseFloat(stats.totalRevenue).toLocaleString() %></div>
        <div class="stat-card-label"><%= t('dashboard.total_revenue') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value">
          <%= stats.avgRating > 0 ? stats.avgRating.toFixed(1) : '—' %> ★
        </div>
        <div class="stat-card-label">
          <%= t('dashboard.avg_rating') %> (<%= stats.reviewCount %>)
        </div>
      </div>
    </div>

    <% if (stats.recentOrders.length > 0) { %>
    <div class="card">
      <div class="card-header"><%= t('dashboard.recent_orders') %></div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th><%= t('order.number') %></th>
              <th><%= locale === 'ar' ? 'المنتج' : 'Item' %></th>
              <th><%= locale === 'ar' ? 'المشتري' : 'Buyer' %></th>
              <th><%= t('order.status') %></th>
            </tr>
          </thead>
          <tbody>
            <% stats.recentOrders.forEach(o => { %>
            <tr>
              <td>
                <a href="/whale/orders/<%= o.id %>">
                  <code><%= o.orderNumber.slice(-8) %></code>
                </a>
              </td>
              <td><%= o.listing.title %></td>
              <td><%= o.buyer.username %></td>
              <td><%- include('../partials/order-status', { status: o.status }) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
