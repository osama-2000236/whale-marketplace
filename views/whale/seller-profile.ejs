<%- include('../partials/header', { title: seller.username + ' — Whale' }) %>

<%
  const profile = seller.sellerProfile || {};
%>

<section class="page-section whale-page">
  <div class="container">
    <div class="panel-card">
      <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
        <%- include('../partials/avatar', { user: seller, size: 'lg' }) %>
        <div>
          <h1 style="margin:0;"><%= seller.username %></h1>
          <% if (profile.isVerified) { %><span class="verified-seller"><%= t('seller.verified') %></span><% } %>
          <p class="muted"><%= t('seller.since') %> <%= new Date(seller.createdAt).toLocaleDateString(lang === 'ar' ? 'ar-PS' : 'en-GB') %></p>
        </div>
      </div>

      <div class="profile-stats" style="margin-top:10px;">
        <div class="profile-stat"><div class="val"><%= profile.totalSales || 0 %></div><div class="lbl"><%= t('seller.total_sales') %></div></div>
        <div class="profile-stat"><div class="val"><%= Number(profile.averageRating || 0).toFixed(1) %></div><div class="lbl"><%= t('dashboard.avg_rating') %></div></div>
        <div class="profile-stat"><div class="val"><%= profile.reviewCount || 0 %></div><div class="lbl"><%= t('listing.reviews') %></div></div>
        <div class="profile-stat"><div class="val"><%= listings.length %></div><div class="lbl"><%= t('seller.active_listings') %></div></div>
      </div>

      <% if (profile.bio || profile.bioAr) { %>
        <p dir="auto" style="margin-top:10px;"><%= profile.bioAr || profile.bio %></p>
      <% } %>
    </div>

    <div class="panel-card" style="margin-top:12px;">
      <h3><%= t('seller.all') %></h3>
      <div class="listing-grid" style="margin-top:8px;">
        <% listings.forEach((listing) => { %>
          <a class="listing-card" href="/whale/listing/<%= listing.slug || listing.id %>">
            <img src="<%= listing.images[0] || '/images/products/placeholder.svg' %>" alt="<%= listing.title %>" class="listing-img">
            <div class="listing-body">
              <div class="listing-price"><%= listing.price.toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %> ₪</div>
              <div class="listing-title" dir="auto"><%= listing.title %></div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>

    <div class="panel-card" style="margin-top:12px;">
      <h3><%= t('listing.reviews') %></h3>
      <% if (reviews.length) { %>
        <% reviews.forEach((review) => { %>
          <article class="panel-card whale-review-card">
            <div style="display:flex; justify-content:space-between; gap:10px;">
              <strong><%= review.reviewer.username %></strong>
              <small><%= new Date(review.createdAt).toLocaleDateString(lang === 'ar' ? 'ar-PS' : 'en-GB') %></small>
            </div>
            <div class="stars"><%- '★'.repeat(review.rating) %><%- '☆'.repeat(5 - review.rating) %></div>
            <% if (review.isVerified) { %><span class="verified-seller"><%= t('listing.verified_p') %></span><% } %>
            <% if (review.title) { %><h4 dir="auto" style="margin-top:8px;"><%= review.title %></h4><% } %>
            <% if (review.body) { %><p dir="auto"><%= review.body %></p><% } %>
          </article>
        <% }) %>
      <% } else { %>
        <p class="muted"><%= t('seller.no_reviews') %></p>
      <% } %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
