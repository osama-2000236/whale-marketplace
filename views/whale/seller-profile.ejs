<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <div class="seller-profile-header">
      <div class="seller-avatar-large">
        <%- include('../partials/avatar', { user: seller, size: 'lg' }) %>
      </div>
      <div class="seller-profile-info">
        <h1><%= seller.username %></h1>
        <% if (seller.sellerProfile) { %>
        <div class="seller-meta">
          <% if (seller.sellerProfile.averageRating) { %>
          <%- include('../partials/star-rating', { rating: seller.sellerProfile.averageRating }) %>
          <span>(<%= seller.sellerProfile.totalReviews || 0 %> <%= t('whale.reviews') %>)</span>
          <% } %>
          <% if (seller.sellerProfile.verified) { %>
          <span class="verified-badge"><%= t('whale.verified_seller') %></span>
          <% } %>
        </div>
        <p class="seller-since"><%= t('whale.member_since') %> <%= new Date(seller.createdAt).toLocaleDateString(lang === 'ar' ? 'ar-PS' : 'en-US', { year: 'numeric', month: 'long' }) %></p>
        <% if (seller.sellerProfile.bio) { %>
        <p class="seller-bio"><%= seller.sellerProfile.bio %></p>
        <% } %>
        <% } %>
      </div>
    </div>

    <div class="seller-stats-bar">
      <div class="stat-item"><strong><%= listings.length %></strong> <%= t('whale.listings') %></div>
      <div class="stat-item"><strong><%= seller.sellerProfile ? (seller.sellerProfile.totalSales || 0) : 0 %></strong> <%= t('whale.sales') %></div>
      <div class="stat-item"><strong><%= seller.sellerProfile && seller.sellerProfile.averageRating ? seller.sellerProfile.averageRating.toFixed(1) : '—' %></strong> <%= t('whale.rating') %></div>
    </div>

    <% if (listings.length) { %>
    <h2><%= t('whale.listings') %></h2>
    <div class="listings-grid">
      <% listings.forEach(listing => { %>
        <%- include('../partials/listing-card', { listing: listing }) %>
      <% }) %>
    </div>
    <% } %>

    <% if (reviews && reviews.length) { %>
    <h2><%= t('whale.reviews') %></h2>
    <div class="reviews-list">
      <% reviews.forEach(review => { %>
        <%- include('../partials/review-card', { review: review }) %>
      <% }) %>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
