<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container">
    <%- include('../partials/flash') %>

    <div class="listing-detail">
      <!-- Gallery -->
      <div class="gallery">
        <div class="gallery-main">
          <img src="<%= listing.images[0] || '' %>" alt="<%= listing.title %>" />
        </div>
        <% if (listing.images.length > 1) { %>
        <div class="gallery-thumbs">
          <% listing.images.forEach((img, i) => { %>
          <div class="gallery-thumb <%= i === 0 ? 'active' : '' %>">
            <img src="<%= img %>" alt="" />
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Info -->
      <div class="listing-detail-info">
        <h1><%= locale === 'ar' && listing.titleAr ? listing.titleAr : listing.title %></h1>

        <div class="flex items-center gap-1 mb-1">
          <span class="badge badge-info"><%= t('condition.' + listing.condition) %></span>
          <span class="text-sm text-muted"><%= listing.city %></span>
          <span class="text-sm text-muted">
            &middot; <%= listing.views %> <%= t('listing.views') %>
          </span>
        </div>

        <div class="listing-detail-price">
          $<%= parseFloat(listing.price).toLocaleString() %> <% if (listing.negotiable) { %>
          <span class="text-sm text-muted">(<%= t('listing.negotiable') %>)</span>
          <% } %>
        </div>

        <!-- Actions -->
        <div class="listing-detail-actions">
          <% if (user && user.id !== listing.sellerId) { %>
          <a href="/whale/checkout/<%= listing.id %>" class="btn btn-primary btn-lg">
            <%= t('listing.buy_now') %>
          </a>
          <% if (listing.seller && listing.seller.sellerProfile &&
          listing.seller.sellerProfile.whatsapp) { %>
          <a
            href="https://wa.me/<%= listing.seller.sellerProfile.whatsapp.replace(/\+/g,'') %>?text=<%= encodeURIComponent(locale === 'ar' ? 'مرحبا، أنا مهتم بمنتجك: ' + listing.title : 'Hi, I am interested in: ' + listing.title) %>"
            target="_blank"
            rel="noopener"
            class="btn btn-success"
          >
            <%= t('listing.whatsapp') %>
          </a>
          <% } %>
          <button
            type="button"
            data-save-listing="<%= listing.id %>"
            class="btn btn-ghost <%= isSaved ? 'saved' : '' %>"
          >
            <span class="save-icon"><%= isSaved ? '❤️' : '🤍' %></span>
            <%= isSaved ? t('listing.saved') : t('listing.save') %>
          </button>
          <% } else if (user && user.id === listing.sellerId) { %>
          <a href="/whale/listing/<%= listing.id %>/edit" class="btn btn-secondary">
            <%= t('listing.edit') %>
          </a>
          <form
            method="POST"
            action="/whale/listing/<%= listing.id %>/delete"
            data-confirm="<%= locale === 'ar' ? 'هل أنت متأكد من الحذف؟' : 'Are you sure you want to delete this listing?' %>"
            style="display: inline"
          >
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn btn-danger"><%= t('listing.delete') %></button>
          </form>
          <% } else { %>
          <a
            href="/auth/login?next=/whale/listing/<%= listing.slug %>"
            class="btn btn-primary btn-lg"
          >
            <%= t('listing.buy_now') %>
          </a>
          <% } %>
        </div>

        <!-- Seller -->
        <div class="seller-info">
          <div class="avatar avatar-lg">
            <% if (listing.seller.avatarUrl) { %>
            <img src="<%= listing.seller.avatarUrl %>" alt="" />
            <% } else { %>
            <%= listing.seller.username.charAt(0).toUpperCase() %>
            <% } %>
          </div>
          <div class="seller-info-details">
            <div class="seller-info-name">
              <%= listing.seller.sellerProfile?.displayName || listing.seller.username %>
            </div>
            <div class="seller-info-meta">
              <% if (listing.seller.sellerProfile) { %>
              <span class="stars">
                <% for(let i=1;i<=5;i++){%>
                <span
                  class="<%= i <= Math.round(listing.seller.sellerProfile.avgRating) ? '' : 'empty' %>"
                >
                  ★
                </span>
                <%}%>
              </span>
              (
              <%= listing.seller.sellerProfile.reviewCount %>
              )
              <% } %>
              &middot;
              <%=
              t('listing.member_since') %>
              <%= new Date(listing.seller.createdAt).getFullYear() %>
            </div>
          </div>
          <a href="/whale/seller/<%= listing.seller.username %>" class="btn btn-ghost btn-sm">
            <%= t('listing.view_profile') %>
          </a>
        </div>

        <!-- Description -->
        <div class="card mt-2">
          <div class="card-header"><%= t('listing.description') %></div>
          <div class="card-body">
            <% if (locale === 'ar' && listing.descriptionAr) { %>
            <p><%= listing.descriptionAr %></p>
            <% } else { %>
            <p><%= listing.description %></p>
            <% } %>
          </div>
        </div>

        <!-- Specs -->
        <% if (listing.specs) { %>
        <div class="card mt-2">
          <div class="card-header"><%= t('listing.specs') %></div>
          <div class="card-body">
            <table>
              <% Object.entries(listing.specs).forEach(([key, val]) => { %>
              <tr>
                <td>
                  <strong><%= key %></strong>
                </td>
                <td><%= val %></td>
              </tr>
              <% }) %>
            </table>
          </div>
        </div>
        <% } %>

        <!-- Reviews -->
        <% if (listing.reviews && listing.reviews.length > 0) { %>
        <div class="card mt-2">
          <div class="card-header"><%= t('listing.reviews') %> (<%= listing.reviews.length %>)</div>
          <div class="card-body" style="padding: 0">
            <% listing.reviews.forEach(review => { %>
            <div class="review-card">
              <div class="review-header">
                <div class="avatar avatar-sm">
                  <%= review.reviewer.username.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <strong><%= review.reviewer.username %></strong>
                  <div class="stars">
                    <% for(let i=1;i<=5;i++){%>
                    <span class="<%= i<=review.rating?'':'empty'%>">★</span>
                    <%}%>
                  </div>
                </div>
              </div>
              <% if (review.body) { %>
              <p class="review-body"><%= review.body %></p>
              <% } %>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
<script>
document.getElementById('saveBtn')?.addEventListener('click', async function() {
  const id = this.dataset.id;
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
  const res = await fetch('/whale/listing/' + id + '/save', { method: 'POST', headers: { 'X-CSRF-Token': csrf } });
  if (res.ok) { const d = await res.json(); this.classList.toggle('saved', d.saved); this.textContent = d.saved ? '<%= t("whale.unsave") %> ❤️' : '<%= t("whale.save") %> ❤️'; }
});
</script>
</body>
</html>
