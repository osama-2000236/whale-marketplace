<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="listing-detail">
    <!-- Gallery -->
    <div class="listing-gallery">
      <div class="gallery-main">
        <img src="<%= listing.images && listing.images[0] ? listing.images[0] : '/images/placeholder.png' %>" alt="<%= listing.title %>" id="mainImage">
      </div>
      <% if (listing.images && listing.images.length > 1) { %>
      <div class="gallery-thumbs">
        <% listing.images.forEach((img, i) => { %>
        <img src="<%= img %>" alt="" class="thumb <%= i === 0 ? 'active' : '' %>" onclick="document.getElementById('mainImage').src=this.src; document.querySelectorAll('.thumb').forEach(t=>t.classList.remove('active')); this.classList.add('active');">
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- Details -->
    <div class="listing-info">
      <h1 dir="auto"><%= lang === 'ar' && listing.titleAr ? listing.titleAr : listing.title %></h1>

      <div class="listing-price-row">
        <span class="listing-price">₪<%= listing.price %></span>
        <% if (listing.negotiable) { %><span class="negotiable-badge"><%= t('whale.negotiable') %></span><% } %>
        <% if (listing.condition) { %>
        <span class="condition-badge condition-<%= listing.condition.toLowerCase() %>"><%= t('condition.' + listing.condition.toLowerCase()) %></span>
        <% } %>
      </div>

      <div class="listing-stats">
        <span>👁 <%= listing.views %> <%= t('whale.views') %></span>
        <span>❤️ <%= listing._count ? listing._count.savedBy : 0 %> <%= t('whale.saved') %></span>
        <% if (listing._count && listing._count.orders > 0) { %>
        <span>🛒 <%= listing._count.orders %> <%= t('whale.sold') %></span>
        <% } %>
      </div>

      <%- include('../partials/trust-box') %>

      <!-- Actions -->
      <div class="listing-actions">
        <% if (currentUser && listing.sellerId !== currentUser.id) { %>
        <a href="/whale/listing/<%= listing.id %>/buy" class="btn btn-primary btn-lg btn-block"><%= t('whale.buy_now') %></a>
        <form method="post" action="/whale/cart/add" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="listingId" value="<%= listing.id %>">
          <button type="submit" class="btn btn-outline btn-lg btn-block"><%= t('whale.add_to_cart') %></button>
        </form>
        <% } else if (!currentUser) { %>
        <a href="/auth/register?returnTo=/whale/listing/<%= listing.slug || listing.id %>" class="btn btn-primary btn-lg btn-block"><%= t('listing.register_contact') %></a>
        <a href="/auth/login?returnTo=/whale/listing/<%= listing.slug || listing.id %>" class="btn btn-outline btn-lg btn-block"><%= t('listing.buy_now') %></a>
        <% } %>

        <% if (listing.seller?.sellerProfile?.whatsapp) { %>
        <a href="https://wa.me/<%= listing.seller.sellerProfile.whatsapp %>?text=<%= encodeURIComponent(listing.title) %>" target="_blank" rel="noopener" class="btn btn-whatsapp btn-block" onclick="fetch('/whale/listing/<%= listing.id %>/wa-click',{method:'POST',headers:{'X-CSRF-Token':'<%= csrfToken %>'}})">
          WhatsApp 📱
        </a>
        <% } %>

        <% if (currentUser) { %>
        <button class="btn btn-outline save-action-btn <%= isSaved ? 'saved' : '' %>" id="saveBtn" data-id="<%= listing.id %>">
          <%= isSaved ? t('whale.unsave') : t('whale.save') %> ❤️
        </button>
        <% } %>
      </div>

      <!-- Seller Card -->
      <% if (listing.seller) { %>
      <div class="seller-card">
        <a href="/whale/seller/<%= listing.seller.username %>" class="seller-header">
          <% if (listing.seller.avatar) { %><img src="<%= listing.seller.avatar %>" alt="" class="avatar-md"><% } else { %><span class="avatar-md avatar-initials"><%= listing.seller.username.charAt(0).toUpperCase() %></span><% } %>
          <div>
            <strong><%= listing.seller.username %> <% if (listing.seller.isVerified) { %><span class="verified-check">✓</span><% } %></strong>
            <% if (listing.seller.sellerProfile) { var sp = listing.seller.sellerProfile; %>
            <div class="seller-stats-mini">
              <span>★ <%= sp.averageRating.toFixed(1) %> (<%= sp.reviewCount %>)</span>
              <span>🛒 <%= sp.totalSales %> sales</span>
            </div>
            <% } %>
            <span class="seller-joined"><%= t('whale.member_since') %> <%= new Date(listing.seller.createdAt).getFullYear() %></span>
          </div>
        </a>
      </div>
      <% } %>

      <!-- Description -->
      <div class="listing-section">
        <h3><%= t('whale.description') %></h3>
        <div class="listing-desc" dir="auto">
          <p><%= lang === 'ar' && listing.descriptionAr ? listing.descriptionAr : listing.description %></p>
        </div>
      </div>

      <!-- Specs -->
      <% if (listing.specs && Object.keys(listing.specs).length) { %>
      <div class="listing-section">
        <h3><%= t('whale.specifications') %></h3>
        <table class="specs-table">
          <% Object.entries(listing.specs).forEach(([k, v]) => { %>
          <tr><th><%= k %></th><td><%= v %></td></tr>
          <% }) %>
        </table>
      </div>
      <% } %>

      <!-- Reviews -->
      <% if (listing.reviews && listing.reviews.length) { %>
      <div class="listing-section">
        <h3><%= t('whale.reviews') %> (<%= listing._count ? listing._count.reviews : listing.reviews.length %>)</h3>
        <% listing.reviews.forEach(review => { %>
        <%- include('../partials/review-card', { review }) %>
        <% }) %>
      </div>
      <% } %>

      <!-- Tags -->
      <% if (listing.tags && listing.tags.length) { %>
      <div class="listing-tags">
        <% listing.tags.forEach(tag => { %>
        <a href="/whale?q=<%= encodeURIComponent(tag) %>" class="tag">#<%= tag %></a>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Similar -->
  <% if (similar && similar.length) { %>
  <section class="similar-section">
    <h2><%= t('whale.similar') %></h2>
    <div class="listings-grid listings-grid-sm">
      <% similar.forEach(listing => { %>
      <%- include('../partials/listing-card', { listing }) %>
      <% }) %>
    </div>
  </section>
  <% } %>
</main>
<%- include('../partials/footer') %>
<script>
document.getElementById('saveBtn')?.addEventListener('click', async function() {
  const id = this.dataset.id;
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
  const res = await fetch('/whale/listing/' + id + '/save', { method: 'POST', headers: { 'X-CSRF-Token': csrf } });
  if (res.ok) { const d = await res.json(); this.classList.toggle('saved', d.saved); this.textContent = d.saved ? '<%= t("whale.unsave") %> ❤️' : '<%= t("whale.save") %> ❤️'; }
});
</script>
</body>
</html>
