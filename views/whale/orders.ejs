<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <h1><%= t('order.title') %></h1>
    </div>

    <div class="tabs">
      <a href="/whale/orders?tab=buying" class="tab <%= tab === 'buying' ? 'active' : '' %>">
        <%= t('order.buying') %>
      </a>
      <a href="/whale/orders?tab=selling" class="tab <%= tab === 'selling' ? 'active' : '' %>">
        <%= t('order.selling') %>
      </a>
    </div>

    <% if (orders.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">📦</div>
      <h3><%= t('order.no_orders') %></h3>
      <a href="/whale" class="btn btn-primary"><%= t('whale.browse') %></a>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= t('order.number') %></th>
            <th><%= locale === 'ar' ? 'المنتج' : 'Item' %></th>
            <th><%= locale === 'ar' ? 'المبلغ' : 'Amount' %></th>
            <th><%= t('order.status') %></th>
            <th><%= locale === 'ar' ? 'التاريخ' : 'Date' %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(order => { %>
          <tr>
            <td>
              <code><%= order.orderNumber.slice(-8) %></code>
            </td>
            <td>
              <div style="display: flex; align-items: center; gap: 0.5rem">
                <% if (order.listing.images && order.listing.images.length > 0) { %>
                <img
                  src="<%= order.listing.images[0] %>"
                  alt=""
                  style="width: 40px; height: 30px; object-fit: cover; border-radius: 4px"
                />
                <% } %>
                <%= order.listing.title %>
              </div>
            </td>
            <td>
              $
              <%= parseFloat(order.amount).toLocaleString() %>
            </td>
            <td><%- include('../partials/order-status', { status: order.status }) %></td>
            <td class="text-sm text-muted">
              <%= new Date(order.createdAt).toLocaleDateString() %>
            </td>
            <td>
              <a href="/whale/orders/<%= order.id %>" class="btn btn-ghost btn-sm">
                <%= locale === 'ar' ? 'عرض' : 'View' %>
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
