<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <h1><%= t('whale.orders') %></h1>
    <div class="tab-bar">
      <a href="/whale/orders?tab=buying" class="tab <%= tab === 'buying' ? 'active' : '' %>"><%= t('whale.buying') %></a>
      <a href="/whale/orders?tab=selling" class="tab <%= tab === 'selling' ? 'active' : '' %>"><%= t('whale.selling') %></a>
    </div>

    <% if (orders.length) { %>
    <div class="orders-list">
      <% orders.forEach(order => { %>
      <a href="/whale/orders/<%= order.id %>" class="order-card">
        <img src="<%= order.listing && order.listing.images && order.listing.images[0] ? order.listing.images[0] : '/images/placeholder.png' %>" alt="" class="order-thumb">
        <div class="order-info">
          <h3><%= order.listing ? order.listing.title : 'Order' %></h3>
          <p class="order-number">#<%= order.orderNumber %></p>
          <p class="order-amount">₪<%= order.amount %></p>
        </div>
        <div class="order-status">
          <% var statusColors = { PENDING: 'warning', SELLER_CONFIRMED: 'info', SHIPPED: 'info', COMPLETED: 'success', CANCELLED: 'danger', DISPUTED: 'danger', REFUNDED: 'warning' }; var os = order.orderStatus || 'PENDING'; %>
          <span class="status-badge status-<%= statusColors[os] || 'neutral' %>"><%= t('status.' + os.toLowerCase()) %></span>
          <span class="order-date"><%= timeAgo(order.createdAt) %></span>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <h3><%= t('whale.no_orders') %></h3>
      <a href="/whale" class="btn btn-primary"><%= t('whale.browse') %></a>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
