<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container" style="max-width: 720px">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <h1><%= t('sell.edit_title') %></h1>
    </div>

    <div class="card">
      <div class="card-body">
        <form
          method="POST"
          action="/whale/listing/<%= listing.id %>/edit"
          enctype="multipart/form-data"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="form-row">
            <div class="form-group">
              <label class="form-label"><%= t('sell.name') %></label>
              <input
                type="text"
                name="title"
                class="input"
                value="<%= listing.title %>"
                required
                maxlength="100"
              >
            </div>
            <div class="form-group">
              <label class="form-label"><%= t('sell.name_ar') %></label>
              <input
                type="text"
                name="titleAr"
                class="input"
                value="<%= listing.titleAr || '' %>"
                maxlength="100"
              >
            </div>
          </div>

          <div class="form-group">
            <label class="form-label"><%= t('sell.description') %></label>
            <textarea name="description" class="textarea" required maxlength="5000"
              ><%= listing.description %></textarea
            >
          </div>
          <div class="form-group">
            <label class="form-label"><%= t('sell.description_ar') %></label>
            <textarea name="descriptionAr" class="textarea" maxlength="5000"
              ><%= listing.descriptionAr || '' %></textarea
            >
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label"><%= t('sell.price') %> ($)</label>
              <input
                type="number"
                name="price"
                class="input"
                value="<%= listing.price %>"
                required
                min="1"
                step="0.01"
              >
            </div>
            <div class="form-group">
              <label class="form-label"><%= t('sell.condition') %></label>
              <select name="condition" class="select">
                <% ['NEW', 'LIKE_NEW', 'GOOD', 'USED', 'FAIR', 'FOR_PARTS'].forEach((c) => { %>
                  <option value="<%= c %>" <%= listing.condition === c ? 'selected' : '' %>>
                    <%= t('condition.' + c) %>
                  </option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="checkbox-label">
              <input
                type="checkbox"
                name="negotiable"
                value="on"
                <%= listing.negotiable ? 'checked' : '' %>
              >
              <%= t('sell.negotiable') %>
            </label>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label"><%= t('sell.category') %></label>
              <select name="categoryId" class="select" required>
                <% categories.forEach((cat) => { %>
                  <option value="<%= cat.id %>" <%= listing.categoryId === cat.id ? 'selected' : '' %>>
                    <%= locale === 'ar' ? cat.nameAr : cat.name %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label"><%= t('sell.city') %></label>
              <select name="city" class="select" required>
                <% cities.forEach((c) => { %>
                  <option value="<%= c %>" <%= listing.city === c ? 'selected' : '' %>><%= c %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">
              <%= t('sell.images') %> (<%= locale === 'ar' ? 'اختياري — يستبدل الحالية' :
              'optional — replaces current' %>)
            </label>
            <input
              type="file"
              name="images"
              class="input"
              accept="image/jpeg,image/png,image/webp"
              multiple
            >
          </div>

          <div class="form-group">
            <label class="form-label"><%= t('sell.tags') %></label>
            <input
              type="text"
              name="tags"
              class="input"
              value="<%= listing.tags ? listing.tags.join(', ') : '' %>"
            >
          </div>

          <button type="submit" class="btn btn-primary btn-block btn-lg mt-2">
            <%= t('sell.update') %>
          </button>
        </form>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
