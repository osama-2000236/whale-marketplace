<%- include('../partials/header') %>

<section class="page-section whale-page">
  <div class="container whale-max-w-md">
    <h1 class="page-title"><%= t('cart.title') %></h1>
    <% const cartErrors = {
      empty: t('cart.err_empty'),
      checkout_failed: t('cart.err_checkout'),
      remove_failed: t('cart.err_remove'),
      card_multi_not_supported: t('cart.err_card_multi')
    }; %>

    <% if (query && query.error && cartErrors[query.error]) { %>
      <div class="alert alert-err" role="alert"><%= cartErrors[query.error] %></div>
    <% } %>

    <% if (!cart.items.length) { %>
      <%- include('../partials/empty-state', {
        icon: '🛒',
        title: t('cart.empty'),
        ctaText: t('cart.empty_cta'),
        ctaHref: '/whale'
      }) %>
    <% } else { %>
      <div class="whale-cart-layout">
        <div class="card whale-cart-items-card">
          <div class="whale-cart-header">
            <strong><%= cart.count %> <%= t('cart.items') %></strong>
            <span class="muted"><%= t('cart.total') %>: <strong class="whale-cart-total-value"><%= cart.total.toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %> ₪</strong></span>
          </div>

          <div class="whale-cart-list">
            <% cart.items.forEach((item) => { %>
              <article class="card whale-cart-item">
                <a href="/whale/listing/<%= item.listing.slug || item.listing.id %>">
                  <img src="<%= item.listing.images[0] || '/images/products/placeholder.svg' %>" alt="<%= item.listing.titleAr || item.listing.title %>" class="whale-cart-item-image" loading="lazy">
                </a>
                <div>
                  <a href="/whale/listing/<%= item.listing.slug || item.listing.id %>" class="listing-title" dir="auto"><%= item.listing.titleAr || item.listing.title %></a>
                  <div class="listing-meta muted"><%= item.listing.city %> · x<%= item.quantity %></div>
                  <div class="listing-price whale-cart-item-price"><%= item.subtotal.toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %> ₪</div>
                </div>
                <form method="POST" action="/whale/cart/remove">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="listingId" value="<%= item.listingId %>">
                  <button type="submit" class="btn btn-danger" aria-label="<%= t('cart.remove') %>"><%= t('cart.remove') %></button>
                </form>
              </article>
            <% }) %>
          </div>
        </div>

        <div class="card whale-cart-sidebar">
          <h3><%= t('cart.checkout') %></h3>
          <form method="POST" action="/whale/cart/checkout" class="auth-form" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label for="paymentMethod"><%= t('checkout.payment') %></label>
            <select id="paymentMethod" name="paymentMethod" required>
              <option value="cod"><%= t('checkout.pay_cod') %></option>
              <option value="card"><%= t('checkout.pay_card') %></option>
            </select>

            <label for="shippingMethod"><%= t('checkout.shipping') %></label>
            <select id="shippingMethod" name="shippingMethod" required>
              <option value="company"><%= t('checkout.ship_company') %></option>
              <option value="self_pickup"><%= t('checkout.ship_pickup') %></option>
              <option value="hand_to_hand"><%= t('checkout.ship_hand') %></option>
            </select>

            <label for="shippingCompany"><%= t('cart.shipping_company') %></label>
            <select id="shippingCompany" name="shippingCompany">
              <% if (shippingCos && shippingCos.length) { %>
                <% shippingCos.forEach((co) => { %>
                  <option value="<%= co.name %>"><%= lang === 'ar' ? co.nameAr : co.name %> · <%= co.basePrice %> ₪</option>
                <% }) %>
              <% } else { %>
                <option value=""><%= t('ui.not_available') %></option>
              <% } %>
            </select>

            <label for="buyerName"><%= t('checkout.full_name') %></label>
            <input id="buyerName" name="buyerName" type="text" autocomplete="name" required>

            <label for="buyerPhone"><%= t('checkout.phone') %></label>
            <input id="buyerPhone" name="buyerPhone" type="tel" inputmode="tel" autocomplete="tel" placeholder="0599-123-456" required>

            <label for="buyerCity"><%= t('checkout.city') %></label>
            <select id="buyerCity" name="buyerCity" required>
              <% cities.forEach((city) => { %>
                <option value="<%= city.label %>"><%= city.label %></option>
              <% }) %>
            </select>

            <label for="buyerAddress"><%= t('checkout.address') %></label>
            <input id="buyerAddress" name="buyerAddress" type="text" autocomplete="street-address" required>

            <label for="buyerNote"><%= t('checkout.note') %></label>
            <textarea id="buyerNote" name="buyerNote" rows="3"></textarea>

            <%- include('../partials/trust-box', { variant: 'inline' }) %>
            <p class="muted whale-refund-note"><%= t('checkout.refund_note') %></p>

            <button type="submit" class="btn btn-primary btn-full"><%= t('cart.checkout') %></button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
