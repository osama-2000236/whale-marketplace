<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="form-page">
    <h1><%= t('whale.cart') %> (<%= cart.count %>)</h1>

    <% if (cart.items.length) { %>
    <div class="cart-items">
      <% cart.items.forEach(item => { %>
      <div class="cart-item">
        <img src="<%= item.listing.images && item.listing.images[0] ? item.listing.images[0] : '/images/placeholder.png' %>" alt="" class="cart-thumb">
        <div class="cart-item-info">
          <h3><a href="/whale/listing/<%= item.listing.slug || item.listing.id %>"><%= item.listing.title %></a></h3>
          <p>₪<%= item.listing.price %> × <%= item.quantity %> = <strong>₪<%= item.subtotal %></strong></p>
        </div>
        <form method="post" action="/whale/cart/remove">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="listingId" value="<%= item.listingId %>">
          <button type="submit" class="btn btn-sm btn-outline btn-danger"><%= t('whale.remove') %></button>
        </form>
      </div>
      <% }) %>
    </div>

    <div class="cart-total"><strong><%= t('whale.total') %>: ₪<%= cart.total %></strong></div>

    <% if (currentUser) { %>
    <form method="post" action="/whale/cart/checkout" class="whale-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <h3><%= t('whale.payment_method') %></h3>
      <div class="radio-group">
        <label><input type="radio" name="paymentMethod" value="cod" checked> <%= t('whale.cod') %></label>
        <label><input type="radio" name="paymentMethod" value="card"> <%= t('whale.card') %></label>
      </div>
      <h3><%= t('whale.shipping_method') %></h3>
      <div class="radio-group">
        <label><input type="radio" name="shippingMethod" value="hand_to_hand" checked> <%= t('whale.hand_to_hand') %></label>
        <label><input type="radio" name="shippingMethod" value="company"> <%= t('whale.company_shipping') %></label>
      </div>
      <button type="submit" class="btn btn-primary btn-lg"><%= t('whale.checkout_now') %></button>
    </form>
    <% } else { %>
    <a href="/auth/login" class="btn btn-primary btn-lg"><%= t('nav.login') %></a>
    <% } %>

    <% } else { %>
    <div class="empty-state">
      <h3>🛒 <%= t('whale.cart_empty') %></h3>
      <a href="/whale" class="btn btn-primary"><%= t('whale.browse') %></a>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
