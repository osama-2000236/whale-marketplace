<%- include('../partials/header') %>

<section class="page-section whale-page">
  <div class="container" style="max-width:980px;">
    <h1 class="page-title"><%= t('cart.title') %></h1>
    <% const cartErrors = {
      empty: t('cart.err_empty'),
      checkout_failed: t('cart.err_checkout'),
      remove_failed: t('cart.err_remove'),
      card_multi_not_supported: t('cart.err_card_multi')
    }; %>

    <% if (query && query.error && cartErrors[query.error]) { %>
      <div class="alert alert-err" style="margin-bottom:14px;"><%= cartErrors[query.error] %></div>
    <% } %>

    <% if (!cart.items.length) { %>
      <div class="card" style="padding:24px;text-align:center;">
        <p style="font-size:16px;font-weight:700;margin-bottom:10px;"><%= t('cart.empty') %></p>
        <a href="/whale" class="btn btn-primary"><%= t('cart.empty_cta') %></a>
      </div>
    <% } else { %>
      <div style="display:grid;grid-template-columns:1.7fr 1fr;gap:14px;">
        <div class="card" style="padding:14px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <strong><%= cart.count %> <%= t('cart.items') %></strong>
            <span class="muted"><%= t('cart.total') %>: <strong style="color:var(--c-ocean)"><%= cart.total.toLocaleString('ar-PS') %> ₪</strong></span>
          </div>

          <div style="display:grid;gap:10px;">
            <% cart.items.forEach((item) => { %>
              <article class="card" style="padding:10px;display:grid;grid-template-columns:88px 1fr auto;gap:10px;align-items:center;">
                <a href="/whale/listing/<%= item.listing.slug || item.listing.id %>">
                  <img src="<%= item.listing.images[0] || '/images/products/placeholder.svg' %>" alt="<%= item.listing.title %>" style="width:88px;height:72px;object-fit:cover;border-radius:8px;">
                </a>
                <div>
                  <a href="/whale/listing/<%= item.listing.slug || item.listing.id %>" class="listing-title" dir="auto"><%= item.listing.title %></a>
                  <div class="listing-meta"><%= item.listing.city %> · x<%= item.quantity %></div>
                  <div class="listing-price" style="font-size:18px;"><%= item.subtotal.toLocaleString('ar-PS') %> ₪</div>
                </div>
                <form method="POST" action="/whale/cart/remove">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="listingId" value="<%= item.listingId %>">
                  <button type="submit" class="btn btn-danger"><%= t('cart.remove') %></button>
                </form>
              </article>
            <% }) %>
          </div>
        </div>

        <div class="card" style="padding:14px;height:max-content;">
          <h3 style="margin-bottom:10px;"><%= t('cart.checkout') %></h3>
          <form method="POST" action="/whale/cart/checkout" class="auth-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label for="paymentMethod"><%= t('checkout.payment') %></label>
            <select id="paymentMethod" name="paymentMethod" required>
              <option value="cod"><%= t('checkout.pay_cod') %></option>
              <option value="card"><%= t('checkout.pay_card') %></option>
            </select>

            <label for="shippingMethod"><%= t('checkout.shipping') %></label>
            <select id="shippingMethod" name="shippingMethod" required>
              <option value="company"><%= t('checkout.ship_company') %></option>
              <option value="self_pickup"><%= t('checkout.ship_pickup') %></option>
              <option value="hand_to_hand"><%= t('checkout.ship_hand') %></option>
            </select>

            <label for="shippingCompany"><%= t('cart.shipping_company') %></label>
            <select id="shippingCompany" name="shippingCompany">
              <% if (shippingCos && shippingCos.length) { %>
                <% shippingCos.forEach((co) => { %>
                  <option value="<%= co.name %>"><%= lang === 'ar' ? co.nameAr : co.name %> · <%= co.basePrice %> ₪</option>
                <% }) %>
              <% } else { %>
                <option value=""><%= t('ui.not_available') %></option>
              <% } %>
            </select>

            <label for="buyerName"><%= t('checkout.full_name') %></label>
            <input id="buyerName" name="buyerName" required>

            <label for="buyerPhone"><%= t('checkout.phone') %></label>
            <input id="buyerPhone" name="buyerPhone" required>

            <label for="buyerCity"><%= t('checkout.city') %></label>
            <select id="buyerCity" name="buyerCity" required>
              <% cities.forEach((city) => { %>
                <option value="<%= city.label %>"><%= city.label %></option>
              <% }) %>
            </select>

            <label for="buyerAddress"><%= t('checkout.address') %></label>
            <input id="buyerAddress" name="buyerAddress" required>

            <label for="buyerNote"><%= t('checkout.note') %></label>
            <textarea id="buyerNote" name="buyerNote" rows="3"></textarea>

            <p class="muted" style="font-size:13px;">🐳 <%= t('checkout.escrow_d') %></p>
            <p class="muted" style="font-size:13px;"><%= t('checkout.refund_note') %></p>

            <button type="submit" class="btn btn-primary btn-full"><%= t('cart.checkout') %></button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
