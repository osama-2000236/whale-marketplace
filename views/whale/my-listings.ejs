<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <div class="page-header">
      <h1><%= t('whale.my_listings') %></h1>
      <a href="/whale/sell" class="btn btn-primary"><%= t('whale.create_listing') %></a>
    </div>

    <% if (listings.length) { %>
    <div class="listings-table">
      <% listings.forEach(listing => { %>
      <div class="listing-row">
        <img src="<%= listing.images && listing.images[0] ? listing.images[0] : '/images/placeholder.png' %>" alt="" class="listing-row-thumb">
        <div class="listing-row-info">
          <h3><a href="/whale/listing/<%= listing.slug || listing.id %>"><%= listing.title %></a></h3>
          <p class="listing-row-meta">
            <span class="price">&#8362;<%= listing.price %></span>
            <% var statusMap = { active: 'success', sold: 'warning', draft: 'neutral', suspended: 'danger' }; %>
            <span class="status-badge status-<%= statusMap[listing.status] || 'neutral' %>"><%= t('status.' + listing.status) %></span>
            <span class="listing-views"><%= listing.views || 0 %> <%= t('whale.views') %></span>
          </p>
        </div>
        <div class="listing-row-actions">
          <a href="/whale/listing/<%= listing.id %>/edit" class="btn btn-sm btn-outline"><%= t('whale.edit') %></a>
          <% if (listing.status === 'active') { %>
          <form method="post" action="/whale/listing/<%= listing.id %>/mark-sold" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline"><%= t('whale.mark_sold') %></button>
          </form>
          <% } %>
          <form method="post" action="/whale/listing/<%= listing.id %>/delete" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline btn-danger" onclick="return confirm('<%= t('whale.confirm_delete') %>')"><%= t('whale.delete') %></button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <h3><%= t('whale.no_listings') %></h3>
      <p><%= t('whale.start_selling') %></p>
      <a href="/whale/sell" class="btn btn-primary"><%= t('whale.create_listing') %></a>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
