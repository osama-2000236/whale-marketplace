<%- include('../partials/header', { title: t('nav.my_listings') + ' — Whale' }) %>

<section class="page-section whale-page">
  <div class="container">
    <div style="display:flex; justify-content:space-between; gap:8px; align-items:center; flex-wrap:wrap;">
      <h1 class="page-title"><%= t('nav.my_listings') %></h1>
      <a href="/whale/sell" class="btn btn-primary"><%= t('market.add_listing') %></a>
    </div>

    <div class="listing-grid">
      <% if (listings.length) { %>
        <% listings.forEach((listing) => { %>
          <div class="listing-card">
            <a href="/whale/listing/<%= listing.slug || listing.id %>">
              <img src="<%= listing.images[0] || '/images/products/placeholder.svg' %>" class="listing-img" alt="<%= listing.title %>">
            </a>
            <div class="listing-body">
              <div class="listing-price"><%= listing.price.toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %> ₪</div>
              <a class="listing-title" dir="auto" href="/whale/listing/<%= listing.slug || listing.id %>"><%= listing.title %></a>
              <p class="muted"><%= t('order.status') %>: <%= t('status.' + listing.status) %> · <%= t('listing.orders_count', { n: listing._count.orders }) %></p>
              <div style="display:flex; flex-wrap:wrap; gap:6px;">
                <a href="/whale/listing/<%= listing.slug || listing.id %>/edit" class="btn btn-sm btn-ghost"><%= t('listing.edit') %></a>
                <form method="POST" action="/whale/listing/<%= listing.slug || listing.id %>/mark-sold">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-sm btn-primary"><%= t('listing.mark_sold') %></button>
                </form>
                <form method="POST" action="/whale/listing/<%= listing.slug || listing.id %>/delete">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-sm btn-danger"><%= t('listing.delete') %></button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="panel-card">
          <p class="muted"><%= t('empty.my_listings') %></p>
          <a href="/whale/sell" class="btn btn-primary"><%= t('empty.my_listings_cta') %></a>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
