<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container" style="max-width: 720px">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <h1><%= t('sell.title') %></h1>
    </div>

    <div class="card">
      <div class="card-body">
        <form method="POST" action="/whale/sell?_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">
                <%= t('sell.name') %>
                <span class="required">*</span>
              </label>
              <input type="text" name="title" class="input" required maxlength="100" />
            </div>
            <div class="form-group">
              <label class="form-label"><%= t('sell.name_ar') %></label>
              <input type="text" name="titleAr" class="input" maxlength="100" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">
              <%= t('sell.description') %>
              <span class="required">*</span>
            </label>
            <textarea name="description" class="textarea" required maxlength="5000"></textarea>
          </div>
          <div class="form-group">
            <label class="form-label"><%= t('sell.description_ar') %></label>
            <textarea name="descriptionAr" class="textarea" maxlength="5000"></textarea>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">
                <%= t('sell.price') %> ($)
                <span class="required">*</span>
              </label>
              <input type="number" name="price" class="input" required min="1" step="0.01" />
            </div>
            <div class="form-group">
              <label class="form-label"><%= t('sell.condition') %></label>
              <select name="condition" class="select">
                <% ['NEW','LIKE_NEW','GOOD','USED','FAIR','FOR_PARTS'].forEach(c => { %>
                <option value="<%= c %>"><%= t('condition.' + c) %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="checkbox-label">
              <input type="checkbox" name="negotiable" value="on" />
              <%= t('sell.negotiable') %>
            </label>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">
                <%= t('sell.category') %>
                <span class="required">*</span>
              </label>
              <select name="categoryId" class="select" required>
                <option value="">--</option>
                <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>">
                  <%= locale === 'ar' ? cat.nameAr : cat.name %>
                </option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">
                <%= t('sell.city') %>
                <span class="required">*</span>
              </label>
              <select name="city" class="select" required>
                <option value="">--</option>
                <% cities.forEach(c => { %>
                <option value="<%= c.value %>"><%= c.label %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">
              <%= t('sell.images') %>
              <span class="required">*</span>
            </label>
            <input
              type="file"
              name="images"
              class="input"
              accept="image/jpeg,image/png,image/webp"
              multiple
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label"><%= t('sell.tags') %></label>
            <input
              type="text"
              name="tags"
              class="input"
              placeholder="<%= locale === 'ar' ? 'مفصولة بفاصلة' : 'comma separated' %>"
            />
          </div>

          <button type="submit" class="btn btn-primary btn-block btn-lg mt-2">
            <%= t('sell.submit') %>
          </button>
        </form>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
