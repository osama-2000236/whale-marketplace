<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="form-page checkout-page">
    <h1><%= t('whale.checkout') %></h1>

    <div class="checkout-layout">
      <div class="checkout-form">
        <form method="post" action="/whale/listing/<%= listing.id %>/buy" class="whale-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <h3><%= t('whale.shipping_method') %></h3>
          <div class="radio-group">
            <label><input type="radio" name="shippingMethod" value="hand_to_hand" checked> <%= t('whale.hand_to_hand') %></label>
            <label><input type="radio" name="shippingMethod" value="self_pickup"> <%= t('whale.self_pickup') %></label>
            <label><input type="radio" name="shippingMethod" value="company"> <%= t('whale.company_shipping') %></label>
          </div>

          <div id="addressFields" style="display:none;">
            <h3><%= t('whale.shipping_address') %></h3>
            <div class="form-group"><label><%= t('whale.buyer_name') %></label><input type="text" name="buyerName"></div>
            <div class="form-group"><label><%= t('whale.phone') %></label><input type="tel" name="buyerPhone"></div>
            <div class="form-group">
              <label><%= t('whale.city') %></label>
              <select name="buyerCity"><% cities.forEach(c => { %><option value="<%= c.value %>"><%= c.name %></option><% }) %></select>
            </div>
            <div class="form-group"><label><%= t('whale.address') %></label><textarea name="buyerAddress" rows="2"></textarea></div>
            <% if (shippingCos && shippingCos.length) { %>
            <div class="form-group">
              <label><%= t('whale.shipping_company') %></label>
              <select name="shippingCompany">
                <% shippingCos.forEach(sc => { %>
                <option value="<%= sc.name %>"><%= lang === 'ar' ? sc.nameAr : sc.name %> — ₪<%= sc.basePrice %></option>
                <% }) %>
              </select>
            </div>
            <% } %>
          </div>

          <h3><%= t('whale.payment_method') %></h3>
          <div class="radio-group">
            <label><input type="radio" name="paymentMethod" value="cod" checked> <%= t('whale.cod') %></label>
            <label><input type="radio" name="paymentMethod" value="card"> <%= t('whale.card') %></label>
          </div>

          <div class="form-group"><label><%= t('whale.buyer_note') %></label><textarea name="buyerNote" rows="2"></textarea></div>
          <input type="hidden" name="quantity" value="1">

          <button type="submit" class="btn btn-primary btn-lg btn-block"><%= t('whale.place_order') %></button>
        </form>
      </div>

      <div class="checkout-summary">
        <div class="summary-card">
          <img src="<%= listing.images && listing.images[0] ? listing.images[0] : '/images/placeholder.png' %>" alt="">
          <h3><%= listing.title %></h3>
          <div class="summary-price">₪<%= listing.price %></div>
        </div>
        <%- include('../partials/trust-box') %>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
<script>
document.querySelectorAll('input[name="shippingMethod"]').forEach(function(r) {
  r.addEventListener('change', function() {
    document.getElementById('addressFields').style.display = this.value === 'company' ? '' : 'none';
  });
});
</script>
</body>
</html>
