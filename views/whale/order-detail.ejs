<%- include('../partials/header', { title: t('order.number') + ' #' + order.orderNumber + ' — Whale' }) %>

<%
  function eventLabel(event) {
    return t('order.event.' + event);
  }
  const isBuyer = currentUser && currentUser.id === order.buyerId;
  const isSeller = currentUser && currentUser.id === order.sellerId;
%>

<section class="page-section whale-page">
  <div class="container">
    <div class="panel-card">
      <h1><%= t('order.number') %> #<%= order.orderNumber %></h1>
      <span class="status-badge status-<%= order.orderStatus %>"><%= t('status.' + order.orderStatus) %></span>
      <p class="muted whale-escrow-copy" style="margin-top:8px;">🐳 <%= t('listing.escrow') %></p>
    </div>

    <div class="whale-order-layout">
      <div class="panel-card">
        <h3><%= t('order.timeline') %></h3>
        <div class="timeline" style="margin-top:10px;">
          <% order.timeline.forEach((event) => { %>
            <div class="timeline-event <%= event.event === order.orderStatus.toLowerCase() ? 'active' : '' %>">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <strong><%= eventLabel(event.event) %></strong>
                <span style="display:block;"><%= timeAgo(event.createdAt) %></span>
                <% if (event.note) { %><p dir="auto"><%= event.note %></p><% } %>
              </div>
            </div>
          <% }) %>
        </div>

        <% if (order.trackingNumber) { %>
          <div class="panel-card whale-tracking-card">
            <h4><%= t('order.track') %></h4>
            <p><%= t('order.tracking_company') %>: <strong><%= order.shippingCompany || t('ui.not_available') %></strong></p>
            <p><%= t('order.tracking_number') %>: <strong><%= order.trackingNumber %></strong></p>
            <% if (shippingCo && shippingCo.trackingUrl) { %>
              <a href="<%= shippingCo.trackingUrl.replace('{trackingNumber}', encodeURIComponent(order.trackingNumber)) %>" target="_blank" rel="noopener"><%= t('order.track') %></a>
            <% } %>
          </div>
        <% } %>
      </div>

      <aside class="panel-card">
        <h3><%= t('order.listing') %></h3>
        <div class="whale-order-item-row">
          <img src="<%= order.listing.images[0] || '/images/products/placeholder.svg' %>" alt="<%= order.listing.title %>" class="whale-order-item-image">
          <div>
            <strong dir="auto"><%= order.listing.title %></strong>
            <p><%= order.amount.toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %> ₪</p>
          </div>
        </div>

        <% if (isSeller && order.orderStatus === 'PENDING') { %>
          <form method="POST" action="/whale/orders/<%= order.id %>/confirm" style="margin-top:10px;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-primary btn-full"><%= t('ui.confirm') %></button>
          </form>
        <% } %>

        <% if (isSeller && order.orderStatus === 'SELLER_CONFIRMED') { %>
          <form method="POST" action="/whale/orders/<%= order.id %>/ship" style="margin-top:10px;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
              <label for="trackingNumber"><%= t('order.tracking_number') %></label>
              <input id="trackingNumber" type="text" name="trackingNumber" required>
            </div>
            <div class="form-group">
              <label for="shippingCompany"><%= t('order.tracking_company') %></label>
              <input id="shippingCompany" type="text" name="shippingCompany" required>
            </div>
            <div class="form-group">
              <label for="estimatedDelivery"><%= t('order.estimated_delivery') %></label>
              <input id="estimatedDelivery" type="date" name="estimatedDelivery">
            </div>
            <button type="submit" class="btn btn-primary btn-full"><%= t('order.add_tracking') %></button>
          </form>
        <% } %>

        <% if (isBuyer && ['SHIPPED', 'DELIVERED', 'IN_TRANSIT'].includes(order.orderStatus)) { %>
          <form method="POST" action="/whale/orders/<%= order.id %>/confirm-delivery" style="margin-top:10px;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-primary btn-full"><%= t('order.confirm_rcv') %></button>
          </form>
          <a href="/buyer-protection" class="muted" style="display:inline-block; margin-top:8px;"><%= t('order.dispute') %></a>
        <% } %>

        <% if (isBuyer && order.orderStatus === 'COMPLETED' && !order.review) { %>
          <form method="POST" action="/whale/orders/<%= order.id %>/review" style="margin-top:12px;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
              <label for="rating"><%= t('order.review_cta') %></label>
              <select id="rating" name="rating" required>
                <option value="5">5</option>
                <option value="4">4</option>
                <option value="3">3</option>
                <option value="2">2</option>
                <option value="1">1</option>
              </select>
            </div>
            <div class="form-group">
              <label for="reviewTitle"><%= t('order.rate_title') %></label>
              <input id="reviewTitle" type="text" name="title">
            </div>
            <div class="form-group">
              <label for="reviewBody"><%= t('order.rate_notes') %></label>
              <textarea id="reviewBody" name="body" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-ghost btn-full"><%= t('order.review_cta') %></button>
          </form>
        <% } %>

        <% if (['PENDING', 'SELLER_CONFIRMED'].includes(order.orderStatus)) { %>
          <form method="POST" action="/whale/orders/<%= order.id %>/cancel" style="margin-top:10px;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="text" name="reason" placeholder="<%= t('order.cancel_reason') %>" required>
            <button type="submit" class="btn btn-danger btn-full" style="margin-top:8px;"><%= t('order.cancel') %></button>
          </form>
        <% } %>
      </aside>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
