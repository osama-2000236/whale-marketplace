<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <h1><%= t('whale.order') %> #<%= order.orderNumber %></h1>

    <div class="order-detail-layout">
      <div class="order-main">
        <!-- Timeline -->
        <div class="order-timeline">
          <% if (order.timeline) { order.timeline.forEach(ev => { %>
          <div class="timeline-item">
            <span class="timeline-dot"></span>
            <div class="timeline-content">
              <strong><%= t('event.' + ev.event) || ev.event %></strong>
              <% if (ev.note) { %><p><%= ev.note %></p><% } %>
              <span class="timeline-time"><%= timeAgo(ev.createdAt) %></span>
            </div>
          </div>
          <% }) } %>
        </div>

        <!-- Actions -->
        <div class="order-actions">
          <% if (order.sellerId === currentUser.id) { %>
            <% if (order.orderStatus === 'PENDING') { %>
            <form method="post" action="/whale/orders/<%= order.id %>/confirm" class="inline-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-primary"><%= t('whale.confirm_order') %></button>
            </form>
            <% } %>
            <% if (['PENDING', 'SELLER_CONFIRMED'].includes(order.orderStatus)) { %>
            <form method="post" action="/whale/orders/<%= order.id %>/ship" class="inline-form ship-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="text" name="trackingNumber" placeholder="<%= t('whale.tracking_number') %>">
              <button type="submit" class="btn btn-primary"><%= t('whale.mark_shipped') %></button>
            </form>
            <% } %>
          <% } %>

          <% if (order.buyerId === currentUser.id) { %>
            <% if (['SHIPPED', 'IN_TRANSIT', 'DELIVERED'].includes(order.orderStatus)) { %>
            <form method="post" action="/whale/orders/<%= order.id %>/confirm-delivery" class="inline-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-primary"><%= t('whale.confirm_delivery') %></button>
            </form>
            <% } %>
          <% } %>

          <% if (!['COMPLETED', 'CANCELLED', 'REFUNDED'].includes(order.orderStatus)) { %>
          <form method="post" action="/whale/orders/<%= order.id %>/cancel" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="text" name="reason" placeholder="<%= t('whale.cancel_reason') %>">
            <button type="submit" class="btn btn-outline btn-danger"><%= t('whale.cancel_order') %></button>
          </form>
          <% } %>

          <!-- Review -->
          <% if (order.orderStatus === 'COMPLETED' && order.buyerId === currentUser.id && !order.review) { %>
          <form method="post" action="/whale/orders/<%= order.id %>/review" class="whale-form review-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <h3><%= t('whale.leave_review') %></h3>
            <div class="form-group">
              <label><%= t('whale.rating') %></label>
              <select name="rating"><option value="5">★★★★★</option><option value="4">★★★★</option><option value="3">★★★</option><option value="2">★★</option><option value="1">★</option></select>
            </div>
            <div class="form-group"><input type="text" name="title" placeholder="<%= t('whale.review_title') %>"></div>
            <div class="form-group"><textarea name="body" rows="3" placeholder="<%= t('whale.review_body') %>"></textarea></div>
            <button type="submit" class="btn btn-primary"><%= t('whale.submit_review') %></button>
          </form>
          <% } %>
          <% if (order.review) { %>
          <%- include('../partials/review-card', { review: order.review }) %>
          <% } %>
        </div>
      </div>

      <div class="order-sidebar">
        <div class="order-summary-card">
          <% if (order.listing) { %>
          <a href="/whale/listing/<%= order.listing.slug || order.listing.id %>">
            <img src="<%= order.listing.images && order.listing.images[0] ? order.listing.images[0] : '/images/placeholder.png' %>" alt="">
            <h3><%= order.listing.title %></h3>
          </a>
          <% } %>
          <div class="summary-row"><span><%= t('whale.amount') %></span><strong>₪<%= order.amount %></strong></div>
          <div class="summary-row"><span><%= t('whale.quantity') %></span><span><%= order.quantity %></span></div>
          <div class="summary-row"><span><%= t('whale.payment') %></span><span><%= order.paymentMethod %></span></div>
          <div class="summary-row"><span><%= t('whale.shipping') %></span><span><%= order.shippingMethod || '—' %></span></div>
          <% if (order.trackingNumber) { %>
          <div class="summary-row"><span><%= t('whale.tracking') %></span><span><%= order.trackingNumber %></span></div>
          <% } %>
        </div>

        <div class="order-parties">
          <div class="party-card">
            <h4><%= t('whale.buyer') %></h4>
            <a href="/u/<%= order.buyer.username %>"><%= order.buyer.username %></a>
          </div>
          <div class="party-card">
            <h4><%= t('whale.seller') %></h4>
            <a href="/whale/seller/<%= order.seller.username %>"><%= order.seller.username %></a>
          </div>
        </div>

        <%- include('../partials/trust-box') %>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
