<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('partials/navbar') %>
<main class="main-content">
  <div class="page-container welcome-page">
    <div class="welcome-hero">
      <h1><%= t('welcome.title') %></h1>
      <p class="welcome-subtitle"><%= t('welcome.subtitle') %></p>
      <% if (typeof referralCode !== 'undefined' && referralCode) { %>
      <div class="referral-badge"><%= t('welcome.referred') %></div>
      <% } %>
      <div class="welcome-cta">
        <a href="/auth/register<%= typeof referralCode !== 'undefined' && referralCode ? '?ref=' + referralCode : '' %>" class="btn btn-primary btn-lg"><%= t('welcome.get_started') %></a>
        <a href="/whale" class="btn btn-outline btn-lg"><%= t('welcome.browse') %></a>
      </div>
    </div>

    <div class="welcome-features">
      <div class="feature-card">
        <h3><%= t('welcome.feature_1_title') %></h3>
        <p><%= t('welcome.feature_1_desc') %></p>
      </div>
      <div class="feature-card">
        <h3><%= t('welcome.feature_2_title') %></h3>
        <p><%= t('welcome.feature_2_desc') %></p>
      </div>
      <div class="feature-card">
        <h3><%= t('welcome.feature_3_title') %></h3>
        <p><%= t('welcome.feature_3_desc') %></p>
      </div>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
</body>
</html>
