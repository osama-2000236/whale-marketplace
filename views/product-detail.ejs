<%- include('partials/header') %>

<section class="section page-section">
  <div class="container">
    <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/">الرئيسية</a> /
      <a href="/products">المنتجات</a> /
      <% if (category) { %><a href="/products?category=<%= category.id %>"><%= category.nameAr %></a> / <% } %>
      <span><%= product.nameAr %></span>
    </div>

    <div class="product-detail">
      <div class="product-detail-image">
        <% if (product.badge) { %><span class="product-badge"><%= product.badge %></span><% } %>
        <img src="<%= product.image %>" alt="<%= product.nameAr %>" onerror="this.src='/images/products/placeholder.svg'">
      </div>
      <div class="product-detail-info">
        <h1><%= product.nameAr %></h1>
        <% if (product.name !== product.nameAr) { %><p class="product-name-en"><%= product.name %></p><% } %>
        <% if (category) { %><span class="product-category-tag"><%= category.icon %> <%= category.nameAr %></span><% } %>

        <div class="product-detail-price">
          <span class="price-main"><%= config.currency %> <%= product.price.toLocaleString() %></span>
          <% if (product.oldPrice) { %>
          <span class="price-old"><%= config.currency %> <%= product.oldPrice.toLocaleString() %></span>
          <span class="price-discount">وفر <%= config.currency %> <%= (product.oldPrice - product.price).toLocaleString() %></span>
          <% } %>
        </div>

        <p class="product-detail-desc"><%= product.description %></p>

        <% if (product.specs && Object.keys(product.specs).length > 0) { %>
        <div class="specs-table">
          <h3>المواصفات</h3>
          <table>
            <% Object.entries(product.specs).forEach(([key, val]) => { %>
            <tr>
              <td class="spec-key"><%= key %></td>
              <td class="spec-val"><%= val %></td>
            </tr>
            <% }) %>
          </table>
        </div>
        <% } %>

        <div class="product-detail-actions">
          <a href="https://wa.me/<%= whatsappNumber %>?text=مرحبا، أريد طلب: <%= encodeURIComponent(product.nameAr) %> - السعر: <%= product.price %> شيكل" target="_blank" class="btn btn-primary btn-lg">📱 اطلب عبر واتساب</a>
          <a href="tel:<%= config.contact.phone %>" class="btn btn-outline">📞 اتصل بنا</a>
        </div>

        <div class="product-availability">
          <% if (product.inStock) { %>
          <span class="in-stock">✅ متوفر في المخزون</span>
          <% } else { %>
          <span class="out-of-stock">❌ غير متوفر حالياً</span>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    <% if (relatedProducts.length > 0) { %>
    <div class="related-products">
      <h2>منتجات مشابهة</h2>
      <div class="products-grid">
        <% relatedProducts.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
