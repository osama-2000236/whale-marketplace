<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="<%= typeof config !== 'undefined' && config.seo ? config.seo.description : t('app.meta_desc') %>">
<meta name="csrf-token" content="<%= csrfToken %>">
<% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
<script type="application/ld+json"><%- JSON.stringify(jsonLd) %></script>
<% } %>
<title><%= typeof title !== 'undefined' ? title + ' — ' + t('app.name') : t('app.name') %></title>
<link rel="icon" href="/img/whale-icon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/WHALE_UI_SYSTEM_V2.css">
<link rel="stylesheet" href="/css/style.css">
<% if (typeof adminPage !== 'undefined' && adminPage) { %>
<link rel="stylesheet" href="/css/admin.css">
<% } %>
<link rel="stylesheet" href="/css/whale-v3.css">
<script>
(function(){
  var t = localStorage.getItem('whale-theme') || sessionStorage.getItem('whale-theme') || '<%= theme %>';
  if (t === 'dark') document.documentElement.setAttribute('data-theme','dark');
})();
</script>
