<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <h3><svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true"><path d="M32 8C18 8 8 20 8 32c0 10 6 18 14 22 2 1 4 2 6 2h8c2 0 4-1 6-2 8-4 14-12 14-22C56 20 46 8 32 8z" fill="var(--v3-brand)"/><circle cx="24" cy="28" r="3" fill="#fff"/><path d="M20 40c4 4 16 4 20 0" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/></svg> Whale · الحوت</h3>
      <p><%= t('app.tagline') %></p>
      <p class="trust-text"><%= t('app.trust_promise') %></p>
    </div>
    <div class="footer-links">
      <h4><%= t('footer.marketplace') %></h4>
      <ul>
        <li><a href="/whale"><%= t('nav.marketplace') %></a></li>
        <li><a href="/whale/sell"><%= t('whale.sell_now') %></a></li>
        <li><a href="/pricing"><%= t('nav.pricing') %></a></li>
      </ul>
    </div>
    <div class="footer-links">
      <h4><%= t('footer.help') %></h4>
      <ul>
        <li><a href="/forum"><%= t('nav.forum') %></a></li>
        <li><a href="/safety"><%= t('nav.safety') %></a></li>
        <li><a href="/buyer-protection"><%= t('nav.buyer_protection') %></a></li>
        <li><a href="/contact"><%= t('nav.contact') %></a></li>
        <li><a href="/about"><%= t('nav.about') %></a></li>
      </ul>
    </div>
    <div class="footer-contact">
      <h4><%= t('footer.contact') %></h4>
      <% if (whatsappNumber) { %>
      <a href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener"><%= t('footer.contact_wa') %></a>
      <% } %>
      <% if (typeof config !== 'undefined' && config.contact) { %>
      <p><%= config.contact.email || '' %></p>
      <% } %>
    </div>
  </div>
  <div class="footer-bottom">
    <p><%= t('app.copyright') %></p>
    <div class="footer-legal">
      <a href="/terms"><%= t('nav.terms') %></a>
      <a href="/privacy"><%= t('nav.privacy') %></a>
    </div>
  </div>
</footer>
<%- include('foot') %>
