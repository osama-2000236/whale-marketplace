<%#
  @partial star-rating.ejs
  @description Renders a star rating display (★★★★☆)
  @param {number} rating - Rating value from 1 to 5
  @param {number} [max=5] - Maximum stars
  @example <%- include('partials/star-rating', { rating: 4 }) %>
%>
<%
  const r = Math.round(Number(typeof rating !== 'undefined' ? rating : 0));
  const m = (typeof max !== 'undefined' && max) || 5;
  const filled = Math.min(r, m);
  const empty = m - filled;
  const ariaText = filled + '/' + m;
%>
<span class="stars" role="img" aria-label="<%= ariaText %> stars"><%- '\u2605'.repeat(filled) %><%- '\u2606'.repeat(empty) %></span>
