<article class="product-card">
  <a href="/api/products/<%= product.id %>">
    <% if (product.image) { %><img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy"><% } %>
    <div class="product-card-body">
      <h3><%= lang === 'ar' && product.nameAr ? product.nameAr : product.name %></h3>
      <div class="product-price">₪<%= product.price %></div>
      <% if (product.badge) { %><span class="product-badge"><%= product.badge %></span><% } %>
    </div>
  </a>
</article>
