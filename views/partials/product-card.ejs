<div class="product-card">
  <% if (product.badge) { %>
  <span class="product-badge"><%= product.badge %></span>
  <% } %>
  <a href="/product/<%= product.id %>" class="product-image-link">
    <img src="<%= product.image %>" alt="<%= product.nameAr %>" class="product-image" loading="lazy" onerror="this.src='/images/products/placeholder.svg'">
  </a>
  <div class="product-info">
    <h3 class="product-name"><a href="/product/<%= product.id %>"><%= product.nameAr %></a></h3>
    <p class="product-desc"><%= product.description ? product.description.substring(0, 80) + '...' : '' %></p>
    <div class="product-price-row">
      <span class="product-price"><%= config.currency %> <%= product.price.toLocaleString() %></span>
      <% if (product.oldPrice) { %>
      <span class="product-old-price"><%= config.currency %> <%= product.oldPrice.toLocaleString() %></span>
      <% } %>
    </div>
    <div class="product-actions">
      <a href="https://wa.me/<%= whatsappNumber %>?text=مرحبا، أريد الاستفسار عن: <%= encodeURIComponent(product.nameAr) %>" target="_blank" class="btn btn-primary btn-sm">📱 اطلب الآن</a>
      <a href="/product/<%= product.id %>" class="btn btn-outline btn-sm">التفاصيل</a>
    </div>
  </div>
</div>
