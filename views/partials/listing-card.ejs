<a href="/whale/listing/<%= listing.slug %>" class="listing-card">
  <div class="listing-card-image">
    <% if (listing.images && listing.images.length > 0) { %>
    <img src="<%= listing.images[0] %>" alt="<%= listing.title %>" loading="lazy" />
    <% } else { %>
    <div
      style="
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        font-size: 2rem;
      "
    >
      🐋
    </div>
    <% } %>
    <div class="listing-card-badge">
      <span class="badge badge-info"><%= t('condition.' + listing.condition) %></span>
    </div>
  </div>
  <div class="listing-card-body">
    <div class="listing-card-title">
      <%= locale === 'ar' && listing.titleAr ? listing.titleAr : listing.title %>
    </div>
    <div class="listing-card-meta">
      <span><%= listing.city %></span>
      <% if (listing.category) { %>
      <span>&middot;</span>
      <span><%= locale === 'ar' ? listing.category.nameAr : listing.category.name %></span>
      <% } %>
    </div>
    <div class="listing-card-price">
      $<%= parseFloat(listing.price).toLocaleString() %> <% if (listing.negotiable) { %>
      <span class="text-sm text-muted">(<%= t('listing.negotiable') %>)</span>
      <% } %>
    </div>
  </div>
</a>
