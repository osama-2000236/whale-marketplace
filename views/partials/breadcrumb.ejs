<%#
  @partial breadcrumb.ejs
  @description Breadcrumb navigation for page hierarchy
  @param {Array<{label: string, href: string}>} crumbs - Array of breadcrumb items (last one is current page, no href)
  @example <%- include('partials/breadcrumb', { crumbs: [{label: t('nav.home'), href: '/'}, {label: t('nav.market'), href: '/whale'}, {label: listing.title}] }) %>
%>
<%
  const items = (typeof crumbs !== 'undefined' && Array.isArray(crumbs)) ? crumbs : [];
%>
<% if (items.length > 1) { %>
<nav class="whale-breadcrumb" aria-label="<%= typeof t === 'function' ? t('ui.breadcrumb') : 'Breadcrumb' %>">
  <ol>
    <% items.forEach((crumb, i) => { %>
      <li>
        <% if (i < items.length - 1 && crumb.href) { %>
          <a href="<%= crumb.href %>"><%= crumb.label %></a>
        <% } else { %>
          <span aria-current="page"><%= crumb.label %></span>
        <% } %>
      </li>
    <% }) %>
  </ol>
</nav>
<% } %>
