<div class="review-card">
  <div class="review-header">
    <% if (review.reviewer) { %>
    <span class="review-author">
      <% if (review.reviewer.avatar) { %><img src="<%= review.reviewer.avatar %>" alt="" class="avatar-xs"><% } %>
      <%= review.reviewer.username %>
    </span>
    <% } %>
    <span class="review-rating">
      <% for (var s = 1; s <= 5; s++) { %>
      <span class="star <%= s <= review.rating ? 'filled' : '' %>">★</span>
      <% } %>
    </span>
    <span class="review-date"><%= timeAgo(review.createdAt) %></span>
  </div>
  <% if (review.title) { %><h4 class="review-title"><%= review.title %></h4><% } %>
  <% if (review.body) { %><p class="review-body"><%= review.body %></p><% } %>
</div>
