<%
  const typeIcons = {
    LIKE: '👍',
    COMMENT: '💬',
    FOLLOW: '👤',
    MENTION: '📣',
    SALE_INQUIRY: '🛒',
    ANNOUNCEMENT: '📢'
  };
  const icon = typeIcons[item.type] || '🔔';
  const label = t('notif.' + item.type.toLowerCase()) || item.type;
%>
<article class="notification-item <%= item.isRead ? '' : 'unread' %>" role="article" aria-label="<%= label %>">
  <div class="notification-title"><span aria-hidden="true"><%= icon %></span> <%= label %></div>
  <% if (item.message) { %><p class="notification-body" dir="auto"><%= item.message %></p><% } %>
  <time class="notification-time" datetime="<%= new Date(item.createdAt).toISOString() %>"><%= new Date(item.createdAt).toLocaleString(lang === 'ar' ? 'ar-PS' : 'en-US') %></time>
</article>
