<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-brand">🐋 <%= locale === 'ar' ? 'الحوت' : 'Whale' %></a>

    <button type="button" class="navbar-toggle" aria-label="Menu">☰</button>

    <div class="navbar-nav">
      <a href="/whale" class="nav-link"><%= t('nav.browse') %></a>
      <% if (user && canSell) { %>
      <a href="/whale/sell" class="nav-link"><%= t('nav.sell') %></a>
      <% } %>
      <% if (user) { %>
      <a href="/whale/dashboard" class="nav-link"><%= t('nav.dashboard') %></a>
      <a href="/whale/orders" class="nav-link"><%= t('nav.orders') %></a>
      <% } %>
      <% if (user && user.role === 'ADMIN') { %>
      <a href="/admin" class="nav-link"><%= t('nav.admin') %></a>
      <% } %>
    </div>

    <div class="navbar-actions">
      <button type="button" class="icon-btn" data-theme-toggle title="Toggle theme">
        <span class="theme-toggle-icon">🌙</span>
      </button>

      <% if (locale === 'ar') { %>
      <button type="button" class="icon-btn" data-locale="en" title="English">EN</button>
      <% } else { %>
      <button type="button" class="icon-btn" data-locale="ar" title="عربي">ع</button>
      <% } %>
      <% if (user) { %>
      <a href="/whale/saved" class="icon-btn" title="<%= t('nav.saved') %>">
        🤍 <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
        <span class="notification-count"><%= unreadCount %></span>
        <% } %>
      </a>

      <div class="user-menu">
        <button type="button" class="user-menu-trigger">
          <div class="avatar avatar-sm">
            <% if (user.avatarUrl) { %>
            <img src="<%= user.avatarUrl %>" alt="" />
            <% } else { %>
            <%= user.username.charAt(0).toUpperCase() %>
            <% } %>
          </div>
        </button>
        <div class="user-menu-dropdown">
          <a href="/profile"><%= t('nav.profile') %></a>
          <a href="/whale/orders"><%= t('nav.orders') %></a>
          <a href="/whale/saved"><%= t('nav.saved') %></a>
          <% if (!canSell) { %>
          <a href="/upgrade"><%= t('nav.upgrade') %></a>
          <% } %>
          <div class="dropdown-divider"></div>
          <form action="/auth/logout" method="POST" style="margin: 0">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button
              type="submit"
              style="
                width: 100%;
                text-align: start;
                background: none;
                border: none;
                padding: 0.625rem 0.75rem;
                font-family: inherit;
                font-size: 0.875rem;
                color: var(--text-secondary);
                cursor: pointer;
                border-radius: var(--radius-md);
              "
            >
              <%= t('nav.logout') %>
            </button>
          </form>
        </div>
      </div>
      <% } else { %>
      <a href="/auth/login" class="btn btn-ghost btn-sm"><%= t('nav.login') %></a>
      <a href="/auth/register" class="btn btn-primary btn-sm"><%= t('nav.register') %></a>
      <% } %>
    </div>
  </div>
</nav>
