<header class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/whale" class="nav-brand">
      <svg width="32" height="32" viewBox="0 0 64 64" fill="none"><path d="M32 8C18 8 8 20 8 32c0 10 6 18 14 22 2 1 4 2 6 2h8c2 0 4-1 6-2 8-4 14-12 14-22C56 20 46 8 32 8z" fill="var(--v3-brand)"/><circle cx="24" cy="28" r="3" fill="#fff"/><path d="M20 40c4 4 16 4 20 0" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/><path d="M32 8c0 0-4-4-8 0" stroke="var(--v3-brand)" stroke-width="2" opacity="0.5"/></svg>
      <span class="brand-text">Whale</span>
    </a>

    <form class="nav-search" action="/whale" method="get">
      <input type="search" name="q" placeholder="<%= t('search.placeholder') %>" value="<%= typeof filters !== 'undefined' && filters ? (filters.q || '') : '' %>" autocomplete="off" id="globalSearchInput">
      <button type="submit" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      <div class="search-dropdown" id="searchDropdown"></div>
    </form>

    <nav class="nav-links">
      <a href="/" class="<%= path === '/' ? 'active' : '' %>"><%= t('nav.home') %></a>
      <a href="/whale" class="<%= path === '/whale' || path.startsWith('/whale') ? 'active' : '' %>"><%= t('nav.marketplace') %></a>
      <a href="/forum" class="<%= path.startsWith('/forum') ? 'active' : '' %>"><%= t('nav.forum') %></a>

      <% if (isPro) { %>
      <a href="/whale/sell" class="btn btn-sm btn-primary"><%= t('whale.sell_now') %></a>
      <% } %>

      <!-- Theme toggle -->
      <button class="btn-icon theme-toggle" id="themeToggle" aria-label="Toggle theme" aria-pressed="<%= theme === 'dark' %>">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>

      <!-- Language toggle -->
      <form method="post" action="/prefs/lang" style="display:inline;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="lang" value="<%= lang === 'ar' ? 'en' : 'ar' %>">
        <button type="submit" class="btn-icon lang-toggle" aria-label="Switch language"><%= lang === 'ar' ? 'EN' : 'عر' %></button>
      </form>

      <% if (currentUser) { %>
      <!-- Notifications -->
      <div class="nav-dropdown" id="notifDropdown">
        <button class="btn-icon notif-bell" aria-label="Notifications" aria-expanded="false">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <% if (unreadCount > 0) { %><span class="badge"><%= unreadCount > 9 ? '9+' : unreadCount %></span><% } %>
        </button>
        <div class="dropdown-menu notif-menu">
          <div class="dropdown-header"><%= t('notifications.title') %></div>
          <% if (navNotifications && navNotifications.length) { %>
            <% navNotifications.slice(0, 6).forEach(n => { %>
            <a href="/notifications" class="dropdown-item <%= n.isRead ? '' : 'unread' %>">
              <span class="notif-msg"><%= n.message %></span>
              <span class="notif-time"><%= timeAgo(n.createdAt) %></span>
            </a>
            <% }) %>
          <% } else { %>
            <div class="dropdown-item empty"><%= t('notifications.empty') %></div>
          <% } %>
          <a href="/notifications" class="dropdown-footer"><%= t('notifications.view_all') %></a>
        </div>
      </div>

      <!-- Cart -->
      <a href="/whale/cart" class="btn-icon cart-icon" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <% if (cartCount > 0) { %><span class="badge"><%= cartCount %></span><% } %>
      </a>

      <!-- User menu -->
      <div class="nav-dropdown" id="userDropdown">
        <button class="btn-icon user-avatar-btn" aria-label="User menu" aria-expanded="false">
          <% if (currentUser.avatar) { %>
          <img src="<%= currentUser.avatar %>" alt="" class="avatar-sm">
          <% } else { %>
          <span class="avatar-sm avatar-initials"><%= currentUser.username.charAt(0).toUpperCase() %></span>
          <% } %>
        </button>
        <div class="dropdown-menu user-menu">
          <div class="dropdown-header"><%= currentUser.username %></div>
          <a href="/u/<%= currentUser.username %>" class="dropdown-item"><%= t('nav.profile') %></a>
          <a href="/whale/my-listings" class="dropdown-item"><%= t('nav.my_listings') %></a>
          <a href="/whale/orders" class="dropdown-item"><%= t('nav.my_orders') %></a>
          <a href="/whale/saved" class="dropdown-item"><%= t('nav.saved') %></a>
          <a href="/whale/dashboard" class="dropdown-item"><%= t('nav.dashboard') %></a>
          <a href="/settings" class="dropdown-item"><%= t('nav.settings') %></a>
          <% if (!isPro) { %>
          <a href="/upgrade" class="dropdown-item upgrade-item"><%= t('nav.upgrade') %> ✨</a>
          <% } else { %>
          <span class="dropdown-item pro-badge">Pro ✓</span>
          <% } %>
          <% if (isAdmin) { %>
          <a href="/admin" class="dropdown-item admin-item"><%= t('nav.admin') %></a>
          <% } %>
          <hr class="dropdown-divider">
          <form method="post" action="/auth/logout">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="dropdown-item logout-btn"><%= t('nav.logout') %></button>
          </form>
        </div>
      </div>
      <% } else { %>
      <a href="/auth/login" class="btn btn-sm btn-outline"><%= t('nav.login') %></a>
      <a href="/auth/register" class="btn btn-sm btn-primary"><%= t('nav.register') %></a>
      <% } %>
    </nav>

    <button class="nav-toggle" id="navToggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile Bottom Nav -->
<nav class="mobile-nav" id="mobileNav">
  <a href="/" class="mobile-nav-item <%= path === '/' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
    <span><%= t('nav.home') %></span>
  </a>
  <a href="/forum" class="mobile-nav-item <%= path.startsWith('/forum') ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <span><%= t('nav.forum') %></span>
  </a>
  <% if (isPro) { %>
  <a href="/whale/sell" class="mobile-nav-item sell-fab">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
  </a>
  <% } %>
  <a href="/whale/orders" class="mobile-nav-item">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
    <span><%= t('nav.orders') %></span>
  </a>
  <a href="<%= currentUser ? '/u/' + currentUser.username : '/auth/login' %>" class="mobile-nav-item">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    <span><%= currentUser ? t('nav.profile') : t('nav.login') %></span>
  </a>
</nav>
