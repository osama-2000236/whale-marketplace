<%
  var navUser = (typeof user !== 'undefined' && user) ? user : ((typeof currentUser !== 'undefined') ? currentUser : null);
  var unread = (typeof unreadCount !== 'undefined') ? unreadCount : ((typeof unreadNotificationsCount !== 'undefined') ? unreadNotificationsCount : 0);
  var isAuthPage = (path || '').startsWith('/auth/login') || (path || '').startsWith('/auth/register');
  function iconForNotification(item) {
    var message = String(item && item.message || '').toLowerCase();
    if (message.includes('طلب جديد') || message.includes('new order')) return '🛒';
    if (message.includes('shipped') || message.includes('تم شحن')) return '🚚';
    if (message.includes('مكتمل') || message.includes('completed')) return '✅';
    if (message.includes('trial') || message.includes('pro')) return '⚡';
    return '🐳';
  }
%>
<nav class="navbar whale-navbar" id="navbar" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-brand whale-logo nav-logo" aria-label="Whale home">
      <svg class="logo-mark" width="30" height="30" viewBox="0 0 56 56" fill="none" aria-hidden="true">
        <ellipse cx="26" cy="30" rx="18" ry="13" fill="var(--c-ocean)"/>
        <ellipse cx="16" cy="26" rx="10" ry="9" fill="var(--c-ocean)"/>
        <circle cx="13" cy="24" r="2.5" fill="white"/>
        <circle cx="13.8" cy="23.2" r="1" fill="var(--c-deep)"/>
        <path d="M42 32 Q50 24 52 30 Q48 34 44 35 Z" fill="var(--c-wave)"/>
        <path d="M42 34 Q50 42 52 37 Q48 33 44 32 Z" fill="var(--c-wave)"/>
      </svg>
      <span class="nav-brand-name"><%= t('app.name') %></span>
    </a>

    <% if (!isAuthPage) { %>
      <div class="nav-search" role="search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input
          type="text"
          placeholder="<%= t('nav.search_ph') %>"
          aria-label="<%= t('nav.search_ph') %>"
          onkeydown="if(event.key==='Enter'&&this.value.trim())window.location='/whale?q='+encodeURIComponent(this.value.trim())"
        >
      </div>

      <div class="nav-links whale-nav-links" aria-label="Site sections">
        <a href="/" class="<%= path==='/' ? 'active' : '' %>" aria-current="<%= path==='/' ? 'page' : 'false' %>"><%= t('nav.home') %></a>
        <a href="/whale" class="<%= path.startsWith('/whale') ? 'active' : '' %>" aria-current="<%= path.startsWith('/whale') ? 'page' : 'false' %>"><%= t('nav.marketplace') %></a>
        <a href="/forum" class="<%= path.startsWith('/forum') ? 'active' : '' %>" aria-current="<%= path.startsWith('/forum') ? 'page' : 'false' %>"><%= t('nav.forum') %></a>
      </div>
    <% } %>

    <div class="nav-right">
      <% if (!isAuthPage) { %>
        <form action="/prefs/theme" method="POST" class="nav-theme-form" data-theme-form>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="theme" value="<%= theme === 'dark' ? 'light' : 'dark' %>" data-theme-next>
          <button type="submit" class="nav-icon-btn theme-toggle" data-theme-toggle aria-label="<%= theme==='dark' ? t('ui.theme_light') : t('ui.theme_dark') %>">
            <span class="theme-toggle-track" aria-hidden="true">
              <svg class="theme-icon theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.2M12 19.3v2.2M4.7 4.7l1.6 1.6M17.7 17.7l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.7 19.3l1.6-1.6M17.7 6.3l1.6-1.6"/></svg>
              <svg class="theme-icon theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21 14.8A9 9 0 1 1 9.2 3a7.2 7.2 0 0 0 11.8 11.8Z"/></svg>
            </span>
          </button>
        </form>

        <form action="/prefs/lang" method="POST" style="display:inline;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="lang" value="<%= lang === 'ar' ? 'en' : 'ar' %>">
          <button type="submit" class="nav-lang-btn" aria-label="<%= lang==='ar' ? 'Switch to English' : 'التبديل إلى العربية' %>">
            <%= lang === 'ar' ? 'EN' : 'ع' %>
          </button>
        </form>
      <% } %>

      <% if (navUser && !isAuthPage) { %>
        <div class="nav-notification-shell">
          <button type="button" class="nav-icon-btn nav-notification-trigger" aria-label="<%= t('nav.notifications') %>" aria-haspopup="true" aria-expanded="false" data-notification-toggle>
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <% if (unread > 0) { %><span class="notif-badge"><%= unread > 9 ? '9+' : unread %></span><% } %>
          </button>
          <div class="whale-notification-panel" data-notification-panel>
            <div class="whale-notification-head">
              <strong><%= t('nav.notifications') %></strong>
              <form method="POST" action="/notifications/read-all">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="whale-inline-link"><%= t('notifications.mark_all') %></button>
              </form>
            </div>
            <div class="whale-notification-list">
              <% if (navNotifications && navNotifications.length) { %>
                <% navNotifications.slice(0, 6).forEach(function (item) { %>
                  <a href="/notifications" class="whale-notification-item <%= item.isRead ? '' : 'is-unread' %>">
                    <span class="whale-notification-icon"><%= iconForNotification(item) %></span>
                    <span class="whale-notification-copy">
                      <strong><%= item.type === 'SYSTEM' ? t('notifications.system') : t('nav.notifications') %></strong>
                      <span dir="auto"><%= item.message %></span>
                    </span>
                    <span class="whale-notification-meta">
                      <small><%= timeAgo(item.createdAt) %></small>
                      <% if (!item.isRead) { %><i class="whale-unread-dot" aria-hidden="true"></i><% } %>
                    </span>
                  </a>
                <% }); %>
              <% } else { %>
                <div class="whale-notification-empty">
                  <div class="whale-notification-empty-icon" aria-hidden="true">🐳</div>
                  <strong><%= t('notifications.empty_title') %></strong>
                  <span><%= t('notifications.empty_desc') %></span>
                </div>
              <% } %>
            </div>
            <a href="/notifications" class="whale-notification-footer"><%= t('notifications.see_all') %></a>
          </div>
        </div>
        <a href="/whale/cart" class="nav-icon-btn" aria-label="<%= t('cart.title') %>">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <% if (cartCount > 0) { %><span class="notif-badge"><%= cartCount > 9 ? '9+' : cartCount %></span><% } %>
        </a>

        <div class="nav-av-wrap">
          <button class="nav-avatar" onclick="toggleMenu(event)" aria-haspopup="true" aria-expanded="false" aria-label="<%= navUser.username %>">
            <% if (navUser.avatar) { %>
              <img src="<%= navUser.avatar %>" alt="<%= navUser.username %>">
            <% } else { %>
              <%= String(navUser.username || '?').charAt(0).toUpperCase() %>
            <% } %>
          </button>

          <div class="av-menu" id="av-menu" role="menu">
            <div class="av-menu-header">
              <div class="av-name"><%= navUser.username %></div>
              <div class="av-email"><%= navUser.email %></div>
              <% if (isPro) { %>
                <span class="badge badge-teal" style="margin-top:6px;font-size:10px">⚡ Pro</span>
              <% } else { %>
                <a href="/upgrade" class="av-upgrade"><%= t('nav.upgrade') %> →</a>
              <% } %>
            </div>
            <a href="/u/<%= navUser.username %>" class="av-link" role="menuitem">👤 <%= t('nav.profile') %></a>
            <a href="/whale/my-listings" class="av-link" role="menuitem">📦 <%= t('nav.my_listings') %></a>
            <a href="/whale/orders" class="av-link" role="menuitem">🛒 <%= t('nav.my_orders') %></a>
            <a href="/whale/saved" class="av-link" role="menuitem">♡ <%= t('nav.saved') %></a>
            <a href="/whale/dashboard" class="av-link" role="menuitem">📊 <%= t('nav.dashboard') %></a>
            <div class="av-divider" role="separator"></div>
            <form action="/auth/logout" method="POST" style="margin:0">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="av-link av-logout" role="menuitem"><%= t('nav.logout') %></button>
            </form>
          </div>
        </div>
      <% } else if (!navUser && !isAuthPage) { %>
        <a href="/auth/login" class="nav-btn-ghost"><%= t('nav.login') %></a>
        <a href="/auth/register" class="nav-btn-primary">🐳 <%= t('nav.register') %></a>
      <% } %>
    </div>
  </div>
</nav>

<% if (!isAuthPage) { %>
<nav class="mob-nav mobile-nav" aria-label="Mobile navigation">
  <a href="/" class="mob-link <%= path==='/' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
    <span><%= t('nav.home') %></span>
  </a>
  <a href="/whale" class="mob-link <%= path.startsWith('/whale') ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    <span><%= t('nav.marketplace') %></span>
  </a>
  <a href="/whale/sell" class="mob-link mob-sell-link">
    <span class="mob-sell-circle">+</span>
    <span><%= t('nav.sell_short') %></span>
  </a>
  <a href="/forum" class="mob-link <%= path.startsWith('/forum') ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <span><%= t('nav.forum') %></span>
  </a>
  <% if (navUser) { %>
    <a href="/u/<%= navUser.username %>" class="mob-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span><%= t('nav.profile') %></span>
      <% if (unread > 0) { %><span class="notif-badge mobile-badge"><%= unread > 9 ? '9+' : unread %></span><% } %>
    </a>
  <% } else { %>
    <a href="/auth/register" class="mob-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
      <span><%= t('ui.join') %></span>
    </a>
  <% } %>
</nav>
<% } %>

<script>
  function toggleMenu(e) {
    e.stopPropagation();
    var menu = document.getElementById('av-menu');
    if (!menu) return;
    var button = e.currentTarget;
    var open = menu.classList.toggle('open');
    button.setAttribute('aria-expanded', String(open));
  }

  document.addEventListener('click', function () {
    var menu = document.getElementById('av-menu');
    if (!menu) return;
    menu.classList.remove('open');
  });
</script>
