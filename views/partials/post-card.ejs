<article class="post-card">
  <div class="post-header">
    <% if (post.author) { %>
    <a href="/u/<%= post.author.username %>" class="post-author">
      <% if (post.author.avatar) { %><img src="<%= post.author.avatar %>" alt="" class="avatar-sm"><% } %>
      <span><%= post.author.username %></span>
    </a>
    <% } %>
    <span class="post-time"><%= timeAgo(post.createdAt) %></span>
  </div>
  <p class="post-content" dir="auto"><%= post.content %></p>
  <div class="post-stats">
    <span>❤️ <%= post.likesCount %></span>
    <span>💬 <%= post._count ? post._count.comments : post.commentsCount %></span>
  </div>
</article>
