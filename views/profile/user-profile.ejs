<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <div class="profile-header">
      <div class="profile-avatar">
        <%- include('../partials/avatar', { user: profile, size: 'lg' }) %>
      </div>
      <div class="profile-info">
        <h1><%= profile.username %></h1>
        <% if (profile.bio) { %><p class="profile-bio"><%= profile.bio %></p><% } %>
        <div class="profile-stats">
          <span><strong><%= profile._count ? profile._count.followers : 0 %></strong> <%= t('profile.followers') %></span>
          <span><strong><%= profile._count ? profile._count.following : 0 %></strong> <%= t('profile.following') %></span>
        </div>
        <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.id !== profile.id) { %>
        <form method="post" action="/u/<%= profile.username %>/follow" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn <%= typeof isFollowing !== 'undefined' && isFollowing ? 'btn-outline' : 'btn-primary' %>">
            <%= typeof isFollowing !== 'undefined' && isFollowing ? t('profile.unfollow') : t('profile.follow') %>
          </button>
        </form>
        <% } %>
        <p class="profile-joined"><%= t('profile.joined') %> <%= new Date(profile.createdAt).toLocaleDateString(lang === 'ar' ? 'ar-PS' : 'en-US', { year: 'numeric', month: 'long' }) %></p>
      </div>
    </div>

    <% if (typeof listings !== 'undefined' && listings.length) { %>
    <h2><%= t('profile.listings') %></h2>
    <div class="listings-grid">
      <% listings.forEach(listing => { %>
        <%- include('../partials/listing-card', { listing: listing }) %>
      <% }) %>
    </div>
    <% } %>

    <% if (typeof posts !== 'undefined' && posts.length) { %>
    <h2><%= t('profile.posts') %></h2>
    <div class="posts-list">
      <% posts.forEach(post => { %>
        <%- include('../partials/post-card', { post: post }) %>
      <% }) %>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
