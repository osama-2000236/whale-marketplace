<%- include('../partials/header') %>

<section class="page-section profile-page">
  <div class="container">
    <div class="profile-hero">
      <div class="profile-cover"></div>
      <div class="profile-main">
        <%- include('../partials/avatar', { user: profile, size: 'lg' }) %>
        <div>
          <h1><%= profile.username %></h1>
          <p><%= profile.bio || 'لا يوجد نبذة | No bio yet' %></p>
          <div class="profile-stats">
            <span><strong><%= profile._count.followers %></strong> Followers</span>
            <span><strong><%= profile._count.following %></strong> Following</span>
            <span><strong><%= profile._count.posts %></strong> Posts</span>
          </div>
        </div>

        <% if (currentUser && currentUser.username !== profile.username) { %>
          <form method="POST" action="/u/<%= profile.username %>/follow">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn <%= profile.isFollowing ? 'btn-outline' : 'btn-primary' %>"><%= profile.isFollowing ? 'إلغاء المتابعة | Unfollow' : 'متابعة | Follow' %></button>
          </form>
        <% } %>
      </div>
    </div>

    <div class="profile-layout">
      <aside class="profile-side panel-card">
        <h3>مواصفات الجهاز | PC Specs</h3>
        <% if (profile.pcSpecs) { %>
          <ul class="simple-list">
            <li>CPU: <%= profile.pcSpecs.cpu || '-' %></li>
            <li>GPU: <%= profile.pcSpecs.gpu || '-' %></li>
            <li>RAM: <%= profile.pcSpecs.ram || '-' %></li>
            <li>Storage: <%= profile.pcSpecs.storage || '-' %></li>
          </ul>
        <% } else { %>
          <p class="muted">لا توجد بيانات | No specs</p>
        <% } %>
      </aside>

      <main class="profile-content">
        <div class="profile-tabs">
          <a href="/u/<%= profile.username %>?tab=posts" class="<%= tab === 'posts' ? 'active' : '' %>">Posts</a>
          <a href="/u/<%= profile.username %>?tab=listings" class="<%= tab === 'listings' ? 'active' : '' %>">Listings</a>
          <a href="/u/<%= profile.username %>?tab=builds" class="<%= tab === 'builds' ? 'active' : '' %>">Builds (Future)</a>
        </div>

        <% if (tab === 'listings') { %>
          <div class="market-grid">
            <% if (profile.listings && profile.listings.length) { %>
              <% profile.listings.forEach((listing) => { %>
                <%- include('../partials/listing-card', { listing }) %>
              <% }) %>
            <% } else { %>
              <p class="muted">لا توجد إعلانات | No listings</p>
            <% } %>
          </div>
        <% } else if (tab === 'builds') { %>
          <div class="panel-card">
            <p>قسم التجميعات قيد التطوير | Builds tab is coming soon.</p>
          </div>
        <% } else { %>
          <% if (profile.posts && profile.posts.length) { %>
            <% profile.posts.forEach((post) => { %>
              <%- include('../partials/post-card', { post }) %>
            <% }) %>
          <% } else { %>
            <p class="muted">لا توجد منشورات | No posts</p>
          <% } %>
        <% } %>
      </main>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
