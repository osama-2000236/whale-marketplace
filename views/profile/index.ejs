<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container" style="max-width: 640px">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <h1><%= t('profile.title') %></h1>
    </div>

    <% if (!profile.isVerified) { %>
    <div class="card mb-2" style="border-color: #f59e0b">
      <div class="card-body">
        <p style="margin-bottom: 0.75rem">
          <%= locale === 'ar' ? 'يرجى تأكيد بريدك الإلكتروني لتفعيل كل الميزات.' : 'Please verify your email to unlock all account features.' %>
        </p>
        <form method="POST" action="/auth/resend-verification">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn-secondary">
            <%= locale === 'ar' ? 'إعادة إرسال رابط التفعيل' : 'Resend verification link' %>
          </button>
        </form>
      </div>
    </div>
    <% } %>

    <div class="card">
      <div class="card-body">
        <form
          method="POST"
          action="/profile?_csrf=<%= encodeURIComponent(csrfToken) %>"
          enctype="multipart/form-data"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="text-center mb-2">
            <div class="avatar avatar-xl" style="margin: 0 auto 1rem">
              <% if (profile.avatarUrl) { %>
              <img src="<%= profile.avatarUrl %>" alt="" />
              <% } else { %>
              <%= profile.username.charAt(0).toUpperCase() %>
              <% } %>
            </div>
            <div class="form-group">
              <label class="form-label"><%= t('profile.avatar') %></label>
              <input type="file" name="avatar" class="input" accept="image/*" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label"><%= t('profile.display_name') %></label>
            <input
              type="text"
              name="displayName"
              class="input"
              value="<%= profile.sellerProfile?.displayName || '' %>"
              maxlength="100"
            />
          </div>
          <div class="form-group">
            <label class="form-label"><%= t('profile.bio') %></label>
            <textarea name="bio" class="textarea" maxlength="500"><%= profile.bio || '' %></textarea>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label"><%= t('profile.city') %></label>
              <input
                type="text"
                name="city"
                class="input"
                value="<%= profile.sellerProfile?.city || '' %>"
                maxlength="100"
              />
            </div>
            <div class="form-group">
              <label class="form-label"><%= t('profile.whatsapp') %></label>
              <input
                type="tel"
                name="whatsapp"
                class="input"
                value="<%= profile.sellerProfile?.whatsapp || '' %>"
                placeholder="+970..."
              />
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg">
            <%= t('profile.save') %>
          </button>
        </form>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
