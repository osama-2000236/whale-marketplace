<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <h1><%= t('settings.title') %></h1>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success"><%= t('settings.saved') %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="settings-grid">
      <div class="settings-card">
        <h2><%= t('settings.profile') %></h2>
        <form method="post" action="/settings" enctype="multipart/form-data" class="whale-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="form-group">
            <label><%= t('settings.avatar') %></label>
            <div class="avatar-upload">
              <% if (currentUser.avatar) { %>
              <img src="<%= currentUser.avatar %>" alt="" class="avatar-lg">
              <% } else { %>
              <span class="avatar-lg avatar-initials"><%= currentUser.username.charAt(0).toUpperCase() %></span>
              <% } %>
              <input type="file" name="avatar" accept="image/*">
            </div>
          </div>

          <div class="form-group">
            <label><%= t('settings.username') %></label>
            <input type="text" value="<%= currentUser.username %>" disabled class="form-input">
            <small class="form-hint"><%= t('settings.username_hint') %></small>
          </div>

          <div class="form-group">
            <label><%= t('settings.email') %></label>
            <input type="email" value="<%= currentUser.email %>" disabled class="form-input">
          </div>

          <div class="form-group">
            <label><%= t('settings.bio') %></label>
            <textarea name="bio" rows="3" maxlength="500" class="form-input"><%= currentUser.bio || '' %></textarea>
          </div>

          <button type="submit" class="btn btn-primary"><%= t('settings.save') %></button>
        </form>
      </div>

      <div class="settings-card">
        <h2><%= t('settings.account') %></h2>
        <div class="settings-info">
          <div class="settings-row">
            <span class="settings-label"><%= t('settings.member_since') %></span>
            <span><%= new Date(currentUser.createdAt).toLocaleDateString(lang === 'ar' ? 'ar-PS' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
          </div>
          <div class="settings-row">
            <span class="settings-label"><%= t('settings.plan') %></span>
            <span><%= isPro ? 'Pro' : t('settings.free_plan') %></span>
            <% if (!isPro) { %><a href="/upgrade" class="btn btn-sm btn-primary"><%= t('settings.upgrade') %></a><% } %>
          </div>
        </div>
      </div>

      <div class="settings-card">
        <h2><%= t('settings.preferences') %></h2>
        <div class="settings-info">
          <div class="settings-row">
            <span class="settings-label"><%= t('settings.language') %></span>
            <form method="post" action="/prefs/lang" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="lang" value="<%= lang === 'ar' ? 'en' : 'ar' %>">
              <button type="submit" class="btn btn-sm btn-outline"><%= lang === 'ar' ? 'Switch to English' : 'التبديل إلى العربية' %></button>
            </form>
          </div>
          <div class="settings-row">
            <span class="settings-label"><%= t('settings.theme') %></span>
            <form method="post" action="/prefs/theme" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="theme" value="<%= theme === 'dark' ? 'light' : 'dark' %>">
              <button type="submit" class="btn btn-sm btn-outline"><%= theme === 'dark' ? t('settings.light_mode') : t('settings.dark_mode') %></button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
