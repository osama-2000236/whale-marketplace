<%- include('../partials/header') %>

<section class="page-section">
  <div class="container">
    <div class="section-header-inline" style="margin-bottom: 16px;">
      <div>
        <h1 class="page-title" style="margin-bottom:6px;"><%= category.nameAr || category.name %></h1>
        <p class="muted"><%= category.descriptionAr || category.description || '' %></p>
      </div>
      <% if (currentUser) { %>
        <a href="/forum/<%= category.slug %>/new" class="btn btn-primary">+ موضوع جديد | New Thread</a>
      <% } else { %>
        <a href="/auth/register" class="btn btn-secondary">سجل لتبدأ النقاش | Register to post</a>
      <% } %>
    </div>

    <div class="thread-list">
      <% if (!threads.length) { %>
        <div class="panel-card">لا توجد مواضيع بعد | No threads yet.</div>
      <% } %>
      <% threads.forEach((thread) => { %>
        <a href="/forum/<%= category.slug %>/<%= thread.slug %>" class="thread-row <%= thread.isPinned ? 'pinned' : '' %> <%= thread.isSolved ? 'solved' : '' %>">
          <div class="thread-title" dir="auto"><%= thread.title %></div>
          <% if (thread.isPinned) { %><span class="pinned-badge">مثبّت | PINNED</span><% } %>
          <% if (thread.isSolved) { %><span class="solved-badge">محلول | SOLVED</span><% } %>
          <div class="thread-meta">
            <span><%= thread._count.replies %> رد | replies</span>
            <span> • </span>
            <span><%= thread.author.username %></span>
          </div>
        </a>
      <% }) %>
    </div>

    <% if (hasMore && nextCursor) { %>
      <div class="load-more-row" style="margin-top: 14px;">
        <a href="/forum/<%= category.slug %>?cursor=<%= nextCursor %>" class="btn btn-secondary">Load more | تحميل المزيد</a>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
