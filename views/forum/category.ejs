<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <div class="page-header">
      <div>
        <a href="/forum" class="breadcrumb-link"><%= t('forum.title') %></a>
        <h1><%= lang === 'ar' && category.nameAr ? category.nameAr : category.name %></h1>
        <% if (category.description) { %><p><%= lang === 'ar' && category.descriptionAr ? category.descriptionAr : category.description %></p><% } %>
      </div>
      <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <a href="/forum/new?category=<%= category.slug %>" class="btn btn-primary"><%= t('forum.new_thread') %></a>
      <% } %>
    </div>

    <% if (typeof threads !== 'undefined' && threads.length) { %>
    <div class="forum-thread-list">
      <% threads.forEach(thread => { %>
      <a href="/forum/t/<%= thread.slug %>" class="forum-thread-card">
        <div class="thread-info">
          <h3><%= thread.title %><% if (thread.pinned) { %> <span class="pin-badge"><%= t('forum.pinned') %></span><% } %><% if (thread.solved) { %> <span class="solved-badge"><%= t('forum.solved') %></span><% } %></h3>
          <p class="thread-meta">
            <span><%= thread.author ? thread.author.username : '' %></span>
            <span><%= timeAgo(thread.createdAt) %></span>
            <span><%= thread.replyCount || 0 %> <%= t('forum.replies') %></span>
          </p>
        </div>
      </a>
      <% }) %>
    </div>
    <% if (typeof nextCursor !== 'undefined' && nextCursor) { %>
    <div class="load-more">
      <a href="/forum/c/<%= category.slug %>?cursor=<%= nextCursor %>" class="btn btn-outline"><%= t('forum.load_more') %></a>
    </div>
    <% } %>
    <% } else { %>
    <div class="empty-state">
      <h3><%= t('forum.no_threads') %></h3>
      <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <a href="/forum/new?category=<%= category.slug %>" class="btn btn-primary"><%= t('forum.start_thread') %></a>
      <% } %>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
