<%- include('../partials/header') %>

<section class="page-section">
  <div class="container">
    <div class="section-header-inline" style="margin-bottom: 20px;">
      <h1 class="page-title">فوروم التجميع | PC BUILD FORUM</h1>
      <a href="/welcome" class="btn btn-secondary">Join Community | انضم للمجتمع</a>
    </div>

    <div class="forum-categories">
      <% categories.forEach((cat) => { %>
        <a href="/forum/<%= cat.slug %>" class="category-card">
          <div class="cat-icon"><%= cat.icon || '💬' %></div>
          <div class="cat-name"><%= cat.name %></div>
          <div class="cat-name-ar"><%= cat.nameAr || '' %></div>
          <div class="cat-desc" dir="auto"><%= cat.descriptionAr || cat.description || '' %></div>
          <div class="cat-stats"><%= cat._count.threads %> موضوع | threads</div>
          <% if (cat.threads && cat.threads.length) { %>
            <div class="cat-stats">آخر مشاركة | Latest: <%= cat.threads[0].author.username %></div>
          <% } %>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
