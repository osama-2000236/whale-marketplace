<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <div class="page-header">
      <h1><%= t('forum.title') %></h1>
      <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <a href="/forum/new" class="btn btn-primary"><%= t('forum.new_thread') %></a>
      <% } %>
    </div>

    <% if (typeof categories !== 'undefined' && categories.length) { %>
    <div class="forum-categories">
      <% categories.forEach(cat => { %>
      <a href="/forum/c/<%= cat.slug %>" class="forum-category-card">
        <div class="forum-cat-icon"><%= cat.icon || '' %></div>
        <div class="forum-cat-info">
          <h3><%= lang === 'ar' && cat.nameAr ? cat.nameAr : cat.name %></h3>
          <% if (cat.description) { %><p><%= lang === 'ar' && cat.descriptionAr ? cat.descriptionAr : cat.description %></p><% } %>
        </div>
        <div class="forum-cat-count"><%= cat._count ? cat._count.threads : 0 %> <%= t('forum.threads') %></div>
      </a>
      <% }) %>
    </div>
    <% } %>

    <% if (typeof recentThreads !== 'undefined' && recentThreads.length) { %>
    <h2><%= t('forum.recent') %></h2>
    <div class="forum-thread-list">
      <% recentThreads.forEach(thread => { %>
      <a href="/forum/t/<%= thread.slug %>" class="forum-thread-card">
        <div class="thread-info">
          <h3><%= thread.title %><% if (thread.pinned) { %> <span class="pin-badge"><%= t('forum.pinned') %></span><% } %><% if (thread.solved) { %> <span class="solved-badge"><%= t('forum.solved') %></span><% } %></h3>
          <p class="thread-meta">
            <span><%= thread.author ? thread.author.username : '' %></span>
            <span><%= timeAgo(thread.createdAt) %></span>
            <span><%= thread.replyCount || 0 %> <%= t('forum.replies') %></span>
          </p>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
