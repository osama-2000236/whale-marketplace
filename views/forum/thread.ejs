<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <div class="forum-breadcrumb">
      <a href="/forum"><%= t('forum.title') %></a> &rsaquo;
      <% if (thread.category) { %><a href="/forum/c/<%= thread.category.slug %>"><%= lang === 'ar' && thread.category.nameAr ? thread.category.nameAr : thread.category.name %></a> &rsaquo;<% } %>
    </div>

    <div class="thread-header">
      <h1><%= thread.title %></h1>
      <% if (thread.pinned) { %><span class="pin-badge"><%= t('forum.pinned') %></span><% } %>
      <% if (thread.solved) { %><span class="solved-badge"><%= t('forum.solved') %></span><% } %>
      <div class="thread-meta">
        <%- include('../partials/avatar', { user: thread.author, size: 'sm' }) %>
        <a href="/u/<%= thread.author.username %>"><%= thread.author.username %></a>
        <span><%= timeAgo(thread.createdAt) %></span>
      </div>
    </div>

    <div class="thread-body">
      <%- thread.bodyHtml || thread.body %>
    </div>

    <% if (typeof replies !== 'undefined' && replies.length) { %>
    <div class="replies-section">
      <h2><%= replies.length %> <%= t('forum.replies') %></h2>
      <% replies.forEach(reply => { %>
      <div class="reply-card" id="reply-<%= reply.id %>">
        <div class="reply-header">
          <%- include('../partials/avatar', { user: reply.author, size: 'sm' }) %>
          <a href="/u/<%= reply.author.username %>"><%= reply.author.username %></a>
          <span class="reply-time"><%= timeAgo(reply.createdAt) %></span>
          <% if (reply.accepted) { %><span class="accepted-badge"><%= t('forum.accepted_answer') %></span><% } %>
        </div>
        <div class="reply-body"><%- reply.bodyHtml || reply.body %></div>
        <div class="reply-actions">
          <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <button class="btn btn-sm btn-outline like-btn" data-reply-id="<%= reply.id %>" data-liked="<%= reply.likedBy && reply.likedBy.includes(currentUser.id) ? 'true' : 'false' %>">
            <span class="like-count"><%= reply.likedBy ? reply.likedBy.length : 0 %></span> <%= t('forum.like') %>
          </button>
          <% if (thread.authorId === currentUser.id && !reply.accepted) { %>
          <button class="btn btn-sm btn-outline accept-btn" data-reply-id="<%= reply.id %>"><%= t('forum.accept_answer') %></button>
          <% } %>
          <% } %>
        </div>

        <% if (reply.children && reply.children.length) { %>
        <div class="nested-replies">
          <% reply.children.forEach(child => { %>
          <div class="reply-card nested" id="reply-<%= child.id %>">
            <div class="reply-header">
              <%- include('../partials/avatar', { user: child.author, size: 'xs' }) %>
              <a href="/u/<%= child.author.username %>"><%= child.author.username %></a>
              <span class="reply-time"><%= timeAgo(child.createdAt) %></span>
            </div>
            <div class="reply-body"><%- child.bodyHtml || child.body %></div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>
    <% } %>

    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <div class="reply-form-section">
      <h3><%= t('forum.post_reply') %></h3>
      <form method="post" action="/forum/t/<%= thread.slug %>/reply" class="whale-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <textarea name="body" rows="4" required placeholder="<%= t('forum.reply_placeholder') %>"></textarea>
        </div>
        <button type="submit" class="btn btn-primary"><%= t('forum.post_reply') %></button>
      </form>
    </div>
    <% } else { %>
    <p class="auth-prompt"><a href="/auth/login"><%= t('auth.login') %></a> <%= t('forum.to_reply') %></p>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
<script>
document.querySelectorAll('.like-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var id = this.dataset.replyId;
    fetch('/forum/reply/' + id + '/like', { method: 'POST', headers: { 'X-CSRF-Token': '<%= csrfToken %>', 'Content-Type': 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(d) { btn.querySelector('.like-count').textContent = d.likes || 0; });
  });
});
document.querySelectorAll('.accept-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var id = this.dataset.replyId;
    fetch('/forum/reply/' + id + '/accept', { method: 'POST', headers: { 'X-CSRF-Token': '<%= csrfToken %>', 'Content-Type': 'application/json' } })
      .then(function() { location.reload(); });
  });
});
</script>
</body>
</html>
