<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="form-page">
    <h1><%= t('forum.new_thread') %></h1>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form method="post" action="/forum/new" class="whale-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label><%= t('forum.category') %></label>
        <select name="categoryId" required>
          <option value="">— <%= t('forum.select_category') %> —</option>
          <% if (typeof categories !== 'undefined') { categories.forEach(cat => { %>
          <option value="<%= cat.id %>" <%= (typeof selectedCategory !== 'undefined' && selectedCategory === cat.slug) ? 'selected' : '' %>><%= lang === 'ar' && cat.nameAr ? cat.nameAr : cat.name %></option>
          <% }) } %>
        </select>
      </div>
      <div class="form-group">
        <label><%= t('forum.thread_title') %></label>
        <input type="text" name="title" required maxlength="200">
      </div>
      <div class="form-group">
        <label><%= t('forum.body') %></label>
        <textarea name="body" rows="8" required placeholder="<%= t('forum.body_placeholder') %>"></textarea>
        <small class="form-hint"><%= t('forum.markdown_supported') %></small>
      </div>
      <div class="form-group">
        <label><%= t('forum.tags') %> (<%= t('auth.optional') %>)</label>
        <input type="text" name="tags" placeholder="<%= t('forum.tags_hint') %>">
      </div>
      <button type="submit" class="btn btn-primary btn-lg"><%= t('forum.create_thread') %></button>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
