<%- include('../partials/header') %>

<section class="page-section">
  <div class="container" style="max-width: 900px;">
    <h1 class="page-title">موضوع جديد | New Thread</h1>
    <div class="panel-card">
      <h3><%= category.nameAr || category.name %></h3>

      <form method="POST" action="/forum/<%= category.slug %>/new" class="auth-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group">
          <label>العنوان | Title</label>
          <input type="text" name="title" minlength="5" required placeholder="RTX 4060 ولا RTX 4060 Ti؟">
        </div>

        <div class="form-group">
          <label>المحتوى (يدعم Markdown) | Body (Markdown supported)</label>
          <textarea name="body" rows="8" minlength="10" required placeholder="اكتب التفاصيل الكاملة هنا..."></textarea>
        </div>

        <div class="form-group">
          <label>الوسوم | Tags (comma separated)</label>
          <input type="text" name="tags" placeholder="gpu, build, budget">
        </div>

        <button type="submit" class="btn btn-primary">نشر الموضوع | Publish Thread</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
