<%- include('partials/header') %>

<section class="section page-section">
  <div class="container">
    <div class="section-header">
      <h2><%= activeCategory ? categories.find(c => c.id === activeCategory)?.nameAr : 'جميع المنتجات' %></h2>
      <div class="section-line"></div>
    </div>

    <!-- Filters Bar -->
    <div class="filters-bar">
      <div class="filter-categories">
        <a href="/products" class="filter-tag <%= !activeCategory ? 'active' : '' %>">الكل</a>
        <% categories.forEach(cat => { %>
        <a href="/products?category=<%= cat.id %>" class="filter-tag <%= activeCategory === cat.id ? 'active' : '' %>">
          <%= cat.icon %> <%= cat.nameAr %>
        </a>
        <% }) %>
      </div>
      <form class="search-form" action="/products" method="GET">
        <% if (activeCategory) { %><input type="hidden" name="category" value="<%= activeCategory %>"><% } %>
        <input type="text" name="search" placeholder="ابحث عن منتج..." value="<%= searchQuery %>" class="search-input">
        <button type="submit" class="btn btn-primary btn-sm">🔍</button>
      </form>
    </div>

    <!-- Products Grid -->
    <% if (products.length > 0) { %>
    <div class="products-grid">
      <% products.forEach(product => { %>
        <%- include('partials/product-card', { product }) %>
      <% }) %>
    </div>

    <!-- Pagination -->
    <% if (pagination.totalPages > 1) { %>
    <div class="pagination">
      <% if (pagination.hasPrev) { %>
      <a href="/products?page=<%= pagination.page - 1 %><%= activeCategory ? '&category=' + activeCategory : '' %>" class="btn btn-outline btn-sm">→ السابق</a>
      <% } %>
      <span class="pagination-info">صفحة <%= pagination.page %> من <%= pagination.totalPages %></span>
      <% if (pagination.hasNext) { %>
      <a href="/products?page=<%= pagination.page + 1 %><%= activeCategory ? '&category=' + activeCategory : '' %>" class="btn btn-outline btn-sm">التالي ←</a>
      <% } %>
    </div>
    <% } %>

    <% } else { %>
    <div class="empty-state">
      <span class="empty-icon">📦</span>
      <h3>لا توجد منتجات</h3>
      <p>لم يتم العثور على منتجات في هذا القسم حالياً</p>
      <a href="/products" class="btn btn-outline">عرض جميع المنتجات</a>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
