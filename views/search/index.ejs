<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <h1><%= t('search.results') %></h1>

    <form method="get" action="/search" class="search-form-page whale-form">
      <div class="search-bar">
        <input type="text" name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" placeholder="<%= t('search.placeholder') %>" autofocus>
        <select name="type">
          <option value="all" <%= typeof type === 'undefined' || type === 'all' ? 'selected' : '' %>><%= t('search.all') %></option>
          <option value="listings" <%= type === 'listings' ? 'selected' : '' %>><%= t('search.listings') %></option>
          <option value="threads" <%= type === 'threads' ? 'selected' : '' %>><%= t('search.threads') %></option>
          <option value="users" <%= type === 'users' ? 'selected' : '' %>><%= t('search.users') %></option>
        </select>
        <button type="submit" class="btn btn-primary"><%= t('search.search') %></button>
      </div>
    </form>

    <% if (typeof results !== 'undefined') { %>
      <% if (results.listings && results.listings.length) { %>
      <h2><%= t('search.listings') %> (<%= results.listings.length %>)</h2>
      <div class="listings-grid">
        <% results.listings.forEach(listing => { %>
          <%- include('../partials/listing-card', { listing: listing }) %>
        <% }) %>
      </div>
      <% } %>

      <% if (results.threads && results.threads.length) { %>
      <h2><%= t('search.threads') %> (<%= results.threads.length %>)</h2>
      <div class="forum-thread-list">
        <% results.threads.forEach(thread => { %>
        <a href="/forum/t/<%= thread.slug %>" class="forum-thread-card">
          <div class="thread-info">
            <h3><%= thread.title %></h3>
            <p class="thread-meta"><%= thread.author ? thread.author.username : '' %> &middot; <%= timeAgo(thread.createdAt) %></p>
          </div>
        </a>
        <% }) %>
      </div>
      <% } %>

      <% if (results.users && results.users.length) { %>
      <h2><%= t('search.users') %> (<%= results.users.length %>)</h2>
      <div class="users-grid">
        <% results.users.forEach(user => { %>
        <a href="/u/<%= user.username %>" class="user-card">
          <%- include('../partials/avatar', { user: user, size: 'md' }) %>
          <span><%= user.username %></span>
        </a>
        <% }) %>
      </div>
      <% } %>

      <% if ((!results.listings || !results.listings.length) && (!results.threads || !results.threads.length) && (!results.users || !results.users.length)) { %>
      <div class="empty-state">
        <h3><%= t('search.no_results') %></h3>
      </div>
      <% } %>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
