<%- include('../partials/header') %>

<section class="page-section notifications-page">
  <div class="container">
    <div class="section-header section-header-inline">
      <h1><%= t('nav.notifications') %></h1>
      <form method="POST" action="/notifications/read-all">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn btn-outline" type="submit"><%= t('notifications.mark_all') %></button>
      </form>
    </div>

    <div class="notifications-list panel-card">
      <% if (notifications && notifications.length) { %>
        <% notifications.forEach((item) => { %>
          <%- include('../partials/notification-item', { item }) %>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          <h3><%= t('notifications.empty_title') %></h3>
          <p class="muted"><%= t('notifications.empty_desc') %></p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
