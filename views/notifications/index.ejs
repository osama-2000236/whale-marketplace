<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <div class="page-header">
      <h1><%= t('notifications.title') %></h1>
      <% if (typeof notifications !== 'undefined' && notifications.length) { %>
      <form method="post" action="/notifications/mark-all-read" class="inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-outline"><%= t('notifications.mark_all_read') %></button>
      </form>
      <% } %>
    </div>

    <% if (typeof notifications !== 'undefined' && notifications.length) { %>
    <div class="notifications-list">
      <% notifications.forEach(n => { %>
      <%- include('../partials/notification-item', { notification: n }) %>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <h3><%= t('notifications.empty') %></h3>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
