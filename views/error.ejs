<%- include('partials/header') %>
<section class="page-section whale-page whale-error-page">
  <div class="container whale-error-container">
    <div class="panel-card whale-error-card">
      <div class="whale-error-icon" aria-hidden="true">⚠️</div>
      <h1 class="whale-error-heading">حدث خطأ | Something went wrong</h1>
