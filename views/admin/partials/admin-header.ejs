<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('admin.title') %> - <%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body <%= bodyClass %>">
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-brand"><a href="/admin"><%= t('admin.panel') %></a></div>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-item"><%= t('admin.dashboard') %></a>
      <a href="/admin/products" class="admin-nav-item"><%= t('admin.products') %></a>
      <a href="/admin/listings" class="admin-nav-item"><%= t('admin.listings') %></a>
      <a href="/admin/whale" class="admin-nav-item"><%= t('admin.whale') %></a>
      <a href="/admin/subscriptions" class="admin-nav-item"><%= t('admin.subscriptions') %></a>
      <a href="/admin/qr" class="admin-nav-item"><%= t('admin.qr_codes') %></a>
      <a href="/admin/settings" class="admin-nav-item"><%= t('admin.settings') %></a>
    </nav>
    <div class="admin-sidebar-footer">
      <form method="post" action="/admin/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-sm btn-outline"><%= t('admin.logout') %></button>
      </form>
    </div>
  </aside>
  <main class="admin-main">
