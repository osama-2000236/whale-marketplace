<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken || '' %>">
  <title><%= title %> - Whale Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <nav class="admin-nav">
    <a href="/admin/whale" class="admin-logo">Whale <span>Admin</span> <small>الحوت</small></a>
    <div class="admin-nav-links">
      <a href="/admin/whale" class="<%= currentPath.includes('/admin/whale') || currentPath.includes('/admin/market') ? 'active' : '' %>">🐳 Whale</a>
      <a href="/admin/qr" class="<%= currentPath.includes('/admin/qr') ? 'active' : '' %>">🔳 QR</a>
      <a href="/admin/subscriptions" class="<%= currentPath.includes('/admin/subscriptions') ? 'active' : '' %>">💳 Subs</a>
      <a href="/admin/settings" class="<%= currentPath.includes('/admin/settings') ? 'active' : '' %>">⚙️ Settings</a>
      <a href="/whale" target="_blank">🌐 View Site</a>
      <a href="/admin/logout" class="logout-btn">🚪 Logout</a>
    </div>
  </nav>
  <main class="admin-main">
