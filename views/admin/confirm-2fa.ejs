<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container" style="max-width: 600px; margin: 2rem auto;">
    <h1>Two-Factor Authentication Setup</h1>
    <div class="card" style="padding: 1.5rem; margin-top: 1rem;">
      <p><strong>Important:</strong> This secret will only be shown once. Save it in your authenticator app now.</p>

      <div style="margin: 1.5rem 0; padding: 1rem; background: var(--bg-secondary, #f5f5f5); border-radius: 8px; word-break: break-all; font-family: monospace; font-size: 1.1rem;">
        <%= secret %>
      </div>

      <p style="margin-top: 1rem;">
        Or scan this URL in your authenticator app:
      </p>
      <div style="margin: 0.5rem 0; padding: 0.75rem; background: var(--bg-secondary, #f5f5f5); border-radius: 8px; word-break: break-all; font-size: 0.85rem;">
        <%= otpauthUrl || 'N/A' %>
      </div>

      <a href="/admin" class="btn btn-primary" style="margin-top: 1.5rem; display: inline-block;">
        I've saved my secret &rarr; Back to Admin
      </a>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
