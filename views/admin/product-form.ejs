<%- include('partials/admin-header') %>
<div class="admin-page">
  <h1><%= typeof product !== 'undefined' && product ? t('admin.edit_product') : t('admin.add_product') %></h1>

  <form method="post" action="<%= typeof product !== 'undefined' && product ? '/admin/products/' + product.id + '/edit' : '/admin/products' %>" enctype="multipart/form-data" class="whale-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-row">
      <div class="form-group">
        <label><%= t('admin.name') %></label>
        <input type="text" name="name" value="<%= typeof product !== 'undefined' && product ? product.name : '' %>" required>
      </div>
      <div class="form-group">
        <label><%= t('admin.name_ar') %></label>
        <input type="text" name="nameAr" value="<%= typeof product !== 'undefined' && product ? (product.nameAr || '') : '' %>" dir="rtl">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label><%= t('admin.description') %></label>
        <textarea name="description" rows="3"><%= typeof product !== 'undefined' && product ? product.description : '' %></textarea>
      </div>
      <div class="form-group">
        <label><%= t('admin.description_ar') %></label>
        <textarea name="descriptionAr" rows="3" dir="rtl"><%= typeof product !== 'undefined' && product ? (product.descriptionAr || '') : '' %></textarea>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label><%= t('admin.category') %></label>
        <input type="text" name="category" value="<%= typeof product !== 'undefined' && product ? (product.category || '') : '' %>">
      </div>
      <div class="form-group">
        <label><%= t('admin.price') %> (&#8362;)</label>
        <input type="number" name="price" value="<%= typeof product !== 'undefined' && product ? product.price : '' %>" min="0" step="0.01" required>
      </div>
    </div>

    <div class="form-group">
      <label><%= t('admin.image') %></label>
      <input type="file" name="image" accept="image/*">
      <% if (typeof product !== 'undefined' && product && product.image) { %>
      <img src="<%= product.image %>" alt="" class="thumb-sm" style="margin-top:8px;">
      <% } %>
    </div>

    <div class="form-group checkbox-group">
      <label><input type="checkbox" name="featured" <%= typeof product !== 'undefined' && product && product.featured ? 'checked' : '' %>> <%= t('admin.featured') %></label>
    </div>
    <div class="form-group checkbox-group">
      <label><input type="checkbox" name="isActive" <%= (typeof product === 'undefined' || !product || product.isActive) ? 'checked' : '' %>> <%= t('admin.active') %></label>
    </div>

    <button type="submit" class="btn btn-primary btn-lg"><%= typeof product !== 'undefined' && product ? t('admin.save_changes') : t('admin.create') %></button>
  </form>
</div>
<%- include('partials/admin-footer') %>
