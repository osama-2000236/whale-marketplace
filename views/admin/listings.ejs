<%- include('partials/admin-header') %>

<div class="admin-header-bar">
  <h1>🛒 Marketplace Moderation</h1>
</div>

<div class="admin-table-wrapper">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Image</th>
        <th>Listing</th>
        <th>Seller</th>
        <th>Price</th>
        <th>Status</th>
        <th>Created</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (listings && listings.length) { %>
        <% listings.forEach((listing) => { %>
          <tr>
            <td><img src="<%= listing.images && listing.images[0] ? listing.images[0] : '/images/products/placeholder.svg' %>" width="50" height="50" style="border-radius:6px;object-fit:cover"></td>
            <td><a href="/marketplace/<%= listing.id %>" target="_blank"><%= listing.titleAr || listing.title %></a><br><small><%= listing.category %> - <%= listing.location %></small></td>
            <td><%= listing.seller.username %></td>
            <td>₪ <%= Number(listing.price).toLocaleString() %></td>
            <td><%= listing.status %></td>
            <td><%= new Date(listing.createdAt).toLocaleDateString('ar-PS') %></td>
            <td>
              <% if (listing.status !== 'REMOVED') { %>
                <form method="POST" action="/admin/listings/<%= listing.id %>/remove" onsubmit="return confirm('Remove this listing?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                </form>
              <% } else { %>
                <span style="color:#888">Removed</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="7">No listings found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('partials/admin-footer') %>
