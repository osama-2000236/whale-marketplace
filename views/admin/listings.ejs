<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><%= t('admin.listings') %></h1>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= locale === 'ar' ? 'المنتج' : 'Listing' %></th>
            <th><%= locale === 'ar' ? 'البائع' : 'Seller' %></th>
            <th><%= locale === 'ar' ? 'السعر' : 'Price' %></th>
            <th><%= t('order.status') %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% listings.forEach(l => { %>
          <tr>
            <td><a href="/whale/listing/<%= l.slug %>"><%= l.title %></a></td>
            <td><%= l.seller?.username %></td>
            <td>
              $
              <%= parseFloat(l.price).toLocaleString() %>
            </td>
            <td>
              <span
                class="badge badge-<%= l.status === 'ACTIVE' ? 'success' : l.status === 'REMOVED' ? 'danger' : 'neutral' %>"
              >
                <%= l.status %>
              </span>
            </td>
            <td>
              <% if (l.status !== 'REMOVED') { %>
              <form
                method="POST"
                action="/admin/listings/<%= l.id %>/remove"
                style="display: inline"
                data-confirm="Remove this listing?"
              >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-danger btn-sm">
                  <%= t('admin.remove') %>
                </button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
