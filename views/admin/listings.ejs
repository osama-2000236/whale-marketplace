<%- include('partials/admin-header') %>
<div class="admin-page">
  <h1><%= t('admin.listings') %></h1>

  <% if (typeof listings !== 'undefined' && listings.length) { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('admin.image') %></th>
        <th><%= t('admin.title') %></th>
        <th><%= t('admin.seller') %></th>
        <th><%= t('admin.price') %></th>
        <th><%= t('admin.status') %></th>
        <th><%= t('admin.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% listings.forEach(listing => { %>
      <tr>
        <td><img src="<%= listing.images && listing.images[0] ? listing.images[0] : '/images/placeholder.png' %>" alt="" class="thumb-sm"></td>
        <td><a href="/whale/listing/<%= listing.slug || listing.id %>"><%= listing.title %></a></td>
        <td><%= listing.seller ? listing.seller.username : '—' %></td>
        <td>&#8362;<%= listing.price %></td>
        <td><span class="status-badge status-<%= {active:'success',sold:'warning',suspended:'danger',draft:'neutral'}[listing.status] || 'neutral' %>"><%= listing.status %></span></td>
        <td>
          <% if (listing.status === 'active') { %>
          <form method="post" action="/admin/whale/listings/<%= listing.id %>/suspend" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline btn-danger"><%= t('admin.suspend') %></button>
          </form>
          <% } else if (listing.status === 'suspended') { %>
          <form method="post" action="/admin/whale/listings/<%= listing.id %>/unsuspend" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline"><%= t('admin.unsuspend') %></button>
          </form>
          <% } %>
          <form method="post" action="/admin/whale/listings/<%= listing.id %>/delete" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline btn-danger" onclick="return confirm('Delete?')"><%= t('admin.delete') %></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
  <div class="empty-state"><h3><%= t('admin.no_listings') %></h3></div>
  <% } %>
</div>
<%- include('partials/admin-footer') %>
