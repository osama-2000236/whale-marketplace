<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('admin.login') %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body <%= bodyClass %>">
<div class="admin-login-page">
  <div class="auth-card">
    <h1><%= t('admin.login') %></h1>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <form method="post" action="/admin/login" class="whale-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label><%= t('auth.email_or_username') %></label>
        <input type="text" name="identifier" required autofocus>
      </div>
      <div class="form-group">
        <label><%= t('auth.password') %></label>
        <input type="password" name="password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-lg btn-block"><%= t('admin.login') %></button>
    </form>
  </div>
</div>
</body>
</html>
