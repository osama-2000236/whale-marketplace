<%- include('partials/admin-header') %>
<div class="admin-page">
  <h1><%= t('admin.settings') %></h1>

  <form method="post" action="/admin/settings" class="whale-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="admin-card">
      <h2><%= t('admin.site_config') %></h2>
      <div class="form-group">
        <label><%= t('admin.site_name') %></label>
        <input type="text" name="siteName" value="<%= config.siteName || '' %>">
      </div>
      <div class="form-group">
        <label><%= t('admin.site_description') %></label>
        <textarea name="siteDescription" rows="2"><%= config.siteDescription || '' %></textarea>
      </div>
      <div class="form-group">
        <label><%= t('admin.contact_email') %></label>
        <input type="email" name="contactEmail" value="<%= config.contactEmail || '' %>">
      </div>
      <div class="form-group">
        <label><%= t('admin.whatsapp') %></label>
        <input type="text" name="whatsapp" value="<%= config.whatsapp || '' %>">
      </div>
    </div>

    <div class="admin-card">
      <h2><%= t('admin.social_links') %></h2>
      <div class="form-group">
        <label>Facebook</label>
        <input type="url" name="facebook" value="<%= config.facebook || '' %>">
      </div>
      <div class="form-group">
        <label>Instagram</label>
        <input type="url" name="instagram" value="<%= config.instagram || '' %>">
      </div>
      <div class="form-group">
        <label>Telegram</label>
        <input type="url" name="telegram" value="<%= config.telegram || '' %>">
      </div>
    </div>

    <button type="submit" class="btn btn-primary btn-lg"><%= t('admin.save_settings') %></button>
  </form>
</div>
<%- include('partials/admin-footer') %>
