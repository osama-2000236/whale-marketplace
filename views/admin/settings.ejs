<%- include('partials/admin-header') %>

<div class="admin-header-bar"><h1>⚙️ Site Settings</h1></div>

<% if (success) { %><div class="alert alert-success">✅ Settings saved successfully!</div><% } %>

<form method="POST" action="/admin/settings" class="settings-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="admin-card">
    <h3>Business Info</h3>
    <div class="form-row">
      <div class="form-group"><label>Site Name</label><input type="text" name="siteName" value="<%= siteConfig.siteName %>"></div>
      <div class="form-group"><label>Tagline (Arabic)</label><input type="text" name="taglineAr" value="<%= siteConfig.taglineAr %>"></div>
    </div>
    <div class="form-group"><label>Description (Arabic)</label><textarea name="description" rows="3"><%= siteConfig.description %></textarea></div>
  </div>

  <div class="admin-card">
    <h3>Contact Info</h3>
    <div class="form-row">
      <div class="form-group"><label>Phone</label><input type="text" name="phone" value="<%= siteConfig.contact.phone %>"></div>
      <div class="form-group"><label>WhatsApp</label><input type="text" name="whatsapp" value="<%= siteConfig.contact.whatsapp %>"></div>
    </div>
    <div class="form-group"><label>Email</label><input type="email" name="email" value="<%= siteConfig.contact.email %>"></div>
  </div>

  <div class="admin-card">
    <h3>Social Media</h3>
    <div class="form-group"><label>Facebook URL</label><input type="url" name="facebook" value="<%= siteConfig.social.facebook %>"></div>
    <div class="form-group"><label>Instagram URL</label><input type="url" name="instagram" value="<%= siteConfig.social.instagram %>"></div>
  </div>

  <div class="admin-card">
    <h3>Location</h3>
    <div class="form-row">
      <div class="form-group"><label>City (Arabic)</label><input type="text" name="cityAr" value="<%= siteConfig.location.cityAr %>"></div>
      <div class="form-group"><label>Full Address</label><input type="text" name="fullAddress" value="<%= siteConfig.location.fullAddress %>"></div>
    </div>
  </div>

  <button type="submit" class="btn btn-primary btn-lg">💾 Save Settings</button>
</form>

<%- include('partials/admin-footer') %>
