<%- include('partials/admin-header') %>
<div class="admin-page">
  <div class="page-header">
    <h1><%= t('admin.products') %></h1>
    <a href="/admin/products/new" class="btn btn-primary"><%= t('admin.add_product') %></a>
  </div>

  <% if (typeof products !== 'undefined' && products.length) { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('admin.image') %></th>
        <th><%= t('admin.name') %></th>
        <th><%= t('admin.category') %></th>
        <th><%= t('admin.price') %></th>
        <th><%= t('admin.featured') %></th>
        <th><%= t('admin.active') %></th>
        <th><%= t('admin.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(product => { %>
      <tr>
        <td><img src="<%= product.image || '/images/placeholder.png' %>" alt="" class="thumb-sm"></td>
        <td><%= product.name %></td>
        <td><%= product.category || '—' %></td>
        <td>&#8362;<%= product.price %></td>
        <td>
          <form method="post" action="/admin/products/<%= product.id %>/toggle-featured" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm <%= product.featured ? 'btn-primary' : 'btn-outline' %>"><%= product.featured ? 'Yes' : 'No' %></button>
          </form>
        </td>
        <td>
          <form method="post" action="/admin/products/<%= product.id %>/toggle-active" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm <%= product.isActive ? 'btn-primary' : 'btn-outline' %>"><%= product.isActive ? 'Yes' : 'No' %></button>
          </form>
        </td>
        <td>
          <a href="/admin/products/<%= product.id %>/edit" class="btn btn-sm btn-outline"><%= t('admin.edit') %></a>
          <form method="post" action="/admin/products/<%= product.id %>/delete" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline btn-danger" onclick="return confirm('Delete?')"><%= t('admin.delete') %></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
  <div class="empty-state"><h3><%= t('admin.no_products') %></h3></div>
  <% } %>
</div>
<%- include('partials/admin-footer') %>
