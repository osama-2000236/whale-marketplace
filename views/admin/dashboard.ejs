<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><%= t('admin.dashboard') %></h1>
    </div>

    <div class="grid-stats mb-3">
      <div class="stat-card">
        <div class="stat-card-value"><%= stats.userCount %></div>
        <div class="stat-card-label"><%= t('admin.users') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value"><%= stats.listingCount %></div>
        <div class="stat-card-label"><%= t('admin.listings') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value"><%= stats.orderCount %></div>
        <div class="stat-card-label"><%= t('admin.orders') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-value">$<%= parseFloat(stats.revenue).toLocaleString() %></div>
        <div class="stat-card-label">
          <%= locale === 'ar' ? 'إجمالي الإيرادات' : 'Total Revenue' %>
        </div>
      </div>
    </div>

    <div class="flex gap-1 flex-wrap">
      <a href="/admin/users" class="btn btn-ghost"><%= t('admin.users') %></a>
      <a href="/admin/listings" class="btn btn-ghost"><%= t('admin.listings') %></a>
      <a href="/admin/orders" class="btn btn-ghost"><%= t('admin.orders') %></a>
      <a href="/admin/vendors" class="btn btn-ghost"><%= locale === 'ar' ? 'المتاجر' : 'Vendors' %></a>
      <a href="/admin/shipping" class="btn btn-ghost"><%= locale === 'ar' ? 'الشحن' : 'Shipping' %></a>
      <a href="/admin/banners" class="btn btn-ghost"><%= locale === 'ar' ? 'البانرات' : 'Banners' %></a>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
