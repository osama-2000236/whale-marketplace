<%- include('partials/admin-header') %>
<div class="admin-page">
  <h1><%= t('admin.dashboard') %></h1>
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-value"><%= stats.totalUsers || 0 %></div>
      <div class="stat-label"><%= t('admin.total_users') %></div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.totalListings || 0 %></div>
      <div class="stat-label"><%= t('admin.total_listings') %></div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.totalOrders || 0 %></div>
      <div class="stat-label"><%= t('admin.total_orders') %></div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.proUsers || 0 %></div>
      <div class="stat-label"><%= t('admin.pro_users') %></div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.totalProducts || 0 %></div>
      <div class="stat-label"><%= t('admin.total_products') %></div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.activeDisputes || 0 %></div>
      <div class="stat-label"><%= t('admin.active_disputes') %></div>
    </div>
  </div>

  <% if (typeof recentOrders !== 'undefined' && recentOrders.length) { %>
  <h2><%= t('admin.recent_orders') %></h2>
  <table class="admin-table">
    <thead>
      <tr>
        <th>#</th>
        <th><%= t('whale.buyer') %></th>
        <th><%= t('whale.seller') %></th>
        <th><%= t('whale.amount') %></th>
        <th><%= t('whale.status') %></th>
        <th><%= t('admin.date') %></th>
      </tr>
    </thead>
    <tbody>
      <% recentOrders.forEach(order => { %>
      <tr>
        <td><%= order.orderNumber %></td>
        <td><%= order.buyer ? order.buyer.username : '—' %></td>
        <td><%= order.seller ? order.seller.username : '—' %></td>
        <td>&#8362;<%= order.amount %></td>
        <td><span class="status-badge status-<%= {PENDING:'warning',COMPLETED:'success',CANCELLED:'danger',SHIPPED:'info'}[order.orderStatus] || 'neutral' %>"><%= order.orderStatus %></span></td>
        <td><%= timeAgo(order.createdAt) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('partials/admin-footer') %>
