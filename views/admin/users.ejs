<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container">
    <div class="page-header flex items-center justify-between">
      <h1><%= t('admin.users') %></h1>
      <form method="GET" action="/admin/users" class="flex gap-1">
        <input
          type="text"
          name="q"
          class="input"
          value="<%= q %>"
          placeholder="<%= t('general.search') %>"
          style="max-width: 300px"
        />
        <button type="submit" class="btn btn-primary btn-sm"><%= t('general.search') %></button>
      </form>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= t('auth.username') %></th>
            <th><%= t('auth.email') %></th>
            <th><%= locale === 'ar' ? 'الدور' : 'Role' %></th>
            <th><%= locale === 'ar' ? 'الخطة' : 'Plan' %></th>
            <th><%= locale === 'ar' ? 'الحالة' : 'Status' %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr>
            <td><%= u.username %></td>
            <td><%= u.email %></td>
            <td>
              <span class="badge badge-<%= u.role === 'ADMIN' ? 'info' : 'neutral' %>">
                <%= u.role %>
              </span>
            </td>
            <td>
              <span
                class="badge badge-<%= u.subscription?.plan === 'pro' ? 'success' : 'neutral' %>"
              >
                <%= u.subscription?.plan || 'free' %>
              </span>
            </td>
            <td><%= u.isBanned ? '🚫' : '✅' %></td>
            <td>
              <form
                method="POST"
                action="/admin/users/<%= u.id %>/ban"
                style="display: inline"
                data-confirm="<%= u.isBanned ? 'Unban this user?' : 'Ban this user?' %>"
              >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button
                  type="submit"
                  class="btn btn-sm <%= u.isBanned ? 'btn-success' : 'btn-danger' %>"
                >
                  <%= u.isBanned ? t('admin.unban') : t('admin.ban') %>
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
