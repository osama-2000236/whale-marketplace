<%- include('partials/admin-header') %>
<div class="admin-page">
  <h1><%= t('admin.whale_moderation') %></h1>

  <!-- Pending Verifications -->
  <% if (typeof pendingVerifications !== 'undefined' && pendingVerifications.length) { %>
  <h2><%= t('admin.pending_verifications') %></h2>
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('admin.seller') %></th>
        <th><%= t('admin.sales') %></th>
        <th><%= t('admin.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% pendingVerifications.forEach(sp => { %>
      <tr>
        <td>
          <% if (sp.user && sp.user.avatar) { %><img src="<%= sp.user.avatar %>" alt="" class="thumb-xs"><% } %>
          <%= sp.user ? sp.user.username : sp.userId %>
        </td>
        <td><%= sp.totalSales || 0 %></td>
        <td>
          <form method="post" action="/admin/whale/verify-seller" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="userId" value="<%= sp.userId %>">
            <button type="submit" class="btn btn-sm btn-primary"><%= t('admin.verify') %></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>

  <!-- Active Listings -->
  <% if (typeof listings !== 'undefined' && listings.length) { %>
  <h2><%= t('admin.active_listings') %> (<%= listings.length %>)</h2>
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('admin.title') %></th>
        <th><%= t('admin.seller') %></th>
        <th><%= t('admin.category') %></th>
        <th><%= t('admin.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% listings.forEach(listing => { %>
      <tr>
        <td><a href="/whale/listing/<%= listing.slug || listing.id %>"><%= listing.title %></a></td>
        <td><%= listing.seller ? listing.seller.username : '—' %></td>
        <td><%= listing.category ? listing.category.name : '—' %></td>
        <td>
          <form method="post" action="/admin/whale/suspend-listing" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="listingId" value="<%= listing.id %>">
            <input type="text" name="reason" placeholder="<%= t('admin.reason') %>" class="input-sm">
            <button type="submit" class="btn btn-sm btn-outline btn-danger"><%= t('admin.suspend') %></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>

  <!-- Pending/Disputed Orders -->
  <% if (typeof orders !== 'undefined' && orders.length) { %>
  <h2><%= t('admin.pending_orders') %> (<%= orders.length %>)</h2>
  <table class="admin-table">
    <thead>
      <tr>
        <th>#</th>
        <th><%= t('whale.buyer') %></th>
        <th><%= t('whale.seller') %></th>
        <th><%= t('whale.amount') %></th>
        <th><%= t('whale.status') %></th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach(order => { %>
      <tr>
        <td><a href="/whale/orders/<%= order.id %>"><%= order.orderNumber %></a></td>
        <td><%= order.buyer ? order.buyer.username : '—' %></td>
        <td><%= order.seller ? order.seller.username : '—' %></td>
        <td>&#8362;<%= order.amount %></td>
        <td><span class="status-badge status-<%= {PENDING:'warning',DISPUTED:'danger'}[order.orderStatus] || 'neutral' %>"><%= order.orderStatus %></span></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>

  <!-- Open Disputes -->
  <% if (typeof disputes !== 'undefined' && disputes.length) { %>
  <h2><%= t('admin.open_disputes') %> (<%= disputes.length %>)</h2>
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('admin.dispute') %></th>
        <th><%= t('admin.order') %></th>
        <th><%= t('admin.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% disputes.forEach(dispute => { %>
      <tr>
        <td><%= dispute.id.substring(0, 8) %></td>
        <td><% if (dispute.order) { %><a href="/whale/orders/<%= dispute.order.id %>">#<%= dispute.order.orderNumber %></a><% } else { %>—<% } %></td>
        <td>
          <form method="post" action="/admin/whale/resolve-dispute" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="disputeId" value="<%= dispute.id %>">
            <select name="winner">
              <option value="buyer"><%= t('admin.refund_buyer') %></option>
              <option value="seller"><%= t('admin.release_seller') %></option>
            </select>
            <input type="text" name="resolution" placeholder="<%= t('admin.resolution') %>" class="input-sm">
            <button type="submit" class="btn btn-sm btn-primary"><%= t('admin.resolve') %></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('partials/admin-footer') %>
