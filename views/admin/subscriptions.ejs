<%- include('partials/admin-header') %>

<div class="admin-header-bar">
  <h1>💳 إدارة الاشتراكات | Subscriptions</h1>
</div>

<div class="stats-grid">
  <div class="stat-card stat-green">
    <div class="stat-number">₪ <%= Number(totalRevenue || 0).toLocaleString() %></div>
    <div class="stat-label">إجمالي الإيراد | Total Revenue (NIS)</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= users.length %></div>
    <div class="stat-label">المستخدمون | Users</div>
  </div>
</div>

<div class="admin-card">
  <h3>اشتراكات المستخدمين | User Subscriptions</h3>
  <table class="data-table">
    <thead>
      <tr>
        <th>المستخدم | User</th>
        <th>الخطة | Plan</th>
        <th>نهاية التجربة | Trial Ends</th>
        <th>مدفوع حتى | Paid Until</th>
        <th>الإجراء | Action</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach((user) => { %>
        <tr>
          <td><strong><%= user.username %></strong></td>
          <td>
            <% if (!user.subscription) { %>
              <span class="status-pill free">free</span>
            <% } else if (user.subscription.plan === 'pro') { %>
              <span class="status-pill active">pro</span>
            <% } else { %>
              <span class="status-pill free"><%= user.subscription.plan %></span>
            <% } %>
          </td>
          <td><%= user.subscription && user.subscription.trialEndsAt ? new Date(user.subscription.trialEndsAt).toLocaleDateString('en-GB') : '-' %></td>
          <td><%= user.subscription && user.subscription.paidUntil ? new Date(user.subscription.paidUntil).toLocaleDateString('en-GB') : '-' %></td>
          <td>
            <form class="manual-activate-form" data-user-id="<%= user.id %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <select name="planMonths">
                <option value="1">1 شهر | 1m</option>
                <option value="3">3 أشهر | 3m</option>
                <option value="6">6 أشهر | 6m</option>
                <option value="12">12 شهر | 12m</option>
              </select>
              <input type="text" name="note" value="تفعيل يدوي من الإدارة | Admin manual activation">
              <button type="submit" class="btn btn-sm btn-primary">تفعيل | Activate</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="admin-card">
  <h3>المدفوعات الأخيرة | Recent Payments</h3>
  <table class="data-table">
    <thead>
      <tr>
        <th>المستخدم | User</th>
        <th>المزوّد | Provider</th>
        <th>المبلغ | Amount</th>
        <th>الحالة | Status</th>
        <th>التاريخ | Date</th>
      </tr>
    </thead>
    <tbody>
      <% if (!recentPayments.length) { %>
        <tr><td colspan="5">لا توجد مدفوعات بعد | No payments yet.</td></tr>
      <% } %>
      <% recentPayments.forEach((payment) => { %>
        <tr>
          <td><%= payment.user ? payment.user.username : '-' %></td>
          <td><%= payment.provider %></td>
          <td><%= payment.amount %> <%= payment.currency %></td>
          <td><span class="status-pill <%= payment.status === 'success' ? 'active' : payment.status === 'pending' ? 'trial' : 'expired' %>"><%= payment.status %></span></td>
          <td><%= new Date(payment.createdAt).toLocaleString('en-GB') %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
  document.querySelectorAll('.manual-activate-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const userId = form.dataset.userId;
      const csrf = form.querySelector('input[name="_csrf"]').value;
      const planMonths = form.querySelector('select[name="planMonths"]').value;
      const note = form.querySelector('input[name="note"]').value;

      const res = await fetch('/admin/subscriptions/activate', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-csrf-token': csrf
        },
        body: JSON.stringify({ userId, planMonths, note })
      });

      if (res.ok) {
        window.location.reload();
      } else {
        alert('فشل التفعيل | Activation failed');
      }
    });
  });
</script>

<%- include('partials/admin-footer') %>
