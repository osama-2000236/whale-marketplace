<%- include('partials/admin-header') %>
<div class="admin-page">
  <h1><%= t('admin.subscriptions') %></h1>

  <div class="admin-card">
    <h2><%= t('admin.manual_activate') %></h2>
    <form method="post" action="/admin/subscriptions/activate" class="whale-form inline-form-row">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label><%= t('admin.user_id') %></label>
        <input type="text" name="userId" required placeholder="User ID">
      </div>
      <div class="form-group">
        <label><%= t('admin.months') %></label>
        <input type="number" name="planMonths" value="1" min="1" max="12" required>
      </div>
      <div class="form-group">
        <label><%= t('admin.note') %></label>
        <input type="text" name="note" placeholder="<%= t('admin.optional') %>">
      </div>
      <button type="submit" class="btn btn-primary"><%= t('admin.activate') %></button>
    </form>
  </div>

  <% if (typeof totalRevenue !== 'undefined') { %>
  <div class="stat-card inline-stat">
    <div class="stat-value">&#8362;<%= totalRevenue %></div>
    <div class="stat-label"><%= t('admin.total_revenue') %></div>
  </div>
  <% } %>

  <% if (typeof payments !== 'undefined' && payments.length) { %>
  <h2><%= t('admin.recent_payments') %></h2>
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('admin.user') %></th>
        <th><%= t('payment.amount') %></th>
        <th><%= t('payment.provider') %></th>
        <th><%= t('payment.status') %></th>
        <th><%= t('payment.date') %></th>
      </tr>
    </thead>
    <tbody>
      <% payments.forEach(p => { %>
      <tr>
        <td><%= p.user ? p.user.username : p.userId %></td>
        <td><%= p.amount %> <%= p.currency || '' %></td>
        <td><%= p.provider || '—' %></td>
        <td><span class="status-badge status-<%= p.status === 'success' ? 'success' : 'neutral' %>"><%= p.status %></span></td>
        <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>

  <% if (typeof users !== 'undefined' && users.length) { %>
  <h2><%= t('admin.users_with_subscriptions') %></h2>
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('admin.username') %></th>
        <th><%= t('admin.plan') %></th>
        <th><%= t('admin.paid_until') %></th>
        <th><%= t('admin.trial_ends') %></th>
      </tr>
    </thead>
    <tbody>
      <% users.filter(u => u.subscription).forEach(u => { var sub = u.subscription; %>
      <tr>
        <td><%= u.username %></td>
        <td><%= sub.plan %></td>
        <td><%= sub.paidUntil ? new Date(sub.paidUntil).toLocaleDateString() : '—' %></td>
        <td><%= sub.trialEndsAt ? new Date(sub.trialEndsAt).toLocaleDateString() : '—' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('partials/admin-footer') %>
