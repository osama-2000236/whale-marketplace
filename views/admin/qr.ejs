<%- include('partials/admin-header') %>

<div class="admin-header-bar">
  <h1>🔳 إدارة QR والإحالات | QR & Referral</h1>
</div>

<% if (success) { %>
  <div class="admin-card">✅ تم إنشاء الكود بنجاح | Referral code generated.</div>
<% } %>
<% if (error) { %>
  <div class="admin-card" style="border-color:#ff4757;">❌ خطأ | Error: <%= error %></div>
<% } %>

<div class="admin-grid-2">
  <div class="admin-card">
    <h3>إنشاء QR للعميل | Generate Customer QR</h3>
    <form method="POST" action="/admin/qr/generate" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Label / الوصف</label>
      <input type="text" name="label" required minlength="3" placeholder="Ahmad - PC sale 2026-03-16">
      <button type="submit" class="btn btn-primary">إنشاء | Generate</button>
    </form>
  </div>

  <div class="admin-card">
    <h3>روابط QR العامة | General QR Codes</h3>
    <div class="quick-links">
      <% generalQRs.forEach((item) => { %>
        <div class="recent-item" style="align-items:flex-start; gap:10px;">
          <img src="<%= item.qrDataUrl %>" alt="<%= item.label %>" width="90" height="90">
          <div>
            <strong><%= item.label %></strong>
            <div><a href="<%= item.url %>" target="_blank"><%= item.url %></a></div>
            <a class="btn btn-sm btn-outline" href="/admin/qr/download-general?url=<%= encodeURIComponent(item.url) %>&label=<%= encodeURIComponent(item.label) %>">تنزيل PNG | Download PNG</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<div class="admin-card">
  <h3>أكواد الإحالة | Referral Codes</h3>
  <table class="data-table">
    <thead>
      <tr>
        <th>الكود | Code</th>
        <th>الوصف | Label</th>
        <th>الاستخدام | Used</th>
        <th>تاريخ الإنشاء | Created</th>
        <th>الإجراءات | Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!codes.length) { %>
        <tr><td colspan="5">لا توجد أكواد إحالة بعد | No referral codes yet.</td></tr>
      <% } %>
      <% codes.forEach((code) => { %>
        <tr>
          <td><code><%= code.code %></code></td>
          <td><%= code.label %></td>
          <td><%= code.usedCount %> (<%= code._count.users %> مستخدم | users)</td>
          <td><%= new Date(code.createdAt).toLocaleDateString('en-GB') %></td>
          <td>
            <a class="btn btn-sm btn-outline" href="/admin/qr/download/<%= code.code %>">تنزيل QR | Download QR</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/admin-footer') %>
