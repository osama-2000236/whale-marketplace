<%- include('partials/admin-header') %>
<div class="admin-page">
  <h1><%= t('admin.qr_codes') %></h1>

  <div class="admin-card">
    <h2><%= t('admin.create_code') %></h2>
    <form method="post" action="/admin/qr/generate" class="whale-form inline-form-row">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label><%= t('admin.label') %></label>
        <input type="text" name="label" required placeholder="<%= t('admin.code_label') %>" minlength="3">
      </div>
      <button type="submit" class="btn btn-primary"><%= t('admin.create') %></button>
    </form>
  </div>

  <% if (typeof qrCodes !== 'undefined' && qrCodes.length) { %>
  <h2><%= t('admin.referral_codes') %></h2>
  <div class="qr-grid">
    <% qrCodes.forEach(qr => { %>
    <div class="qr-card">
      <h3><%= qr.label || qr.code %></h3>
      <p class="qr-code-text"><%= qr.code %></p>
      <% if (qr.dataUrl) { %>
      <img src="<%= qr.dataUrl %>" alt="QR" class="qr-image">
      <% } %>
      <p><%= t('admin.uses') %>: <%= qr.usedCount || 0 %></p>
      <div class="qr-actions">
        <a href="<%= qr.url %>" class="btn btn-sm btn-outline" target="_blank"><%= t('admin.open_link') %></a>
        <a href="/admin/qr/download/<%= qr.code %>" class="btn btn-sm btn-outline"><%= t('admin.download') %></a>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>

  <% if (typeof generalQRs !== 'undefined' && generalQRs.length) { %>
  <h2><%= t('admin.general_qr') %></h2>
  <div class="qr-grid">
    <% generalQRs.forEach(g => { %>
    <div class="qr-card">
      <h3><%= g.label %></h3>
      <% if (g.dataUrl) { %>
      <img src="<%= g.dataUrl %>" alt="QR" class="qr-image">
      <% } %>
      <div class="qr-actions">
        <a href="<%= g.url %>" class="btn btn-sm btn-outline" target="_blank"><%= t('admin.open_link') %></a>
        <a href="/admin/qr/download-general?url=<%= encodeURIComponent(g.url) %>&label=<%= encodeURIComponent(g.label) %>" class="btn btn-sm btn-outline"><%= t('admin.download') %></a>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
<%- include('partials/admin-footer') %>
