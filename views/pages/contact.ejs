<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container content-page">
    <h1><%= t('pages.contact_title') %></h1>
    <div class="content-body">
      <p><%= t('pages.contact_desc') %></p>
      <ul>
        <% if (config.contactEmail) { %><li><strong><%= t('pages.email') %>:</strong> <a href="mailto:<%= config.contactEmail %>"><%= config.contactEmail %></a></li><% } %>
        <% if (config.whatsapp) { %><li><strong>WhatsApp:</strong> <a href="https://wa.me/<%= config.whatsapp %>" target="_blank"><%= config.whatsapp %></a></li><% } %>
        <% if (config.telegram) { %><li><strong>Telegram:</strong> <a href="<%= config.telegram %>" target="_blank"><%= config.telegram %></a></li><% } %>
      </ul>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
