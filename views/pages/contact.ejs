<%- include('../partials/header', { title: t('contact.title') + ' — Whale' }) %>
<main class="container section">
  <div style="max-width:560px;margin:0 auto">
    <h1 class="page-title"><%= t('contact.title') %></h1>
    <p style="color:var(--c-mist);margin-bottom:28px"><%= t('contact.sub') %></p>

    <div class="card" style="padding:24px;margin-bottom:14px;display:flex;align-items:center;gap:16px">
      <div style="width:52px;height:52px;border-radius:var(--r-md);background:#E6F7F5;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0">💬</div>
      <div>
        <div style="font-size:15px;font-weight:700;margin-bottom:3px"><%= t('contact.wa_title') %></div>
        <div style="font-size:13px;color:var(--c-mist);margin-bottom:8px"><%= t('contact.wa_sub') %></div>
        <a
          href="https://wa.me/<%= process.env.WHATSAPP_NUMBER || '' %>"
          target="_blank"
          rel="noopener"
          style="display:inline-flex;align-items:center;gap:6px;background:#25D366;color:#fff;padding:8px 18px;border-radius:var(--r-sm);font-size:13px;font-weight:700;text-decoration:none"
        >
          WhatsApp — <%= process.env.WHATSAPP_NUMBER || 'WHATSAPP_NUMBER' %>
        </a>
      </div>
    </div>

    <div class="card" style="padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:52px;height:52px;border-radius:var(--r-md);background:var(--c-sky);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0">✉</div>
      <div>
        <div style="font-size:15px;font-weight:700;margin-bottom:3px"><%= t('contact.email_title') %></div>
        <div style="font-size:13px;color:var(--c-mist);margin-bottom:8px"><%= t('contact.email_sub') %></div>
        <a href="mailto:<%= process.env.CONTACT_EMAIL || 'contact@whale.ps' %>" style="color:var(--c-wave);font-weight:600;font-size:14px">
          <%= process.env.CONTACT_EMAIL || 'CONTACT_EMAIL' %>
        </a>
      </div>
    </div>

    <div style="margin-top:20px;padding:14px;background:var(--c-card2);border-radius:var(--r-md);font-size:13px;color:var(--c-mist);text-align:center">
      <%= t('contact.hours') %><br>
      <%= t('contact.location') %>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
