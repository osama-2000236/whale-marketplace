<%- include('../partials/header', { title: t('about.title') + ' — Whale' }) %>
<main class="container section">
  <div style="max-width:720px;margin:0 auto">
    <h1 class="page-title"><%= t('about.title') %></h1>

    <div class="card" style="padding:32px;margin-bottom:24px">
      <h2 style="font-size:20px;font-weight:700;color:var(--c-ocean);margin-bottom:12px">🐳 <%= t('about.born_title') %></h2>
      <p style="font-size:15px;color:var(--c-slate);line-height:1.8" dir="auto"><%= t('about.born_text') %></p>
    </div>

    <div class="card" style="padding:32px;margin-bottom:24px">
      <h2 style="font-size:20px;font-weight:700;color:var(--c-ocean);margin-bottom:12px">🎯 <%= t('about.mission_title') %></h2>
      <p style="font-size:15px;color:var(--c-slate);line-height:1.8" dir="auto"><%= t('about.mission_text') %></p>
    </div>

    <div class="card" style="padding:32px">
      <h2 style="font-size:20px;font-weight:700;color:var(--c-ocean);margin-bottom:20px"><%= t('about.values_title') %></h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px">
        <div style="text-align:center;padding:20px;background:var(--c-card2);border-radius:var(--r-md)">
          <div style="font-size:28px;margin-bottom:8px">🔒</div>
          <div style="font-weight:700;color:var(--c-ink);margin-bottom:6px"><%= t('about.v1_t') %></div>
          <div style="font-size:13px;color:var(--c-mist)"><%= t('about.v1_d') %></div>
        </div>
        <div style="text-align:center;padding:20px;background:var(--c-card2);border-radius:var(--r-md)">
          <div style="font-size:28px;margin-bottom:8px">🌍</div>
          <div style="font-weight:700;color:var(--c-ink);margin-bottom:6px"><%= t('about.v2_t') %></div>
          <div style="font-size:13px;color:var(--c-mist)"><%= t('about.v2_d') %></div>
        </div>
        <div style="text-align:center;padding:20px;background:var(--c-card2);border-radius:var(--r-md)">
          <div style="font-size:28px;margin-bottom:8px">🤝</div>
          <div style="font-weight:700;color:var(--c-ink);margin-bottom:6px"><%= t('about.v3_t') %></div>
          <div style="font-size:13px;color:var(--c-mist)"><%= t('about.v3_d') %></div>
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
