<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container content-page">
    <h1><%= t('pages.pricing_title') %></h1>
    <div class="pricing-cards">
      <div class="pricing-card">
        <h2><%= t('pages.free_plan') %></h2>
        <div class="pricing-amount"><%= t('pages.free') %></div>
        <ul class="pricing-features">
          <li><%= t('pages.free_feature_1') %></li>
          <li><%= t('pages.free_feature_2') %></li>
          <li><%= t('pages.free_feature_3') %></li>
        </ul>
      </div>
      <div class="pricing-card featured">
        <div class="pricing-badge">PRO</div>
        <h2><%= t('pages.pro_plan') %></h2>
        <div class="pricing-amount">&#8362;29<span>/<%= t('payment.month') %></span></div>
        <ul class="pricing-features">
          <li><%= t('pages.pro_feature_1') %></li>
          <li><%= t('pages.pro_feature_2') %></li>
          <li><%= t('pages.pro_feature_3') %></li>
          <li><%= t('pages.pro_feature_4') %></li>
        </ul>
        <a href="/upgrade" class="btn btn-primary btn-lg btn-block"><%= t('pages.upgrade_now') %></a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
