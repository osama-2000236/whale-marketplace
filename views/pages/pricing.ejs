<%- include('../partials/header', { title: t('pricing.title') + ' — Whale' }) %>
<main class="container section">
  <div style="max-width:820px;margin:0 auto;text-align:center">
    <h1 class="page-title"><%= t('pricing.title') %></h1>
    <p style="color:var(--c-mist);margin-bottom:36px"><%= t('pricing.sub') %></p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:600px;margin:0 auto 40px">
      <div class="card" style="padding:28px;text-align:start">
        <div style="font-size:12px;font-weight:700;color:var(--c-mist);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px"><%= t('pricing.free_t') %></div>
        <div style="font-size:36px;font-weight:800;color:var(--c-ink);margin-bottom:4px"><%= t('pricing.free_p') %></div>
        <div style="font-size:12px;color:var(--c-mist);margin-bottom:20px"><%= lang === 'ar' ? 'للأبد' : 'forever' %></div>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:24px">
          <% ['free_f1','free_f2','free_f3','free_f4'].forEach((k) => { %>
            <li style="font-size:13px;color:var(--c-slate);display:flex;align-items:center;gap:8px">
              <span style="color:var(--c-teal);font-weight:700">✓</span> <%= t('pricing.' + k) %>
            </li>
          <% }) %>
        </ul>
        <% if (!isPro) { %>
          <div style="text-align:center;font-size:12px;font-weight:700;color:var(--c-teal);padding:10px;background:var(--c-teal-lt);border-radius:var(--r-sm)"><%= t('pricing.current') %></div>
        <% } %>
      </div>

      <div class="card" style="padding:28px;text-align:start;border-color:var(--c-ocean);box-shadow:0 0 0 2px var(--c-ocean),var(--shadow-md);position:relative">
        <div style="position:absolute;top:-12px;inset-inline-start:50%;transform:translateX(-50%);background:var(--c-ocean);color:#fff;font-size:11px;font-weight:700;padding:3px 14px;border-radius:20px;white-space:nowrap"><%= lang==='ar' ? '⭐ الأكثر شعبية' : '⭐ Most Popular' %></div>
        <div style="font-size:12px;font-weight:700;color:var(--c-ocean);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px"><%= t('pricing.pro_t') %></div>
        <div style="font-size:36px;font-weight:800;color:var(--c-ocean);margin-bottom:4px"><%= t('pricing.pro_p') %></div>
        <div style="font-size:12px;color:var(--c-teal);font-weight:700;margin-bottom:20px">⚡ <%= t('pricing.trial') %></div>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:24px">
          <% ['pro_f1','pro_f2','pro_f3','pro_f4','pro_f5','pro_f6'].forEach((k) => { %>
            <li style="font-size:13px;color:var(--c-slate);display:flex;align-items:center;gap:8px">
              <span style="color:var(--c-ocean);font-weight:700">✓</span> <%= t('pricing.' + k) %>
            </li>
          <% }) %>
        </ul>
        <% if (isPro) { %>
          <div style="text-align:center;font-size:12px;font-weight:700;color:var(--c-ocean);padding:10px;background:var(--c-sky);border-radius:var(--r-sm)"><%= t('pricing.current') %></div>
        <% } else { %>
          <a href="/upgrade" style="display:block;text-align:center;background:var(--c-ocean);color:#fff;padding:13px;border-radius:var(--r-sm);font-size:14px;font-weight:700;text-decoration:none"><%= t('pricing.cta') %> →</a>
        <% } %>
      </div>
    </div>

    <div style="max-width:560px;margin:0 auto;text-align:start">
      <h2 style="font-size:18px;font-weight:700;margin-bottom:16px"><%= t('pricing.faq_title') %></h2>
      <div class="card" style="padding:20px;margin-bottom:10px">
        <div style="font-weight:700;margin-bottom:6px"><%= t('pricing.faq_q1') %></div>
        <div style="font-size:14px;color:var(--c-slate)"><%= t('pricing.faq_a1') %></div>
      </div>
      <div class="card" style="padding:20px">
        <div style="font-weight:700;margin-bottom:6px"><%= t('pricing.faq_q2') %></div>
        <div style="font-size:14px;color:var(--c-slate)"><%= t('pricing.faq_a2') %></div>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
