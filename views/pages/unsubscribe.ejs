<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container content-page">
    <div class="auth-card">
      <h1><%= t('pages.unsubscribe_title') %></h1>
      <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success"><%= t('pages.unsubscribe_success') %></div>
      <% } else { %>
      <p><%= t('pages.unsubscribe_desc') %></p>
      <form method="post" action="/unsubscribe" class="whale-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
        <button type="submit" class="btn btn-primary"><%= t('pages.unsubscribe_confirm') %></button>
      </form>
      <% } %>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
