<%- include('../partials/header', { title: t('nav.forum') + ' — Whale' }) %>
<main class="container section">
  <div style="max-width:980px;margin:0 auto;">
    <section class="card" style="padding:28px;margin-bottom:16px;background:linear-gradient(145deg,var(--c-card),var(--c-sky));">
      <h1 class="page-title" style="margin-bottom:10px;"><%= t('nav.forum') %></h1>
      <p style="margin:0;color:var(--c-slate);font-size:15px;">
        <%= lang === 'ar'
          ? 'مكان مخصص للأسئلة والمساعدة قبل الشراء أو البيع على Whale.'
          : 'A dedicated help area for buy/sell questions on Whale.' %>
      </p>
    </section>

    <section style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;">
      <article class="card" style="padding:18px;">
        <h3 style="margin:0 0 8px;"><%= lang === 'ar' ? 'شراء آمن' : 'Safe buying' %></h3>
        <p class="muted" style="margin:0;"><%= t('app.trust_promise') %></p>
      </article>
      <article class="card" style="padding:18px;">
        <h3 style="margin:0 0 8px;"><%= lang === 'ar' ? 'حل مشاكل الطلب' : 'Order issues' %></h3>
        <p class="muted" style="margin:0;"><%= lang === 'ar' ? 'إرشادات الشحن، التتبع، وتأكيد الاستلام.' : 'Shipping, tracking, and delivery-confirmation guidance.' %></p>
      </article>
      <article class="card" style="padding:18px;">
        <h3 style="margin:0 0 8px;"><%= lang === 'ar' ? 'دعم البائع' : 'Seller support' %></h3>
        <p class="muted" style="margin:0;"><%= lang === 'ar' ? 'تحسين الإعلان، التسعير، وزيادة المبيعات.' : 'Improve listing quality, pricing, and conversion.' %></p>
      </article>
    </section>

    <section class="card" style="padding:20px;margin-top:14px;">
      <p style="margin:0;color:var(--c-slate);">
        <%= lang === 'ar'
          ? 'للتواصل السريع، استخدم صفحة التواصل أو واتساب.'
          : 'For fast help, use Contact page or WhatsApp support.' %>
      </p>
      <div style="margin-top:12px;display:flex;gap:10px;flex-wrap:wrap;">
        <a class="btn btn-primary" href="/contact"><%= t('footer.contact') %></a>
        <a class="btn btn-ghost" href="/safety"><%= t('footer.safety') %></a>
      </div>
    </section>
  </div>
</main>
<%- include('../partials/footer') %>
