    <p style="color:var(--c-mist);margin-bottom:24px"><%= t('legal.last_updated') %></p>

    <div class="card" style="padding:20px;margin-bottom:12px">
      <h3 style="font-size:16px;margin-bottom:8px"><%= t('legal.bp_how_title') %></h3>
      <p style="line-height:1.8;color:var(--c-slate)"><%= t('legal.bp_how_body') %></p>
    </div>
    <div class="card" style="padding:20px;margin-bottom:12px">
      <h3 style="font-size:16px;margin-bottom:8px"><%= t('legal.bp_what_title') %></h3>
      <p style="line-height:1.8;color:var(--c-slate)"><%= t('legal.bp_what_body') %></p>
    </div>
    <div class="card" style="padding:20px">
      <h3 style="font-size:16px;margin-bottom:8px"><%= t('legal.bp_not_title') %></h3>
      <p style="line-height:1.8;color:var(--c-slate)"><%= t('legal.bp_not_body') %></p>
    </div>
