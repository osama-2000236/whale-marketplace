<%- include('../partials/header', { title: t('footer.terms') + ' — Whale' }) %>
<main class="container section">
  <div style="max-width:760px;margin:0 auto">
    <h1 class="page-title"><%= t('footer.terms') %></h1>
    <p style="color:var(--c-mist);margin-bottom:24px"><%= t('legal.last_updated') %></p>

    <% const sections = Array.from({ length: 8 }, (_unused, index) => {
      const num = index + 1;
      return {
        h: t(`legal.terms.${num}.title`),
        b: t(`legal.terms.${num}.body`)
      };
    }); %>

    <% sections.forEach((s) => { %>
      <div class="card" style="padding:20px;margin-bottom:12px">
        <h3 style="font-size:15px;font-weight:700;margin-bottom:8px"><%= s.h %></h3>
        <p style="font-size:14px;line-height:1.8;color:var(--c-slate)"><%= s.b %></p>
      </div>
    <% }); %>

    <div style="margin-top:20px;padding:16px;background:var(--c-sky);border-radius:var(--r-md);font-size:13px;color:var(--c-ocean)">
      <%= t('legal.terms_contact_intro') %>
      <a href="/contact" style="color:var(--c-ocean);font-weight:700"><%= t('legal.contact_us') %></a>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
