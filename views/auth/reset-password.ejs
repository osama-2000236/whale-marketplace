<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="auth-container">
    <%- include('../partials/flash') %>
    <div class="auth-card">
      <h1><%= t('auth.reset_password') %></h1>
      <p class="subtitle"><%= locale === 'ar' ? 'أدخل كلمة المرور الجديدة' : 'Enter your new password' %></p>

      <form method="POST" action="/auth/reset-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="token" value="<%= token %>" />
        <div class="form-group">
          <label class="form-label"><%= t('auth.new_password') %></label>
          <input type="password" name="password" class="input" required minlength="8" placeholder="<%= locale === 'ar' ? 'كلمة المرور الجديدة (8 أحرف على الأقل)' : 'New password (min 8 characters)' %>" />
        </div>
        <div class="form-group">
          <label class="form-label"><%= locale === 'ar' ? 'تأكيد كلمة المرور' : 'Confirm Password' %></label>
          <input type="password" name="confirmPassword" class="input" required minlength="8" />
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <%= locale === 'ar' ? 'تعيين كلمة المرور' : 'Reset Password' %>
        </button>
      </form>

      <div class="auth-footer">
        <a href="/auth/login"><%= t('auth.login') %></a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
