<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="auth-container">
    <%- include('../partials/flash') %>
    <div class="auth-card">
      <h1><%= t('auth.register') %></h1>
      <p class="subtitle">
        🐋 <%= locale === 'ar' ? 'انضم إلى مجتمع الحوت' : 'Join the Whale community' %>
      </p>

      <% if (hasGoogle) { %>
      <div class="oauth-buttons">
        <a
          href="/auth/google?next=<%= encodeURIComponent(next || '/whale') %>"
          class="btn-google"
        >
          <img src="/icons/google.svg" alt="" width="20" height="20" />
          <%= t('auth.google') %>
        </a>
      </div>

      <div class="auth-or-divider" role="separator" aria-label="<%= locale === 'ar' ? 'أو' : 'or' %>">
        <%= locale === 'ar' ? 'أو' : 'or' %>
      </div>

      <details class="auth-local-disclosure">
        <summary
          class="auth-local-toggle"
          id="show-local-register"
          aria-controls="local-register-form"
        >
          <%= locale === 'ar' ? 'إنشاء حساب بالبريد الإلكتروني' : 'Register with email instead' %>
        </summary>

      <div class="auth-local-form" id="local-register-form">
      <% } %>

        <form method="POST" action="/auth/register">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '/whale' %>" />
          <div class="form-group">
            <label class="form-label">
              <%= t('auth.username') %>
              <span class="required">*</span>
            </label>
            <input
              type="text"
              name="username"
              class="input"
              required
              minlength="3"
              maxlength="30"
              pattern="[a-zA-Z0-9_]+"
              placeholder="<%= locale === 'ar' ? 'أحرف وأرقام فقط' : 'Letters, numbers, underscore' %>"
            />
          </div>
          <div class="form-group">
            <label class="form-label">
              <%= t('auth.email') %>
              <span class="required">*</span>
            </label>
            <input type="email" name="email" class="input" required />
          </div>
          <div class="form-group">
            <label class="form-label">
              <%= t('auth.password') %>
              <span class="required">*</span>
            </label>
            <input type="password" name="password" class="input" required minlength="8" />
          </div>
          <div class="form-group">
            <label class="form-label">
              <%= locale === 'ar' ? 'تأكيد كلمة المرور' : 'Confirm Password' %>
              <span class="required">*</span>
            </label>
            <input type="password" name="confirmPassword" class="input" required minlength="8" />
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg">
            <%= t('auth.register') %>
          </button>
        </form>

      <% if (hasGoogle) { %>
      </div><!-- /#local-register-form -->
      </details>
      <% } %>

      <div class="auth-footer">
        <%= t('auth.has_account') %>
        <a href="/auth/login?next=<%= encodeURIComponent(next || '/whale') %>"><%= t('auth.login') %></a>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
</body>
</html>
