<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="form-page auth-page">
    <div class="auth-card">
      <h1><%= t('auth.register') %></h1>
      <div class="trial-badge"><%= t('auth.free_trial') %></div>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form method="post" action="/auth/register" class="whale-form" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (typeof referralCode !== 'undefined' && referralCode) { %>
        <input type="hidden" name="referralCode" value="<%= referralCode %>">
        <% } %>
        <div class="form-group">
          <label><%= t('auth.username') %></label>
          <input type="text" name="username" required minlength="3" maxlength="30" pattern="[a-zA-Z0-9_-]+" title="<%= t('auth.username_hint') %>">
        </div>
        <div class="form-group">
          <label><%= t('auth.email') %></label>
          <input type="email" name="email" required>
        </div>
        <div class="form-group">
          <label><%= t('auth.password') %></label>
          <input type="password" name="password" required minlength="6">
        </div>
        <div class="form-group">
          <label><%= t('auth.avatar') %> (<%= t('auth.optional') %>)</label>
          <input type="file" name="avatar" accept="image/*">
        </div>
        <div class="form-group">
          <label><%= t('auth.bio') %> (<%= t('auth.optional') %>)</label>
          <textarea name="bio" rows="2" maxlength="500"></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg btn-block"><%= t('auth.create_account') %></button>
      </form>

      <div class="auth-divider"><span><%= t('auth.or') %></span></div>

      <div class="oauth-buttons">
        <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
        <a href="/auth/google" class="btn btn-outline btn-block btn-oauth btn-google">
          <img src="/images/google-icon.svg" alt="" class="oauth-icon"> <%= t('auth.signup_google') %>
        </a>
        <% } %>
        <% if (typeof facebookEnabled !== 'undefined' && facebookEnabled) { %>
        <a href="/auth/facebook" class="btn btn-outline btn-block btn-oauth btn-facebook">
          <img src="/images/facebook-icon.svg" alt="" class="oauth-icon"> <%= t('auth.signup_facebook') %>
        </a>
        <% } %>
        <% if (typeof appleEnabled !== 'undefined' && appleEnabled) { %>
        <a href="/auth/apple" class="btn btn-outline btn-block btn-oauth btn-apple">
          <img src="/images/apple-icon.svg" alt="" class="oauth-icon"> <%= t('auth.signup_apple') %>
        </a>
        <% } %>
      </div>

      <p class="auth-switch"><%= t('auth.have_account') %> <a href="/auth/login"><%= t('auth.login') %></a></p>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
