<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="form-page auth-page">
    <div class="auth-card">
      <h1><%= t('auth.register') %></h1>
      <div class="trial-badge"><%= t('auth.free_trial') %></div>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form method="post" action="/auth/register" class="whale-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (typeof referralCode !== 'undefined' && referralCode) { %>
        <input type="hidden" name="referralCode" value="<%= referralCode %>">
        <% } %>
        <div class="form-group">
          <label><%= t('auth.username') %></label>
          <input type="text" name="username" required minlength="3" maxlength="30" pattern="[a-zA-Z0-9_-]+" title="<%= t('auth.username_hint') %>">
        </div>
        <div class="form-group">
          <label><%= t('auth.email') %></label>
          <input type="email" name="email" required>
        </div>
        <div class="form-group">
          <label><%= t('auth.password') %></label>
          <input type="password" name="password" required minlength="6">
        </div>
        <div class="form-group">
          <label><%= t('auth.avatar') %> (<%= t('auth.optional') %>)</label>
          <input type="file" name="avatar" accept="image/*">
        </div>
        <div class="form-group">
          <label><%= t('auth.bio') %> (<%= t('auth.optional') %>)</label>
          <textarea name="bio" rows="2" maxlength="500"></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg btn-block"><%= t('auth.create_account') %></button>
      </form>

      <div class="auth-divider"><span><%= t('auth.or') %></span></div>

      <div class="oauth-buttons">
        <% var oe = typeof oauthEnabled !== 'undefined' ? oauthEnabled : {}; %>
        <a href="<%= oe.google ? '/auth/google' : '#' %>" class="btn btn-outline btn-block btn-oauth btn-google <%= !oe.google ? 'btn-disabled' : '' %>" <%= !oe.google ? 'onclick="return false;" title="' + t('oauth.google_unavailable') + '"' : '' %>>
          <svg class="oauth-icon" width="20" height="20" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          <%= t('auth.signup_google') %>
        </a>
        <a href="<%= oe.facebook ? '/auth/facebook' : '#' %>" class="btn btn-outline btn-block btn-oauth btn-facebook <%= !oe.facebook ? 'btn-disabled' : '' %>" <%= !oe.facebook ? 'onclick="return false;" title="' + t('oauth.facebook_unavailable') + '"' : '' %>>
          <svg class="oauth-icon" width="20" height="20" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          <%= t('auth.signup_facebook') %>
        </a>
        <a href="<%= oe.apple ? '/auth/apple' : '#' %>" class="btn btn-outline btn-block btn-oauth btn-apple <%= !oe.apple ? 'btn-disabled' : '' %>" <%= !oe.apple ? 'onclick="return false;" title="' + t('oauth.apple_unavailable') + '"' : '' %>>
          <svg class="oauth-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
          <%= t('auth.signup_apple') %>
        </a>
      </div>

      <p class="auth-switch"><%= t('auth.have_account') %> <a href="/auth/login"><%= t('auth.login') %></a></p>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
