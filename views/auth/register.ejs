<%- include('../partials/header') %>

<section class="page-section auth-page">
  <div class="container auth-grid">
    <div class="auth-card">
      <div class="auth-brand">
        <div class="brand-icon auth-logo">
          <svg width="28" height="28" viewBox="0 0 56 56" fill="none" aria-hidden="true">
            <ellipse cx="26" cy="30" rx="18" ry="13" fill="var(--c-ocean)"/>
            <ellipse cx="16" cy="26" rx="10" ry="9" fill="var(--c-ocean)"/>
            <circle cx="13" cy="24" r="2.5" fill="white"/>
            <path d="M42 32 Q50 24 52 30 Q48 34 44 35 Z" fill="var(--c-wave)"/>
            <path d="M42 34 Q50 42 52 37 Q48 33 44 32 Z" fill="var(--c-wave)"/>
          </svg>
        </div>
        <div class="brand-name">Whale</div>
        <div class="trial-pill"><%= t('register.trial') %></div>
      </div>
      <h1 class="auth-title"><%= t('register.title') %></h1>

      <% if (error) { %>
        <div class="alert alert-err"><%= error %></div>
      <% } %>

      <form method="POST" action="/auth/register" class="auth-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (formData.ref) { %>
          <input type="hidden" name="ref" value="<%= formData.ref %>">
        <% } %>

        <% if (formData.ref) { %>
          <div class="alert alert-ok">🎁 <%= t('register.ref_active') %>: <strong><%= formData.ref %></strong></div>
        <% } %>

        <label for="username"><%= t('register.username') %></label>
        <input id="username" type="text" name="username" required value="<%= formData.username || '' %>">

        <label for="email"><%= t('register.email') %></label>
        <input id="email" type="email" name="email" required value="<%= formData.email || '' %>">

        <label for="password"><%= t('register.password') %></label>
        <input id="password" type="password" name="password" minlength="8" required>

        <button type="submit" class="btn btn-primary btn-full"><%= t('register.submit') %></button>
      </form>

      <% if (oauthEnabled && (oauthEnabled.google || oauthEnabled.facebook || oauthEnabled.apple)) { %>
        <div class="auth-divider"><%= t('oauth.or_sign_up_with') %></div>
        <div class="oauth-buttons">
          <% if (oauthEnabled.google) { %>
            <a href="/auth/google" class="oauth-btn oauth-google" aria-label="Sign up with Google">
              <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              <span>Google</span>
            </a>
          <% } %>
          <% if (oauthEnabled.facebook) { %>
            <a href="/auth/facebook" class="oauth-btn oauth-facebook" aria-label="Sign up with Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              <span>Facebook</span>
            </a>
          <% } %>
          <% if (oauthEnabled.apple) { %>
            <a href="/auth/apple" class="oauth-btn oauth-apple" aria-label="Sign up with Apple">
              <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <span>Apple</span>
            </a>
          <% } %>
        </div>
      <% } %>
      <p class="auth-switch" style="margin-top:8px;"><%= t('register.terms_consent') %> <a href="/terms"><%= t('footer.terms') %></a> · <a href="/privacy"><%= t('footer.privacy') %></a></p>
      <p class="auth-switch"><%= t('register.have_acct') %> <a href="/auth/login"><%= t('register.login_cta') %></a></p>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
