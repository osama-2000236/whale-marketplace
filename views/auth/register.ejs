<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="auth-container">
    <%- include('../partials/flash') %>
    <div class="auth-card">
      <h1><%= t('auth.register') %></h1>
      <p class="subtitle">
        🐋 <%= locale === 'ar' ? 'انضم إلى مجتمع الحوت' : 'Join the Whale community' %>
      </p>

      <% const hasOAuth = (typeof process !== 'undefined' && process.env &&
      (process.env.GOOGLE_CLIENT_ID || process.env.FACEBOOK_APP_ID ||
      process.env.APPLE_SERVICE_ID)); %>
      <% if (hasOAuth) { %>
      <div class="oauth-buttons">
        <% if (process.env.GOOGLE_CLIENT_ID) { %>
        <a href="/auth/google" class="btn btn-secondary btn-block">
          <img
            src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
            alt=""
            width="18"
            height="18"
          />
          <%= t('auth.google') %>
        </a>
        <% } %>
        <% if (process.env.FACEBOOK_APP_ID) { %>
        <a
          href="/auth/facebook"
          class="btn btn-secondary btn-block"
          style="background: #1877f2; color: #fff; border-color: #1877f2"
        >
          &#xf09a; Facebook
        </a>
        <% } %>
        <% if (process.env.APPLE_SERVICE_ID) { %>
        <a
          href="/auth/apple"
          class="btn btn-secondary btn-block"
          style="background: #000; color: #fff; border-color: #000"
        >
          &#xf179; Apple
        </a>
        <% } %>
      </div>
      <div class="divider"><%= locale === 'ar' ? 'أو' : 'or' %></div>
      <% } %>

      <form method="POST" action="/auth/register">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <label class="form-label">
            <%= t('auth.username') %>
            <span class="required">*</span>
          </label>
          <input
            type="text"
            name="username"
            class="input"
            required
            minlength="3"
            maxlength="30"
            pattern="[a-zA-Z0-9_]+"
            placeholder="<%= locale === 'ar' ? 'أحرف وأرقام فقط' : 'Letters, numbers, underscore' %>"
          />
        </div>
        <div class="form-group">
          <label class="form-label">
            <%= t('auth.email') %>
            <span class="required">*</span>
          </label>
          <input type="email" name="email" class="input" required />
        </div>
        <div class="form-group">
          <label class="form-label">
            <%= t('auth.password') %>
            <span class="required">*</span>
          </label>
          <input type="password" name="password" class="input" required minlength="8" />
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <%= t('auth.register') %>
        </button>
      </form>

      <div class="auth-footer">
        <%= t('auth.has_account') %>
        <a href="/auth/login"><%= t('auth.login') %></a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
