<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="auth-container">
    <%- include('../partials/flash') %>
    <div class="auth-card">
      <h1><%= t('auth.forgot_password') %></h1>
      <p class="subtitle"><%= locale === 'ar' ? 'أدخل بريدك الإلكتروني لاستعادة كلمة المرور' : 'Enter your email to reset your password' %></p>

      <form method="POST" action="/auth/forgot-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <label class="form-label"><%= t('auth.email') %></label>
          <input type="email" name="email" class="input" required placeholder="<%= locale === 'ar' ? 'البريد الإلكتروني' : 'your@email.com' %>" />
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <%= locale === 'ar' ? 'إرسال رابط الاستعادة' : 'Send Reset Link' %>
        </button>
      </form>

      <div class="auth-footer">
        <a href="/auth/login"><%= t('auth.login') %></a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
