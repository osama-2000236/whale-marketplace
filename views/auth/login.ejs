<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="form-page auth-page">
    <div class="auth-card">
      <h1><%= t('auth.login') %></h1>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success"><%= success %></div>
      <% } %>

      <form method="post" action="/auth/login" class="whale-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label><%= t('auth.email_or_username') %></label>
          <input type="text" name="identifier" required autofocus>
        </div>
        <div class="form-group">
          <label><%= t('auth.password') %></label>
          <input type="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-primary btn-lg btn-block"><%= t('auth.login') %></button>
      </form>

      <div class="auth-divider"><span><%= t('auth.or') %></span></div>

      <div class="oauth-buttons">
        <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
        <a href="/auth/google" class="btn btn-outline btn-block btn-oauth btn-google">
          <img src="/images/google-icon.svg" alt="" class="oauth-icon"> <%= t('auth.login_google') %>
        </a>
        <% } %>
        <% if (typeof facebookEnabled !== 'undefined' && facebookEnabled) { %>
        <a href="/auth/facebook" class="btn btn-outline btn-block btn-oauth btn-facebook">
          <img src="/images/facebook-icon.svg" alt="" class="oauth-icon"> <%= t('auth.login_facebook') %>
        </a>
        <% } %>
        <% if (typeof appleEnabled !== 'undefined' && appleEnabled) { %>
        <a href="/auth/apple" class="btn btn-outline btn-block btn-oauth btn-apple">
          <img src="/images/apple-icon.svg" alt="" class="oauth-icon"> <%= t('auth.login_apple') %>
        </a>
        <% } %>
      </div>

      <p class="auth-switch"><%= t('auth.no_account') %> <a href="/auth/register"><%= t('auth.register') %></a></p>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
