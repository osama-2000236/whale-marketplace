<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="auth-container">
    <%- include('../partials/flash') %>
    <div class="auth-card">
      <h1><%= t('auth.login') %></h1>
      <p class="subtitle">🐋 <%= locale === 'ar' ? 'مرحباً بعودتك' : 'Welcome back' %></p>

      <% if (hasGoogle) { %>
      <div class="oauth-buttons">
        <a
          href="/auth/google?next=<%= encodeURIComponent(next || '/whale') %>"
          class="btn-google"
        >
          <img src="/icons/google.svg" alt="" width="20" height="20" />
          <%= t('auth.google') %>
        </a>
      </div>

      <div class="auth-or-divider" role="separator" aria-label="<%= locale === 'ar' ? 'أو' : 'or' %>">
        <%= locale === 'ar' ? 'أو' : 'or' %>
      </div>

      <details class="auth-local-disclosure">
        <summary
          class="auth-local-toggle"
          id="show-local-login"
          aria-controls="local-login-form"
        >
          <%= locale === 'ar' ? 'تسجيل الدخول بكلمة المرور' : 'Sign in with password instead' %>
        </summary>

      <div class="auth-local-form" id="local-login-form">
      <% } %>

        <form method="POST" action="/auth/login">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input
            type="hidden"
            name="next"
            value="<%= typeof next !== 'undefined' ? next : '/whale' %>"
          />
          <div class="form-group">
            <label class="form-label"><%= t('auth.identifier') %></label>
            <input
              type="text"
              name="identifier"
              class="input"
              required
              placeholder="<%= locale === 'ar' ? 'البريد أو اسم المستخدم' : 'Email or username' %>"
            />
          </div>
          <div class="form-group">
            <label class="form-label"><%= t('auth.password') %></label>
            <input type="password" name="password" class="input" required minlength="8" />
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg">
            <%= t('auth.login') %>
          </button>
        </form>

        <div class="auth-links">
          <a href="/auth/forgot-password"><%= t('auth.forgot_password') %></a>
        </div>

      <% if (hasGoogle) { %>
      </div><!-- /#local-login-form -->
      </details>
      <% } %>

      <div class="auth-footer">
        <%= t('auth.no_account') %>
        <a href="/auth/register?next=<%= encodeURIComponent(next || '/whale') %>"><%= t('auth.register') %></a>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
</body>
</html>
