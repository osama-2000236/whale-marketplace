<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="auth-container">
    <%- include('../partials/flash') %>
    <div class="auth-card">
      <h1><%= t('auth.login') %></h1>
      <p class="subtitle">🐋 <%= locale === 'ar' ? 'مرحباً بعودتك' : 'Welcome back' %></p>

      <% if (hasGoogle || hasFacebook || hasApple) { %>
      <div class="oauth-buttons">
        <% if (hasGoogle) { %>
        <a href="/auth/google" class="btn btn-secondary btn-block">
          <img
            src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
            alt=""
            width="18"
            height="18"
          />
          <%= t('auth.google') %>
        </a>
        <% } %>
        <% if (hasFacebook) { %>
        <a
          href="/auth/facebook"
          class="btn btn-secondary btn-block"
          style="background: #1877f2; color: #fff; border-color: #1877f2"
        >
          &#xf09a; Facebook
        </a>
        <% } %>
        <% if (hasApple) { %>
        <a
          href="/auth/apple"
          class="btn btn-secondary btn-block"
          style="background: #000; color: #fff; border-color: #000"
        >
          &#xf179; Apple
        </a>
        <% } %>
      </div>
      <div class="divider"><%= locale === 'ar' ? 'أو' : 'or' %></div>
      <% } %>

      <form method="POST" action="/auth/login">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input
          type="hidden"
          name="next"
          value="<%= typeof next !== 'undefined' ? next : '/whale' %>"
        />
        <div class="form-group">
          <label class="form-label"><%= t('auth.identifier') %></label>
          <input
            type="text"
            name="identifier"
            class="input"
            required
            placeholder="<%= locale === 'ar' ? 'البريد أو اسم المستخدم' : 'Email or username' %>"
          />
        </div>
        <div class="form-group">
          <label class="form-label"><%= t('auth.password') %></label>
          <input type="password" name="password" class="input" required minlength="8" />
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <%= t('auth.login') %>
        </button>
      </form>

      <div class="auth-footer">
        <%= t('auth.no_account') %>
        <a href="/auth/register"><%= t('auth.register') %></a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
