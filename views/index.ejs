<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">🎮 <%= config.stats.followers %> متابع</div>
    <h1 class="hero-title">PC GAMING</h1>
    <p class="hero-subtitle"><%= config.tagline %></p>
    <p class="hero-desc"><%= config.description %></p>
    <div class="hero-buttons">
      <a href="https://wa.me/<%= whatsappNumber %>" class="btn btn-primary" target="_blank">📱 تواصل عبر واتساب</a>
      <a href="/products" class="btn btn-outline">🛒 تصفح المنتجات</a>
    </div>
  </div>
</section>

<!-- Features -->
<section class="section features-section">
  <div class="container">
    <div class="features-grid">
      <% config.features.forEach(f => { %>
      <div class="feature-card">
        <span class="feature-icon"><%= f.icon %></span>
        <h3><%= f.title %></h3>
        <p><%= f.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Featured Products -->
<% if (featuredProducts.length > 0) { %>
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>منتجات مميزة</h2>
      <div class="section-line"></div>
      <p>أفضل العروض والمنتجات المختارة لك</p>
    </div>
    <div class="products-grid">
      <% featuredProducts.forEach(product => { %>
        <%- include('partials/product-card', { product }) %>
      <% }) %>
    </div>
    <div class="section-cta">
      <a href="/products" class="btn btn-outline">عرض جميع المنتجات ←</a>
    </div>
  </div>
</section>
<% } %>

<!-- Categories -->
<section class="section categories-section">
  <div class="container">
    <div class="section-header">
      <h2>أقسام المتجر</h2>
      <div class="section-line"></div>
    </div>
    <div class="categories-grid">
      <% categories.forEach(cat => { %>
      <a href="/products?category=<%= cat.id %>" class="category-card">
        <span class="category-icon"><%= cat.icon %></span>
        <h3><%= cat.nameAr %></h3>
        <p><%= cat.description %></p>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="section cta-section">
  <div class="container">
    <div class="cta-box">
      <h2>هل تبحث عن جهاز معين؟</h2>
      <p>تواصل معنا عبر واتساب وسنساعدك في اختيار الجهاز المناسب لك</p>
      <a href="https://wa.me/<%= whatsappNumber %>?text=مرحبا، أريد الاستفسار عن منتج" target="_blank" class="btn btn-primary btn-lg">💬 تواصل الآن</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
