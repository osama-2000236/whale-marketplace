<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container" style="max-width: 800px">
    <%- include('../partials/flash') %>
    <div class="text-center mb-3">
      <h1><%= t('upgrade.title') %></h1>
      <p class="text-muted"><%= t('upgrade.subtitle') %></p>
      <% if (user.subscription) { %>
      <p class="text-sm">
        <%= t('upgrade.current_plan') %>:
        <span class="badge badge-info"><%= user.subscription.plan %></span>
      </p>
      <% } %>
    </div>

    <div class="grid-stats" style="grid-template-columns: repeat(3, 1fr)">
      <% Object.entries(plans).forEach(([months, plan]) => { %>
      <div class="card text-center" style="padding: 2rem">
        <h3>
          <% if (Number(months) === 1) { %><%= t('upgrade.monthly') %><% } %>
          <% if (Number(months) === 6) { %><%= t('upgrade.semiannual') %><% } %>
          <% if (Number(months) === 12) { %><%= t('upgrade.annual') %><% } %>
        </h3>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--brand); margin: 1rem 0">
          $<%= plan.price %>
        </div>
        <p class="text-muted text-sm mb-2">
          <%= months %> <%= locale === 'ar' ? 'شهر' : 'months' %>
        </p>

        <% if (providerAvailability.paymob) { %>
        <form method="POST" action="/upgrade/paymob" style="margin-bottom: 0.5rem">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="planMonths" value="<%= months %>" />
          <button type="submit" class="btn btn-primary btn-block">
            <%= t('upgrade.pay_paymob') %>
          </button>
        </form>
        <% } %>
        <% if (providerAvailability.stripe) { %>
        <form method="POST" action="/upgrade/stripe" style="margin-bottom: 0.5rem">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="planMonths" value="<%= months %>" />
          <button type="submit" class="btn btn-secondary btn-block">
            <%= locale === 'ar' ? '💳 فيزا / ماستركارد' : '💳 Visa / Mastercard' %>
          </button>
        </form>
        <% } %>
        <% if (providerAvailability.paypal) { %>
        <form method="POST" action="/upgrade/paypal">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="planMonths" value="<%= months %>" />
          <button type="submit" class="btn btn-ghost btn-block">
            <%= t('upgrade.pay_paypal') %>
          </button>
        </form>
        <% } %>
        <% if (!providerAvailability.paymob && !providerAvailability.stripe && !providerAvailability.paypal) { %>
        <p class="text-muted text-sm" style="margin: 0">
          <%= locale === 'ar' ? 'لا توجد وسائل دفع مفعلة حالياً.' : 'No online payment providers are configured right now.' %>
        </p>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
