<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <h1><%= t('payment.upgrade_to_pro') %></h1>

    <div class="pricing-cards">
      <div class="pricing-card">
        <h2><%= t('payment.monthly') %></h2>
        <div class="pricing-amount">&#8362;29<span>/<%= t('payment.month') %></span></div>
        <ul class="pricing-features">
          <li><%= t('payment.feature_listings') %></li>
          <li><%= t('payment.feature_priority') %></li>
          <li><%= t('payment.feature_badge') %></li>
          <li><%= t('payment.feature_analytics') %></li>
        </ul>
        <form method="post" action="/payment/start" class="whale-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="months" value="1">
          <input type="hidden" name="provider" value="paymob">
          <button type="submit" class="btn btn-primary btn-lg btn-block"><%= t('payment.pay_paymob') %></button>
        </form>
        <form method="post" action="/payment/start" class="whale-form" style="margin-top:8px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="months" value="1">
          <input type="hidden" name="provider" value="paypal">
          <button type="submit" class="btn btn-outline btn-lg btn-block"><%= t('payment.pay_paypal') %></button>
        </form>
      </div>

      <div class="pricing-card featured">
        <div class="pricing-badge"><%= t('payment.best_value') %></div>
        <h2><%= t('payment.yearly') %></h2>
        <div class="pricing-amount">&#8362;249<span>/<%= t('payment.year') %></span></div>
        <div class="pricing-savings"><%= t('payment.save_30') %></div>
        <ul class="pricing-features">
          <li><%= t('payment.feature_listings') %></li>
          <li><%= t('payment.feature_priority') %></li>
          <li><%= t('payment.feature_badge') %></li>
          <li><%= t('payment.feature_analytics') %></li>
        </ul>
        <form method="post" action="/payment/start" class="whale-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="months" value="12">
          <input type="hidden" name="provider" value="paymob">
          <button type="submit" class="btn btn-primary btn-lg btn-block"><%= t('payment.pay_paymob') %></button>
        </form>
        <form method="post" action="/payment/start" class="whale-form" style="margin-top:8px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="months" value="12">
          <input type="hidden" name="provider" value="paypal">
          <button type="submit" class="btn btn-outline btn-lg btn-block"><%= t('payment.pay_paypal') %></button>
        </form>
      </div>
    </div>

    <%- include('../partials/trust-box') %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
