<%- include('../partials/header') %>

<section class="page-section">
  <div class="container" style="max-width: 960px;">
    <h1 class="page-title">PAYMOB CHECKOUT | الدفع</h1>
    <div class="panel-card">
      <p>أكمل الدفع بأمان في الإطار التالي | Complete secure checkout below.</p>
      <div style="aspect-ratio: 16 / 10; width:100%;">
        <iframe
          src="<%= iframeUrl %>"
          title="Paymob Checkout"
          style="width:100%; height:100%; border:0; border-radius:10px; background:#fff;"
          allow="payment"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
