<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head><%- include('../partials/head') %></head>
<body class="<%= bodyClass %>">
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-container">
    <h1><%= t('payment.history') %></h1>

    <% if (typeof subscription !== 'undefined' && subscription) { %>
    <div class="admin-card">
      <h2><%= t('payment.current_plan') %></h2>
      <p><strong><%= t('payment.plan') %>:</strong> <%= subscription.plan %></p>
      <% if (subscription.paidUntil) { %>
      <p><strong><%= t('payment.paid_until') %>:</strong> <%= new Date(subscription.paidUntil).toLocaleDateString(lang === 'ar' ? 'ar-PS' : 'en-US') %></p>
      <% } %>
      <% if (subscription.trialEndsAt && new Date(subscription.trialEndsAt) > new Date()) { %>
      <p><strong><%= t('payment.trial_ends') %>:</strong> <%= new Date(subscription.trialEndsAt).toLocaleDateString(lang === 'ar' ? 'ar-PS' : 'en-US') %></p>
      <% } %>
    </div>
    <% } %>

    <% if (typeof payments !== 'undefined' && payments.length) { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th><%= t('payment.date') %></th>
          <th><%= t('payment.amount') %></th>
          <th><%= t('payment.months') %></th>
          <th><%= t('payment.provider') %></th>
          <th><%= t('payment.status') %></th>
        </tr>
      </thead>
      <tbody>
        <% payments.forEach(p => { %>
        <tr>
          <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
          <td><%= p.amount %> <%= p.currency %></td>
          <td><%= p.months %></td>
          <td><%= p.provider %></td>
          <td><span class="status-badge status-<%= p.status === 'completed' ? 'success' : 'neutral' %>"><%= p.status %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %>
    <div class="empty-state">
      <h3><%= t('payment.no_history') %></h3>
      <a href="/upgrade" class="btn btn-primary"><%= t('payment.upgrade') %></a>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
