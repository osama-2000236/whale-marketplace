<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="container" style="max-width: 500px">
    <div class="card text-center" style="padding: 3rem">
      <div style="font-size: 4rem; margin-bottom: 1rem">🎉</div>
      <h1><%= t('payment.success') %></h1>
      <p class="text-muted mt-1"><%= t('payment.success.desc') %></p>
      <div class="mt-3">
        <a href="<%= primaryHref || '/whale/sell' %>" class="btn btn-primary btn-lg">
          <%= primaryLabel || t('nav.sell') %>
        </a>
        <a href="<%= secondaryHref || '/whale' %>" class="btn btn-ghost btn-lg">
          <%= secondaryLabel || t('nav.browse') %>
        </a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
