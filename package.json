{
  "name": "pc-gaming-website",
  "version": "1.0.0",
  "description": "Full-stack website for PC Gaming - Tulkarem, Palestine. Computers, Laptops & Accessories.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node prisma/seed.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:unit": "cross-env NODE_ENV=test jest --runInBand --testPathPatterns=unit",
    "test:component": "cross-env NODE_ENV=test jest --runInBand --testPathPatterns=component",
    "test:integration": "cross-env NODE_ENV=test jest --runInBand --testPathPatterns=integration",
    "test:security": "cross-env NODE_ENV=test jest --runInBand --testPathPatterns=security",
    "test:watch": "cross-env NODE_ENV=test jest --runInBand --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "claude:check": "node scripts/claude-check.js",
    "agent": "node agent.js",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "test:ui:report": "playwright show-report",
    "test:ui:a11y": "playwright test --grep @accessibility",
    "test:ui:mobile": "playwright test --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
    "test:ui:visual": "playwright test --grep @visual",
    "test:ui:perf": "playwright test --grep @performance"
  },
  "keywords": [
    "pc-gaming",
    "ecommerce",
    "tulkarem",
    "palestine"
  ],
  "author": "Osama Abu Jarad",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@prisma/client": "^6.7.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.7.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "isomorphic-dompurify": "^3.3.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^17.0.4",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "qrcode": "^1.5.4",
    "slugify": "^1.6.8",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "axe-playwright": "^2.2.2",
    "chrome-launcher": "^1.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-extended": "^7.0.0",
    "lighthouse": "^13.0.3",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.1.4",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "prisma": "^6.7.0",
    "supertest": "^7.2.2"
  }
}
