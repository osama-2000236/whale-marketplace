{
  "name": "whale-marketplace",
  "version": "2.0.0",
  "description": "Whale (الحوت) — Trust-first peer-to-peer marketplace for Palestine and Arab cities",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node entrypoint.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "build": "prisma generate",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,css}\"",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage",
    "test:ui": "playwright test",
    "test:ui:html": "playwright test --reporter=html && playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@prisma/client": "^6.19.2",
    "@sendgrid/mail": "^8.1.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.0.0",
    "connect-pg-simple": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "dotenv": "^16.4.0",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "marked": "^12.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "slugify": "^1.6.6",
    "stripe": "^21.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.0",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ejs": "^1.0.3",
    "prisma": "^6.19.2",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "effect": "^3.20.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
